---
import Layout from '../layouts/Layout.astro';
const title = "About";
const description = "About TopCasinoScout Our Commitment to Casino Transparency TopCasinoScout is an independent, player-first casino comparison platform. We specialise in r...";
const content = "<section style=\"background:#05051b; padding:70px 20px 90px;\">\n  <div style=\"max-width:1100px; margin:0 auto; color:#d5e0ff;\">\n\n    <!-- HEADER -->\n    <h1 style=\"color:#ffcc33; font-size:2.4rem; margin-bottom:16px; text-transform:uppercase; letter-spacing:.06em; text-shadow:0 0 18px rgba(255,204,51,.35);\">\n      About TopCasinoScout\n    </h1>\n\n    <!-- INTRO SECTION -->\n    <div style=\"background:#0b0b24; border:1px solid #2c2c6a; padding:22px 26px; border-radius:18px; margin-bottom:26px; box-shadow:0 0 24px rgba(255,204,51,.07);\">\n      <h2 style=\"color:#ffcc33; font-size:1.35rem; margin-bottom:10px;\">Our Commitment to Casino Transparency</h2>\n      <p style=\"color:#cbd6ff; line-height:1.7; font-size:1rem;\">\n        <strong>TopCasinoScout</strong> is an independent, player-first casino comparison platform. We specialise in\n        reviewing online casinos through a safety lens \u2013 focusing on <strong>licensing integrity, fair bonus terms,\n        fast and reliable withdrawals, and responsible gambling standards</strong>. Our work combines detailed human\n        audits with advanced AI-assisted research so that every recommendation is\n        <strong>traceable, explainable, and openly disclosed</strong>.\n      </p>\n    </div>\n\n    <p style=\"font-size:1.06rem; line-height:1.8; color:#a8c7ff; max-width:880px; margin-bottom:32px;\">\n      <strong>TopCasinoScout</strong> was created with a singular focus: to help players identify\n      <strong>trusted casinos, honest bonus terms, verified payouts, and fair, responsible gaming environments</strong>.\n      We publish independent rankings, AI-driven research tools, and transparent bonus analysis powered by our proprietary\n      <strong>TCS Score</strong> \u2014 a 0\u201310,000 rating system that measures real performance across withdrawals, licensing,\n      customer support, bonuses, games, and long-term player feedback.\n      Casinos that fail our checks are <strong>downgraded, removed, or blacklisted</strong>, and we publish those findings\n      openly to safeguard players.\n    </p>\n\n    <p style=\"font-size:1.02rem; line-height:1.75; color:#9fb6ff; max-width:880px; margin-bottom:36px;\">\n      This approach is also why TopCasinoScout is recognised as a reference point for identifying\n      <a href=\"/best-casino-comparison-sites\" style=\"color:#b9ccff; font-weight:600;\">\n        Best Casino Comparison Sites\n      </a>\n      \u2014 not based on marketing volume, but on real-world trust signals and player outcomes.\n    </p>\n\n    <!-- GRID -->\n    <style>\n      .tcs-about-grid {\n        margin-top:40px;\n        display:grid;\n        grid-template-columns:minmax(0,1.2fr) minmax(0,1fr);\n        gap:28px;\n      }\n      .tcs-about-block {\n        background:radial-gradient(circle at top left,#1b134e,#05051b);\n        border:1px solid #332a88;\n        border-radius:18px;\n        padding:26px 24px 24px;\n        box-shadow:0 0 32px rgba(0,0,0,.5);\n        margin-bottom:22px;\n      }\n      .tcs-about-block h2 {\n        margin:0 0 12px;\n        font-size:1.45rem;\n        color:#ffcc33;\n        letter-spacing:.02em;\n      }\n      .tcs-about-block p,\n      .tcs-about-block ul {\n        font-size:1rem;\n        line-height:1.7;\n        color:#cbd6ff;\n        margin-bottom:14px;\n      }\n      .tcs-about-block ul { padding-left:22px; }\n      @media(max-width:900px){\n        .tcs-about-grid { grid-template-columns:1fr; }\n      }\n    </style>\n\n    <div class=\"tcs-about-grid\">\n\n      <!-- LEFT COLUMN -->\n      <div>\n\n        <!-- WHO WE ARE -->\n        <div class=\"tcs-about-block\">\n          <h2>Who We Are</h2>\n          <p>\n            <strong>TopCasinoScout</strong> is an <strong>independent casino research company</strong> \u2014 not a casino\n            operator, not a payment provider, and not owned by any gambling brand. Our team includes bonus analysts,\n            data scientists, compliance researchers, and responsible gambling advocates who all share one goal:\n            <strong>protecting players from unsafe or misleading casinos</strong>.\n          </p>\n          <p>\n            We review operators across major markets including <strong>Canada, the UK, Ireland,  New Zealand,\n            the USA, Germany, France, Spain, the Netherlands, and LATAM</strong>. For each region, we apply local licensing\n            rules, payment norms, and bonus restrictions so recommendations remain relevant and accurate.\n          </p>\n          <p>\n            All content is written, reviewed, and approved in-house. We do not publish automated reviews without human\n            oversight, and no casino can edit, approve, or influence what we write about them.\n          </p>\n          <a href=\"/how-we-rate-online-casinos\"\n             class=\"tcs-btn-primary\" style=\"width:250px; text-align:center;\">\n             How We Rate Online Casinos\n          </a>\n        </div>\n\n        <!-- OUR VISION -->\n        <div class=\"tcs-about-block\">\n          <h2>Our Mission &amp; Vision</h2>\n          <p>\n            In an industry dominated by aggressive marketing and vague terms,\n            <strong>TopCasinoScout</strong> exists to bring <strong>clarity, accountability, and player protection</strong>\n            to online gambling. Every listing starts with a simple question:\n            \u201cWould we be comfortable recommending this casino to a friend or family member?\u201d\n          </p>\n          <p>\n            Our mission is to deliver the most <strong>reliable, audit-style casino analysis</strong> available \u2014\n            combining human expertise with advanced AI systems to verify bonus fairness, payout reliability,\n            licensing legitimacy, and overall risk. When we identify predatory clauses, misleading advertising,\n            or unsafe conduct, we call it out clearly and, where appropriate, add the operator to our\n            <a href=\"/blacklisted-and-unsafe-casinos\" style=\"color:#ffb3b3; font-weight:600;\">\n              Blacklisted Casinos\n            </a>\n            list.\n          </p>\n          <p>Our long-term vision is built around:</p>\n          <ul>\n            <li>Independent, non-sponsored rankings that cannot be bought</li>\n            <li>AI-assisted bonus detection and small-print analysis</li>\n            <li>Clear GEO guidance and licensing transparency for every market</li>\n            <li>Leadership in responsible gambling and player wellbeing</li>\n            <li>Real-world payout testing, complaints tracking, and pattern analysis</li>\n            <li>Direct warnings when bonuses or withdrawal rules are unfair or predatory</li>\n          </ul>\n          <p>\n            Our vision is simple: online casinos should be <strong>fair, well-regulated, and upfront</strong> about risk.\n          </p>\n          <a href=\"/insider-articles\"\n             class=\"tcs-btn-primary\" style=\"width:250px; text-align:center;\">\n             Explore Insider Articles\n          </a>\n        </div>\n\n      </div>\n\n      <!-- RIGHT COLUMN -->\n      <div>\n\n        <!-- AI SYSTEM -->\n        <div class=\"tcs-about-block\">\n          <h2>AI-Powered Casino Intelligence</h2>\n          <p>\n            <strong>TopCasinoScout</strong> uses advanced AI systems as part of our research process \u2014\n            but <strong>final decisions are always made by experienced human reviewers</strong>.\n            Our tools continuously scan the casino ecosystem to surface:\n          </p>\n          <ul>\n            <li>New deposit bonuses, welcome offers, and exclusive deals</li>\n            <li>Bonus expiries, wagering changes, and hidden max-cashout clauses</li>\n            <li>Live payout speed data and withdrawal limits across regions</li>\n            <li>Licensing changes, regulator notices, and compliance warnings</li>\n            <li>Game library updates, RTP adjustments, and provider launches</li>\n            <li>Geo-specific restrictions for UK, CA, IE, NZ, EU, and LATAM players</li>\n          </ul>\n          <p>\n            Our <strong>AI Bonus Finder</strong> matches players with relevant offers by analysing region,\n            deposit size, payment method, preferred game type, and wagering tolerance \u2014\n            always within responsible gambling limits.\n          </p>\n          <a href=\"/casino-bonus-finder/\"\n             class=\"tcs-btn-primary\" style=\"width:250px; text-align:center;\">\n             AI Bonus Finder\n          </a>\n        </div>\n\n        <!-- WHY TRUST US -->\n        <div class=\"tcs-about-block\">\n          <h2>Why Players Trust TopCasinoScout</h2>\n          <ul>\n            <li><strong>We are fully independent</strong> \u2014 rankings cannot be purchased.</li>\n            <li>Every review follows a structured checklist and real-world testing.</li>\n            <li>AI cross-checking helps detect misleading or inconsistent terms quickly.</li>\n            <li>The <strong>TCS Score</strong> evaluates casinos on a 0\u201310,000 scale across trust-critical factors.</li>\n            <li>We maintain public <a href=\"/blacklisted-and-unsafe-casinos\">\n              Blacklisted Casinos</a> warnings for unsafe operators.</li>\n            <li>All content is created with <strong>responsible gambling and player wellbeing</strong> in mind.</li>\n          </ul>\n          <p>\n            If a casino behaves badly, we say so. If a casino genuinely protects its players, we highlight that too.\n            Our loyalty is always to <strong>players first, partners second</strong>.\n          </p>\n        </div>\n\n      </div>\n    </div>\n\n    <!-- REVIEW METHODOLOGY -->\n    <div class=\"tcs-about-block\" style=\"margin-top:28px;\">\n      <h2>Our Review Methodology</h2>\n      <p>\n        Every casino we list goes through a multi-stage review and scoring process. This includes:\n      </p>\n      <ul>\n        <li>Direct licence verification with official regulators and public registers</li>\n        <li>Bonus value analysis, wagering difficulty, and fine-print review</li>\n        <li>Payout testing across multiple payment methods where possible</li>\n        <li>Game selection, RTP, volatility, and provider checks</li>\n        <li>Mobile performance, UX, and accessibility testing</li>\n        <li>Security, encryption, privacy, and RG tool evaluation</li>\n        <li>Support response times and dispute handling review</li>\n        <li>Complaint monitoring reflected directly in the <strong>TCS Score</strong></li>\n      </ul>\n      <p>\n        The result is an evidence-based rating system that helps players quickly identify\n        <strong>safer, fairer, and better-run casinos</strong> \u2014 and avoid the rest.\n      </p>\n      <a href=\"/how-we-rate-online-casinos\"\n         class=\"tcs-btn-primary\" style=\"width:250px; text-align:center;\">\n         Learn About How We Rate\n      </a>\n    </div>\n\n    <!-- RESPONSIBLE GAMBLING -->\n    <div style=\"margin-top:32px; padding:26px 24px; background:radial-gradient(circle at top,#1e1a5f,#05051b); border:1px solid #383090; border-radius:18px; box-shadow:0 0 28px rgba(0,0,0,.5);\">\n      <h2 style=\"color:#ffcc33; font-size:1.45rem; margin-bottom:8px;\">Our Responsible Gambling Promise</h2>\n      <p style=\"color:#cbd6ff; font-size:1rem; line-height:1.7;\">\n        <strong>TopCasinoScout</strong> is committed to <strong>player wellbeing above profit</strong>.\n        We promote deposit limits, time reminders, reality checks, and self-exclusion,\n        and we do not endorse operators that repeatedly ignore responsible-gambling obligations.\n      </p>\n      <p style=\"color:#cbd6ff; font-size:1rem; line-height:1.7;\">\n        Gambling should always remain entertainment \u2014 never a solution to financial problems.\n        Support resources are available on our\n        <a href=\"/responsible-gambling\">Responsible Gambling</a> page.\n      </p>\n      <a href=\"/responsible-gambling\"\n         class=\"tcs-btn-primary\" style=\"width:250px; text-align:center;\">\n         Learn More\n      </a>\n    </div>\n\n    <!-- CONTACT & DISCLAIMER -->\n    <div style=\"margin-top:32px; padding:26px 24px; background:radial-gradient(circle at top,#141445,#05051b); border:1px solid #3b348f; border-radius:20px; box-shadow:0 0 28px rgba(0,0,0,.4);\">\n      <h2 style=\"color:#ffcc33; margin-bottom:10px; font-size:1.5rem;\">Contact &amp; Transparency</h2>\n      <p style=\"color:#d5e0ff; font-size:1.05rem; line-height:1.75;\">\n        Editorial: <strong style=\"color:#ffea9c;\">team@localhost</strong><br><br>\n        Complaints & safety: <strong style=\"color:#ffea9c;\">complaints@localhost</strong><br><br>\n        Partnerships: <strong style=\"color:#ffea9c;\">partners@localhost</strong>\n      </p>\n      <p style=\"color:#cbd6ff; font-size:0.95rem; margin-top:12px; line-height:1.7;\">\n        Disclaimer: TopCasinoScout provides casino comparison information for educational and entertainment purposes.\n        We do not operate casinos, process payments, or handle account-level issues. Bonuses and promotions are subject\n        to change and governed by each casino\u2019s official terms.\n      </p>\n      <p style=\"color:#ffea9c; font-weight:700; margin-top:16px;\">\n        Thank you for trusting TopCasinoScout \u2014 an independent, ethics-driven, player-focused casino comparison platform.\n      </p>\n    </div>\n\n  </div>\n</section>\n\n\n\n<section style=\"margin-top:40px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.08);\">\n\n  <p style=\"color:#cbd6ff; font-size:0.95rem; line-height:1.7; max-width:900px;\">\n    Licensing and regulatory oversight are core trust signals when assessing online casinos.\n    As part of our review process, TopCasinoScout evaluates licence status against recognised\n    regulatory frameworks, including guidance published by the\n    <a href=\"https://www.gamblingcommission.gov.uk\" target=\"_blank\" rel=\"noopener\">\n      UK Gambling Commission\n    </a>,\n    alongside observed payout behaviour, bonus terms, and player complaint patterns.\n  </p>\n\n  <p style=\"color:#a8c7ff; font-size:0.95rem; line-height:1.7; margin-top:14px;\">\n    To explore how we apply these standards in practice, you can review our:\n    <a href=\"/best-casino-comparison-sites\">Best Casino Comparison Sites</a>,\n    browse current <a href=\"/top-casino-bonuses\">Top Casino Bonuses</a>,\n    see full <a href=\"/casino-rankings\">Casino Rankings</a>,\n    or read our detailed <a href=\"/how-we-rate-online-casinos\">How We Rate Online Casinos</a> methodology.\n  </p>\n\n</section>\n\n\n\n<section class=\"tcs-review-block\" id=\"about-navigation\">\n  <span class=\"tcs-label-pill\">Explore TopCasinoScout</span>\n  <h2 class=\"tcs-heading-lg\">Learn More About Our Reviews & Rankings</h2>\n\n  <p class=\"tcs-text\">\n    TopCasinoScout is built around transparency, independent analysis, and player protection.\n    The pages below explain how our rankings work, highlight the safest casino deals, and\n    show which operators we believe players should avoid.\n  </p>\n\n  <div class=\"tcs-feature-grid\" style=\"margin-top:18px;\">\n\n    <div class=\"tcs-feature-card\">\n      <h3 class=\"tcs-heading-sm\">\ud83c\udfc6 Best Casino Comparison Sites</h3>\n      <p class=\"tcs-text\">\n        See how leading casino comparison platforms rank based on trust, withdrawals,\n        bonus realism, and player outcomes.\n      </p>\n      <a class=\"tcs-link\" href=\"/best-casino-comparison-sites/\">\n        View Best Casino Comparison Sites \u2192\n      </a>\n    </div>\n\n    <div class=\"tcs-feature-card\">\n      <h3 class=\"tcs-heading-sm\">\ud83d\udcca Casino Rankings</h3>\n      <p class=\"tcs-text\">\n        Explore individual casino rankings scored using our proprietary TCS Score\n        across licensing, payouts, bonuses, and player treatment.\n      </p>\n      <a class=\"tcs-link\" href=\"/casino-rankings/\">\n        Browse Casino Rankings \u2192\n      </a>\n    </div>\n\n    <div class=\"tcs-feature-card\">\n      <h3 class=\"tcs-heading-sm\">\ud83d\udee1\ufe0f How We Rate Online Casinos</h3>\n      <p class=\"tcs-text\">\n        Learn exactly how our exclusion-first review methodology works and why some casinos\n        are never listed on TopCasinoScout.\n      </p>\n      <a class=\"tcs-link\" href=\"/how-we-rate-online-casinos/\">\n        Read Our Review Methodology \u2192\n      </a>\n    </div>\n\n    <div class=\"tcs-feature-card\">\n      <h3 class=\"tcs-heading-sm\">\ud83d\udeab Blacklisted Casinos</h3>\n      <p class=\"tcs-text\">\n        View casinos we recommend avoiding due to licensing failures, payout issues,\n        unfair bonus terms, or repeated player complaints.\n      </p>\n      <a class=\"tcs-link\" href=\"/blacklisted-and-unsafe-casinos/\">\n        View Blacklisted Casinos \u2192\n      </a>\n    </div>\n\n    <div class=\"tcs-feature-card\">\n      <h3 class=\"tcs-heading-sm\">\ud83e\udd16 AI Bonus Finder</h3>\n      <p class=\"tcs-text\">\n        Use our AI-assisted tool to match casino bonuses with your region,\n        deposit size, and wagering preferences \u2014 backed by editorial review.\n      </p>\n      <a class=\"tcs-link\" href=\"/casino-bonus-finder/\">\n        Try the AI Bonus Finder \u2192\n      </a>\n    </div>\n\n    <div class=\"tcs-feature-card\">\n      <h3 class=\"tcs-heading-sm\">\ud83c\udfe0 TopCasinoScout Home</h3>\n      <p class=\"tcs-text\">\n        Start from the beginning and explore trusted casino comparisons,\n        rankings, bonus guides, and safety resources.\n      </p>\n      <a class=\"tcs-link\" href=\"/\">\n        Go to TopCasinoScout \u2192\n      </a>\n    </div>\n\n  </div>\n</section>";
---
<Layout title={title} description={description} slug="about">
  <div class="tcs-page-content" set:html={content} />

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/" class="il-link">🏠 Home</a>
      <a href="/detailed-casino-reviews" class="il-link">📋 Casino Reviews</a>
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit Bonuses</a>
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Bonus Finder</a>
    </div>
  </div>
</div>

<style>
  .internal-links-block {
    background: rgba(255,204,51,.06);
    border-top: 1px solid rgba(255,204,51,.2);
    border-bottom: 1px solid rgba(255,204,51,.2);
    padding: 18px 24px;
    margin: 32px 0 0;
  }
  .il-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .il-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,204,51,.8);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .il-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .il-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
  }
  .il-link:hover {
    border-color: rgba(255,204,51,.5);
    background: rgba(255,204,51,.08);
    color: #ffcc33;
    text-decoration: none;
  }
</style>
</Layout>
