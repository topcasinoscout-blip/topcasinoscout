---
import Layout from '../layouts/Layout.astro';
const title = "Age Disclaimer (18+)";
const description = "18+ Age Disclaimer TopCasinoScout provides independent casino reviews , bonus comparisons , and global casino rankings . Our content is strictly intende...";
const content = "<section class=\"tcs-section tcs-section--deep-navy\">\n  <div class=\"tcs-container age-container\">\n\n    <h1 class=\"tcs-heading-xl\">18+ Age Disclaimer</h1>\n\n    <p class=\"tcs-text-lead age-intro\">\n      TopCasinoScout provides independent <a href=\"/casino-reviews\">casino reviews</a>,\n      <a href=\"/top-casino-bonuses\">bonus comparisons</a>, and\n      <a href=\"/casino-rankings\">global casino rankings</a>.  \n      Our content is strictly intended for adults aged <strong>18 years or older</strong>, or the legal gambling age\n      in your jurisdiction \u2014 whichever is higher.\n    </p>\n\n    <!-- LEGAL NOTICE -->\n    <div class=\"age-block\">\n      <h2 class=\"tcs-heading-lg\">Legal Age Requirement</h2>\n      <p>\n        By accessing or using TopCasinoScout, you confirm that you are:\n      </p>\n      <ul class=\"age-list\">\n        <li>At least <strong>18 years old</strong>, <em>or</em></li>\n        <li>Of legal gambling age in your country, state, or region</li>\n      </ul>\n      <p>\n        Online gambling laws vary significantly by location.  \n        You are responsible for ensuring that using online casino services is legal in your jurisdiction and that\n        you meet all age requirements before creating an account or depositing funds.\n      </p>\n    </div>\n\n    <!-- RESPONSIBLE USE -->\n    <div class=\"age-block\">\n      <h2 class=\"tcs-heading-lg\">Underage Gambling Prevention</h2>\n      <p>\n        TopCasinoScout does not promote gambling to minors and takes responsible use seriously.  \n        Our mission is to provide transparent, safe, and verified information about\n        <a href=\"/top-casino-bonuses/\">casino deposit bonuses</a>,\n        payout processes, and licensed gaming platforms.\n      </p>\n      <p>\n        If you believe a minor may be accessing gambling websites, we recommend parental control tools and\n        filtering systems designed to block gambling content.\n      </p>\n    </div>\n\n    <!-- RESPONSIBLE GAMBLING -->\n    <div class=\"age-block\">\n      <h2 class=\"tcs-heading-lg\">Responsible Gambling Commitment</h2>\n      <p>\n        Gambling should always be viewed as entertainment \u2014 not a source of income.  \n        If you or someone you know may be experiencing gambling issues, please refer to our\n        <a href=\"/responsible-gambling\">Responsible Gambling</a>\n        page for professional support resources available in your region.\n      </p>\n    </div>\n\n    <!-- CONTACT -->\n    <div class=\"age-block\">\n      <h2 class=\"tcs-heading-lg\">Need Assistance?</h2>\n      <p>\n        For questions regarding age requirements, online casino eligibility, geo-restricted bonuses, or\n        access to country-specific gambling laws, please contact us using the link below.\n      </p>\n      <a href=\"/contact-us\" class=\"tcs-play-button\" target=\"_blank\" rel=\"noopener noreferrer\">\n        Contact Support\n      </a>\n    </div>\n\n    <p class=\"tcs-text-muted age-footnote\">\n      TopCasinoScout is a comparison and informational service only.  \n      We do not operate gambling platforms, process payments, or accept wagers.\n    </p>\n\n  </div>\n</section>\n\n<style>\n  .age-container{max-width:900px;margin:0 auto}\n  .age-intro{max-width:820px}\n  .age-block{margin-top:34px;color:#d0e3ff}\n  .age-list{margin:10px 0 0;padding-left:1rem}\n  .age-list li{margin-bottom:6px;line-height:1.7}\n  .age-footnote{margin-top:32px;font-size:.85rem}\n</style>";
---
<Layout title={title} description={description} slug="age-disclaimer-18">
  <div class="tcs-page-content" set:html={content} />
</Layout>
