---
import Layout from '../layouts/Layout.astro';
const title = "How We Rate";
const description = "How We Rate Casinos: TopCasinoScout Score (TCS) This page explains how we rate online casinos using the TopCasinoScout Score (TCS) \u2014 our proprietary 10,...";
const content = "<section id=\"how-we-rate\" style=\"background-color:#0e0833; padding:80px 20px; font-family:Arial, sans-serif;\">\n  <div style=\"max-width:1100px; margin:0 auto;\">\n\n    <!-- Page header -->\n    <h1 style=\"color:#ffcc33; font-size:2.2rem; text-align:center; margin-bottom:12px;\">\n      How We Rate Casinos: TopCasinoScout Score (TCS) \n    </h1>\n\n    <p style=\"color:#a8c7ff; text-align:center; max-width:960px; margin:0 auto 14px; line-height:1.8;\">\n      This page explains <strong>how we rate online casinos</strong> using the <strong style=\"color:#ffcc33;\">TopCasinoScout Score (TCS)</strong> \u2014\n      our proprietary <strong>10,000-point casino rating methodology</strong> built for one purpose: to help players compare brands using\n      <strong>verifiable evidence</strong> instead of vague star ratings.\n      <br><br>\n      TCS is designed to be <strong>easy to prove</strong> using screenshots, public data, timers, and simple math. Where a casino makes claims\n      about withdrawals, licensing, bonuses or security, we look for evidence that a normal player can see and check.\n      <br><br>\n      We keep point bands stable for consistency. We may update thresholds periodically as the market changes, but we always publish the methodology\n      version and last updated date so readers can compare scores fairly over time.\n      <br><br>\n      We do <strong>not</strong> accept payments to increase scores. No operator can influence or purchase a higher rating \u2014 ever.\n    </p>\n\n    <p style=\"color:#a8c7ff; text-align:center; max-width:960px; margin:0 auto 28px; line-height:1.8;\">\n      <strong>Methodology version:</strong> TCS v1.3 &nbsp;|&nbsp;\n      <strong>Last updated:</strong> 28 January 2026 &nbsp;|&nbsp;\n      <strong>Scoring scale:</strong> 0\u201310,000 points\n    </p>\n\n    <style>\n      .tcs-grid {\n        display: grid;\n        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n        gap: 22px;\n      }\n      .tcs-card {\n        background: #080826;\n        border: 1px solid #1c1c4a;\n        border-radius: 14px;\n        padding: 22px;\n        box-shadow: 0 0 14px rgba(255, 204, 51, .05);\n      }\n      .tcs-card h3 {\n        color: #ffcc33;\n        margin: 0 0 8px;\n        font-size: 1.08rem;\n      }\n      .tcs-card p {\n        color: #a8c7ff;\n        line-height: 1.75;\n        margin: 0;\n      }\n      .tcs-card strong { color: #ffd86a; }\n\n      .tcs-table {\n        width: 100%;\n        border-collapse: collapse;\n        color: #a8c7ff;\n        font-size: 0.95rem;\n        margin: 10px 0 0;\n      }\n      .tcs-table th,\n      .tcs-table td {\n        border: 1px solid #1c1c4a;\n        padding: 9px 10px;\n        text-align: left;\n        vertical-align: top;\n      }\n      .tcs-table th {\n        background: #141445;\n        color: #ffcc33;\n      }\n\n      .tcs-box {\n        background:#07071f;\n        border:1px solid #2a2a62;\n        border-radius:12px;\n        padding:18px;\n      }\n      .tcs-box p, .tcs-box li { color:#a8c7ff; line-height:1.85; }\n      .tcs-mini { font-size:0.92rem; opacity:0.98; }\n\n      .tcs-chip-row {\n        display:flex;\n        flex-wrap:wrap;\n        gap:10px;\n        justify-content:center;\n        margin-top:12px;\n      }\n      .tcs-chip {\n        display:inline-block;\n        padding:8px 12px;\n        border-radius:999px;\n        border:1px solid #2a2a62;\n        background:#080826;\n        color:#a8c7ff;\n        font-size:0.92rem;\n        line-height:1;\n        white-space:nowrap;\n      }\n      .tcs-chip strong { color:#ffcc33; }\n    </style>\n\n    <!-- Visual summary table up top -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:22px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.55rem; margin:0 0 10px; text-align:center;\">\n        TCS at a Glance: Categories, Points, and What We Measure\n      </h2>\n      <p style=\"color:#a8c7ff; margin:0 auto 14px; line-height:1.8; max-width:980px; text-align:center;\">\n        This is the full scoring blueprint in one view. If you only read one table, make it this one.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Category</th>\n            <th>Max points</th>\n            <th>What it measures (1 line)</th>\n            <th>Typical proof</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Payments &amp; Withdrawals</strong></td>\n            <td>2,000</td>\n            <td>Payout speed, payment coverage, KYC friction, fees and limits</td>\n            <td>Banking terms + cashier + support test</td>\n          </tr>\n          <tr>\n            <td><strong>Licensing, Security &amp; RG Tools</strong></td>\n            <td>1,500</td>\n            <td>Licence strength and responsible gambling tools available in-account</td>\n            <td>Footer licence + verification + RG tools screenshots</td>\n          </tr>\n          <tr>\n            <td><strong>Trustpilot &amp; Player Reviews</strong></td>\n            <td>2,000</td>\n            <td>Trustpilot rating converted by formula (when sample size is reliable)</td>\n            <td>Public Trustpilot rating + review count</td>\n          </tr>\n          <tr>\n            <td><strong>Player Experience &amp; Support</strong></td>\n            <td>1,500</td>\n            <td>Channels, response speed, and objective accuracy checks</td>\n            <td>Chat transcript screenshots + timestamps</td>\n          </tr>\n          <tr>\n            <td><strong>Welcome Bonus Value</strong></td>\n            <td>1,000</td>\n            <td>Bonus size, wagering, rule clarity, ongoing promos</td>\n            <td>Bonus page + terms completeness checklist</td>\n          </tr>\n          <tr>\n            <td><strong>Games &amp; Software Quality</strong></td>\n            <td>1,000</td>\n            <td>Provider strength, game count estimate, live casino coverage</td>\n            <td>Provider list + lobby evidence</td>\n          </tr>\n          <tr>\n            <td><strong>Mobile Optimisation</strong></td>\n            <td>500</td>\n            <td>Mobile performance and loading speed with standardised testing</td>\n            <td>3 test runs, median result documented</td>\n          </tr>\n          <tr>\n            <td><strong>Data Privacy &amp; Account Security</strong></td>\n            <td>500</td>\n            <td>2FA availability and privacy-policy clarity</td>\n            <td>Account security page + privacy policy screenshots</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <!-- Evidence checklist strip -->\n      <div class=\"tcs-chip-row\" aria-label=\"Evidence checklist\">\n        <span class=\"tcs-chip\"><strong>Licence check</strong> (public)</span>\n        <span class=\"tcs-chip\"><strong>Banking terms</strong> screenshots</span>\n        <span class=\"tcs-chip\"><strong>Limits &amp; fees</strong> evidence</span>\n        <span class=\"tcs-chip\"><strong>Bonus rules</strong> completeness</span>\n        <span class=\"tcs-chip\"><strong>Support test</strong> transcript</span>\n        <span class=\"tcs-chip\"><strong>Trustpilot</strong> snapshot</span>\n        <span class=\"tcs-chip\"><strong>Mobile test</strong> output</span>\n        <span class=\"tcs-chip\"><strong>Privacy &amp; 2FA</strong> proof</span>\n      </div>\n    </div>\n\n    <!-- Quick trust box -->\n    <div style=\"background:#07071f; border:1px solid #2a2a62; border-radius:14px; padding:22px; margin:0 auto 28px; max-width:1000px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.35rem; margin:0 0 10px; text-align:center;\">The TCS Promise: Proof-First, Player-First</h2>\n      <ul style=\"color:#a8c7ff; margin:0; padding-left:20px; line-height:1.9; max-width:900px; margin-left:auto; margin-right:auto;\">\n        <li><strong>Evidence rule:</strong> If we can\u2019t screenshot it, verify it, or time it, it doesn\u2019t earn top-tier points.</li>\n        <li><strong>Worst-case rule:</strong> If support says one thing and the terms say another, we score the <strong>worse</strong> outcome.</li>\n        <li><strong>No \u201cvibes\u201d rule:</strong> We use fixed tables, checklists, and formulas. No hidden rubrics.</li>\n        <li><strong>Versioning:</strong> Every review is tied to a TCS version so scores remain comparable over time.</li>\n      </ul>\n    </div>\n\n    <!-- Disqualification / blacklist -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:34px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.55rem; margin:0 0 10px; text-align:center;\">Automatic Disqualification Rules (0 / 10,000)</h2>\n      <p style=\"color:#a8c7ff; margin:0 auto 14px; line-height:1.8; max-width:960px; text-align:center;\">\n        Some issues are too serious to \u201caverage out.\u201d If we find any of the following, the casino receives a <strong>TCS score of 0 / 10,000</strong>\n        and is not recommended.\n      </p>\n      <ul style=\"color:#a8c7ff; margin:0; padding-left:20px; line-height:1.9; max-width:900px; margin-left:auto; margin-right:auto;\">\n        <li><strong>No licence</strong>, clearly <strong>fake licensing</strong>, or licensing claims that cannot be verified in a credible way.</li>\n        <li><strong>Proven pattern of non-payment</strong>, confiscating legitimate winnings, or systematic refusal to process withdrawals.</li>\n        <li><strong>Evidence of fake games</strong>, tampered RNG, or unapproved / misrepresented software.</li>\n      </ul>\n    </div>\n\n    <!-- Category cards -->\n    <div class=\"tcs-grid\" style=\"margin-bottom:30px;\">\n      <div class=\"tcs-card\">\n        <h3>Payments &amp; Withdrawals (2,000 pts)</h3>\n        <p>How quickly and reliably players get paid, plus payment coverage, KYC friction, and withdrawal fees/limits.</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Licensing, Security &amp; RG Tools (1,500 pts)</h3>\n        <p>Licence strength, verifiability, and responsible gambling tools players can actually use in-account.</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Trustpilot &amp; Player Reviews (2,000 pts)</h3>\n        <p>Trustpilot rating converted by formula when there is a reliable sample size (50+ reviews).</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Player Experience &amp; Support (1,500 pts)</h3>\n        <p>Support channels, response speed, and objective accuracy checks on withdrawals, fees, and KYC questions.</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Welcome Bonus Value (1,000 pts)</h3>\n        <p>Bonus size, wagering, clarity of rules, and ongoing promos measured with fixed bands and checklists.</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Games &amp; Software Quality (1,000 pts)</h3>\n        <p>Provider strength, game count estimate, and live casino coverage confirmed with lobby/provider evidence.</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Mobile Optimisation (500 pts)</h3>\n        <p>Mobile performance and loading metrics using a standardised workflow and repeatable thresholds.</p>\n      </div>\n      <div class=\"tcs-card\">\n        <h3>Data Privacy &amp; Account Security (500 pts)</h3>\n        <p>2FA availability and provable privacy-policy clarity (retention, sharing, contact, consent).</p>\n      </div>\n    </div>\n\n    <!-- What the score means -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:30px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.55rem; margin:0 0 10px;\">What the TCS Score Means (In Plain English)</h2>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        The TopCasinoScout Score is a <strong>risk-and-value</strong> rating. It is designed to answer the questions players care about most:\n        <strong>Will it pay?</strong> <strong>Is it accountable?</strong> <strong>Are the rules fair and clear?</strong> <strong>If something goes wrong, is there real support?</strong>\n      </p>\n      <ul style=\"color:#a8c7ff; margin:0; padding-left:20px; line-height:1.9;\">\n        <li><strong>Higher score:</strong> Faster withdrawals, clearer terms, stronger accountability signals, and fewer friction traps.</li>\n        <li><strong>Mid score:</strong> Mixed signals. Some strong features, but meaningful restrictions, slower payouts, or clarity gaps.</li>\n        <li><strong>Lower score:</strong> Higher friction or risk signals such as slow payouts, weak licensing, unclear terms, or repeated complaint themes.</li>\n      </ul>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h3 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.1rem;\">Quick Risk Bands</h3>\n        <ul style=\"margin:0; padding-left:20px;\">\n          <li><strong>9,000\u201310,000:</strong> Strong overall reliability indicators (low friction signals).</li>\n          <li><strong>8,000\u20138,999:</strong> Solid overall score with manageable trade-offs.</li>\n          <li><strong>7,000\u20137,999:</strong> Mixed signals. Read the banking and bonus sections carefully.</li>\n          <li><strong>Below 7,000:</strong> Higher caution. Expect restrictions, delays, or weak transparency.</li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- Evidence standard -->\n    <div style=\"background:#07071f; border:1px solid #2a2a62; border-radius:14px; padding:26px; margin-bottom:36px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.55rem; margin:0 0 10px;\">Our Evidence Standard (How We Prove Scores)</h2>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        TCS is built to be <strong>auditable</strong>. In practical terms, that means each major score area can be backed by evidence a reader could verify.\n        We collect proof in a consistent way and apply scoring tables exactly as written.\n      </p>\n\n      <h3 style=\"color:#ffcc33; margin:12px 0 8px; font-size:1.1rem;\">What counts as proof</h3>\n      <ul style=\"color:#a8c7ff; margin:0 0 14px; padding-left:20px; line-height:1.9;\">\n        <li><strong>Terms screenshots:</strong> banking terms, withdrawal limits, fee schedules, bonus rules, privacy policy.</li>\n        <li><strong>Cashier screenshots:</strong> available deposit/withdrawal categories, limits, and method coverage.</li>\n        <li><strong>Licence verification:</strong> licence details and jurisdiction evidence where possible.</li>\n        <li><strong>Timed tests:</strong> support response timestamps; standardised mobile checks (3 runs, median).</li>\n        <li><strong>Public feedback pages:</strong> Trustpilot rating and review count (when sample size is adequate).</li>\n      </ul>\n\n      <h3 style=\"color:#ffcc33; margin:12px 0 8px; font-size:1.1rem;\">How we handle missing or conflicting information</h3>\n      <ul style=\"color:#a8c7ff; margin:0; padding-left:20px; line-height:1.9;\">\n        <li><strong>No evidence:</strong> the casino scores the lowest tier for that sub-factor.</li>\n        <li><strong>Contradictions:</strong> we score the <strong>worse</strong> outcome (worst-case rule) and document the conflict.</li>\n        <li><strong>Method differences:</strong> if crypto is fast but cards are slow, we score the typical mainstream experience and note crypto separately.</li>\n      </ul>\n    </div>\n\n    <!-- Quick workflow -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:36px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.55rem; margin:0 0 10px;\">Quick Calculation Workflow (What We Do for Every Casino)</h2>\n      <ol style=\"color:#a8c7ff; margin:0; padding-left:20px; line-height:1.9;\">\n        <li><strong>Gather proof:</strong> terms screenshots, cashier screenshots, licence claim, RG tools page, privacy policy, Trustpilot page, and a support chat transcript.</li>\n        <li><strong>Run timed checks:</strong> support response time using timestamps; mobile performance test using a consistent method (3 runs, median).</li>\n        <li><strong>Score by table:</strong> each metric is mapped to points using tier tables or checklist points.</li>\n        <li><strong>Apply formulas:</strong> Trustpilot formula (when 50+ reviews) and scaling rule if Trustpilot is excluded.</li>\n        <li><strong>Publish transparently:</strong> each review includes category scores and key evidence notes.</li>\n      </ol>\n      <p style=\"color:#a8c7ff; margin:12px 0 0; line-height:1.8;\" class=\"tcs-mini\">\n        Practical goal: repeatable scoring that a reader can understand without needing insider knowledge.\n      </p>\n    </div>\n\n    <!-- ====== DETAILED SCORING TABLES ====== -->\n    <h2 id=\"how-we-score\" style=\"color:#ffcc33; font-size:1.75rem; margin:42px 0 12px;\">\n      Detailed Methodology: Exact TCS Scoring Tables (10,000 Points)\n    </h2>\n\n    <p style=\"color:#a8c7ff; margin-bottom:22px; line-height:1.8;\">\n      Below is the full breakdown of <strong>how we rate online casinos</strong> using TCS. Each section includes exact point bands and proof methods.\n      If you want to understand why a casino scored high or low, this is the page that explains it.\n    </p>\n\n    <!-- 1) Payments & Withdrawals -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">1) Payments &amp; Withdrawals (2,000 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Payments and withdrawals are the core of player trust. A casino can have a huge lobby and flashy promotions, but if withdrawals are slow,\n        unclear, or capped aggressively, the real value collapses. This category measures speed, coverage, verification friction, and costs.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands (points)</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Withdrawal Speed</strong></td>\n            <td>800</td>\n            <td>\u22641hr (800) \u2022 \u22648hr (650) \u2022 \u226424hr (450) \u2022 \u226448hr (250) \u2022 \u2264120hr (100) \u2022 &gt;120hr (0)</td>\n            <td>Banking terms + cashier wording + support confirmation where needed</td>\n          </tr>\n          <tr>\n            <td><strong>Payment Categories</strong></td>\n            <td>500</td>\n            <td>6 (500) \u2022 4\u20135 (350) \u2022 3 (200) \u2022 2 (100) \u2022 \u22641 (0)</td>\n            <td>Cashier categories count (cards, bank, e-wallets, PayPal, crypto, local)</td>\n          </tr>\n          <tr>\n            <td><strong>KYC Speed</strong></td>\n            <td>400</td>\n            <td>\u22646hr (400) \u2022 \u226424hr (300) \u2022 \u226472hr (150) \u2022 &gt;72hr (0)</td>\n            <td>Terms claim + support chat confirmation + visible verification guidance</td>\n          </tr>\n          <tr>\n            <td><strong>Fees &amp; Limits</strong></td>\n            <td>300</td>\n            <td>Checklist points (see below), capped at 300</td>\n            <td>Limits table + fee disclosure screenshots</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h4 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.05rem;\">Fees &amp; Limits Checklist (0\u2013300 points)</h4>\n        <p style=\"margin:0 0 10px;\">\n          Instead of subjective judgement, we score fees and limits using a fixed checklist. Each verified item earns points.\n        </p>\n        <ul style=\"margin:0; padding-left:20px;\">\n          <li><strong>Fee clarity:</strong> withdrawal fees clearly stated as \u201cnone\u201d or disclosed in a visible schedule (+100)</li>\n          <li><strong>Limits clarity:</strong> minimum and maximum withdrawal limits visible in terms or cashier (+100)</li>\n          <li><strong>No hidden deductions:</strong> no extra \u201cprocessing\u201d or \u201chandling\u201d fee language found (+100)</li>\n        </ul>\n        <p style=\"margin:10px 0 0;\" class=\"tcs-mini\">\n          Note: If terms contain contradictory fee language, we apply the <strong>worst-case rule</strong> and relevant checklist items do not score.\n        </p>\n      </div>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h4 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.05rem;\">Important clarification: crypto vs card/bank speed</h4>\n        <p style=\"margin:0;\">\n          If crypto payouts are instant but card/bank payouts take days, we do not automatically score the fastest method.\n          We score the typical mainstream experience and document method differences clearly in the review.\n        </p>\n      </div>\n    </div>\n\n    <!-- 2) Licensing, Security & RG Tools -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">2) Licensing, Security &amp; Responsible Gambling Tools (1,500 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 10px; line-height:1.8;\">\n        Licensing determines accountability. Responsible gambling tools determine whether players can set limits when needed.\n        We score what can be verified and what is available inside the account.\n        <br><br>\n        <span class=\"tcs-mini\">Note: Technical privacy and account security controls (such as 2FA and privacy policy clarity) are scored separately in Category 8.</span>\n      </p>\n\n      <div class=\"tcs-box\" style=\"margin:0 0 14px;\">\n        <p style=\"margin:0;\">\n          <strong>Important:</strong> Licensing tiers are a simplified baseline. Operator execution matters more than jurisdiction labels.\n          A strong licence does not automatically mean fast payouts, fair limits, or good support.\n        </p>\n      </div>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands / checklist</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Licence Tier</strong></td>\n            <td>1,000</td>\n            <td>Tier 1 (1,000) \u2022 Tier 2 (800) \u2022 Tier 3 (500) \u2022 Unclear/unverified (0)</td>\n            <td>Footer licence claim + verifiable regulator evidence where possible</td>\n          </tr>\n          <tr>\n            <td><strong>RG Tools</strong></td>\n            <td>500</td>\n            <td>Checklist points (see below), capped at 500</td>\n            <td>Account RG tools page screenshots</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h4 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.05rem;\">RG Tools Checklist (0\u2013500 points)</h4>\n        <ul style=\"margin:0; padding-left:20px;\">\n          <li>Deposit limits available (+100)</li>\n          <li>Loss limits available (+100)</li>\n          <li>Session/time limits available (+75)</li>\n          <li>Timeout/cool-off available (+75)</li>\n          <li>Self-exclusion available (+100)</li>\n          <li>Relevant help links provided (+50)</li>\n        </ul>\n        <p style=\"margin:10px 0 0;\" class=\"tcs-mini\">\n          We also encourage players to use recognised resources such as\n          <a href=\"https://www.begambleaware.org\" target=\"_blank\" rel=\"noopener\" style=\"color:#ffcc33; text-decoration:none;\">BeGambleAware</a>.\n        </p>\n      </div>\n    </div>\n\n    <!-- 3) Trustpilot & Player Reviews (UPDATED: NO MODIFIERS / NO WEIGHTING) -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">3) Trustpilot &amp; Player Reviews (2,000 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Player reviews can reveal patterns that don\u2019t show up on marketing pages: stalled withdrawals, repeated KYC disputes,\n        and support refusal. We include Trustpilot as an external signal using a simple conversion formula.\n      </p>\n\n      <div class=\"tcs-box\">\n        <p style=\"margin:0 0 10px;\">\n          <strong>Trustpilot formula (max 2,000):</strong><br>\n          <span style=\"font-family:monospace;\">Trustpilot Points = (Trustpilot Rating / 5.0) \u00d7 2,000</span>\n        </p>\n        <p style=\"margin:0;\">\n          Example: 4.2 / 5.0 \u2192 (4.2 \u00f7 5) \u00d7 2,000 = 1,680 points\n        </p>\n      </div>\n\n      <h4 style=\"color:#ffcc33; margin:14px 0 8px; font-size:1.05rem;\">Minimum review count rule</h4>\n      <p style=\"color:#a8c7ff; margin:0 0 10px; line-height:1.8;\">\n        Trustpilot is only included when there is enough volume for the rating to be meaningful.\n        If a casino has <strong>fewer than 50 Trustpilot reviews</strong>, we treat this category as <strong>N/A</strong>.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Trustpilot review count</th>\n            <th>Trustpilot category</th>\n            <th>What happens</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>&lt; 50 reviews</strong></td>\n            <td><strong>N/A</strong></td>\n            <td>We exclude Trustpilot and <strong>scale the other categories</strong> to a 10,000-point total.</td>\n          </tr>\n          <tr>\n            <td><strong>50+ reviews</strong></td>\n            <td><strong>Included</strong></td>\n            <td>We apply the Trustpilot formula and add those points to the score.</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <p style=\"margin:0;\">\n          <strong>Scaling rule when Trustpilot is N/A:</strong><br>\n          <span style=\"font-family:monospace;\">Final TCS = (Score Without Trustpilot / 8,000) \u00d7 10,000</span><br>\n          <span class=\"tcs-mini\">This keeps the overall score comparable without rewarding or punishing a casino for limited external review data.</span>\n        </p>\n      </div>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <p style=\"margin:0;\">\n          <strong>Important note:</strong> Trustpilot is not treated as \u201ctruth.\u201d If we see repeated complaint themes (for example, withdrawal delays or KYC disputes),\n          we use that as a trigger to double-check the relevant evidence areas (payments, terms, and support accuracy).\n        </p>\n      </div>\n    </div>\n\n    <!-- 4) Player Experience & Support -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">4) Player Experience &amp; Support (1,500 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Support is where casino policies become real. We score support using what a player can observe: channels available, response time,\n        and an objective accuracy test based on three standard questions.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands / checklist</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Support channels</strong></td>\n            <td>500</td>\n            <td>Chat+Email+Phone (500) \u2022 Chat+Email (350) \u2022 Email only (100) \u2022 None (0)</td>\n            <td>Visible support options on site</td>\n          </tr>\n          <tr>\n            <td><strong>Chat response speed</strong></td>\n            <td>600</td>\n            <td>&lt;30s (600) \u2022 \u226460s (450) \u2022 \u2264180s (300) \u2022 \u2264300s (150) \u2022 &gt;300s (0)</td>\n            <td>Timestamped chat test (screenshots)</td>\n          </tr>\n          <tr>\n            <td><strong>Support accuracy test</strong></td>\n            <td>400</td>\n            <td>Checklist points (see below), capped at 400</td>\n            <td>Chat transcript screenshots</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h4 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.05rem;\">Support Accuracy Checklist (0\u2013400 points)</h4>\n        <p style=\"margin:0 0 10px;\">\n          We ask three standard questions. Points are earned only if the answer is clear and usable.\n        </p>\n        <ul style=\"margin:0; padding-left:20px;\">\n          <li><strong>Q1: \u201cWhat are your withdrawal limits?\u201d</strong><br>\n            Numeric limits + where to find them (+150) \u2022 Partial numbers, no source (+75) \u2022 No numbers / dodges (+0)\n          </li>\n          <li style=\"margin-top:8px;\"><strong>Q2: \u201cDo you charge withdrawal fees?\u201d</strong><br>\n            Clear yes/no + fee schedule reference (+150) \u2022 Vague answer (+75) \u2022 Contradiction / wrong (+0)\n          </li>\n          <li style=\"margin-top:8px;\"><strong>Q3: \u201cWhen do you require verification (KYC)?\u201d</strong><br>\n            Explains triggers + documents (+100) \u2022 Partial (+50) \u2022 Unclear (+0)\n          </li>\n        </ul>\n        <p style=\"margin:10px 0 0;\" class=\"tcs-mini\">\n          If a bot responds first, we record time to a human agent where possible. If answers conflict with published terms, we apply the <strong>worst-case rule</strong>.\n        </p>\n      </div>\n    </div>\n\n    <!-- 5) Welcome Bonus Value -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">5) Welcome Bonus Value (1,000 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Bonuses are marketing unless the rules are fair and clear. TCS scores bonuses based on size, wagering, transparency,\n        and whether there\u2019s ongoing value beyond the first deposit.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands / checklist</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Bonus size (% + cap)</strong></td>\n            <td>250</td>\n            <td>200%+ / 1,000+ (250) \u2022 100% / 500 (200) \u2022 &lt;100% (100) \u2022 None (0)</td>\n            <td>Bonus page headline + terms excerpt</td>\n          </tr>\n          <tr>\n            <td><strong>Wagering</strong></td>\n            <td>250</td>\n            <td>\u226420x (250) \u2022 21\u201335x (150) \u2022 36\u201350x (50) \u2022 &gt;50x/unclear (0)</td>\n            <td>T&amp;Cs screenshot</td>\n          </tr>\n          <tr>\n            <td><strong>Transparency</strong></td>\n            <td>250</td>\n            <td>Checklist points (see below), capped at 250</td>\n            <td>T&amp;Cs visibility and completeness</td>\n          </tr>\n          <tr>\n            <td><strong>Ongoing promos/VIP</strong></td>\n            <td>250</td>\n            <td>Strong (250) \u2022 Average (150) \u2022 Weak (50) \u2022 None (0)</td>\n            <td>Promotions page / VIP page evidence</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h4 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.05rem;\">Bonus Transparency Checklist (0\u2013250 points)</h4>\n        <p style=\"margin:0 0 10px;\">\n          Each item is worth 50 points. Missing item = 0 for that item.\n        </p>\n        <ul style=\"margin:0; padding-left:20px;\">\n          <li>Wagering stated clearly (+50)</li>\n          <li>Eligible games / contributions stated (+50)</li>\n          <li>Max bet rule stated (+50)</li>\n          <li>Max cashout / profit cap rule stated (+50)</li>\n          <li>Bonus expiry stated (+50)</li>\n        </ul>\n        <p style=\"margin:10px 0 0;\" class=\"tcs-mini\">\n          If key bonus rules are hidden, contradictory, or not easily findable, transparency points drop quickly by design.\n        </p>\n      </div>\n    </div>\n\n    <!-- 6) Games & Software Quality -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">6) Games &amp; Software Quality (1,000 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        This category rewards casinos with strong provider ecosystems, healthy game variety, and a properly stocked live casino.\n        We score what can be verified via provider lists and lobby evidence.\n      </p>\n\n      <div class=\"tcs-box\" style=\"margin:0 0 14px;\">\n        <p style=\"margin:0;\">\n          <strong>Game count note:</strong> Game totals are treated as an estimate based on visible lobby counters or published totals.\n          If no reliable count is visible (or the number appears inflated without evidence), this sub-factor scores lower.\n          <br><br>\n          <span class=\"tcs-mini\">Future-proofing: thresholds may be reviewed periodically as the market shifts. Any changes are versioned and dated.</span>\n        </p>\n      </div>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Top providers</strong></td>\n            <td>400</td>\n            <td>10+ (400) \u2022 7\u20139 (300) \u2022 4\u20136 (200) \u2022 &lt;4 (0)</td>\n            <td>Provider list / game studio filter evidence</td>\n          </tr>\n          <tr>\n            <td><strong>Game count</strong></td>\n            <td>300</td>\n            <td>5,000+ (300) \u2022 3,000+ (200) \u2022 1,000+ (100) \u2022 &lt;1,000 (0)</td>\n            <td>Lobby counter / published library size</td>\n          </tr>\n          <tr>\n            <td><strong>Live casino strength</strong></td>\n            <td>300</td>\n            <td>Full live coverage (300) \u2022 Good tables (200) \u2022 Minimal (100) \u2022 None (0)</td>\n            <td>Live lobby screenshots</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n\n    <!-- 7) Mobile Optimisation -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:24px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">7) Mobile Optimisation (500 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Mobile performance affects everything: login friction, cashier reliability, and general usability. To keep this measurable,\n        we use standardised thresholds and document the test output.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>Mobile performance score</strong></td>\n            <td>250</td>\n            <td>90\u2013100 (250) \u2022 70\u201389 (150) \u2022 50\u201369 (50) \u2022 &lt;50 (0)</td>\n            <td>Standardised mobile test output (3 runs, median)</td>\n          </tr>\n          <tr>\n            <td><strong>Loading speed (LCP or equivalent)</strong></td>\n            <td>250</td>\n            <td>\u22642.5s (250) \u2022 2.6\u20134.0s (150) \u2022 4.1\u20136.0s (50) \u2022 &gt;6.0s (0)</td>\n            <td>Same test output showing the loading metric</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <p style=\"margin:0;\">\n          <strong>Standardisation rule:</strong> We test the same page type where possible (home or lobby), run the check three times,\n          and use the median result. This reduces one-off spikes and makes mobile scores more repeatable.\n          <br><br>\n          <span class=\"tcs-mini\">Future-proofing: mobile thresholds may be reviewed periodically against typical market performance. Any updates are published as a new TCS version.</span>\n        </p>\n      </div>\n    </div>\n\n    <!-- 8) Data Privacy & Account Security -->\n    <div style=\"background:#080826; border:1px solid #1c1c4a; border-radius:14px; padding:26px; margin-bottom:30px;\">\n      <h3 style=\"color:#ffcc33; margin:0 0 10px; font-size:1.3rem;\">8) Data Privacy &amp; Account Security (500 points)</h3>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Players trust casinos with sensitive personal and payment information. We score security and privacy based on what is provable:\n        whether 2FA exists and whether the privacy policy is clear about retention, sharing, contact, and consent.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            <th>Sub-factor</th>\n            <th>Max</th>\n            <th>Tier bands / checklist</th>\n            <th>Proof method</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><strong>2FA availability</strong></td>\n            <td>300</td>\n            <td>2FA required (300) \u2022 2FA optional (150) \u2022 No 2FA (0)</td>\n            <td>Account security settings screenshot</td>\n          </tr>\n          <tr>\n            <td><strong>Privacy policy clarity</strong></td>\n            <td>200</td>\n            <td>Checklist points (see below), capped at 200</td>\n            <td>Privacy policy screenshots</td>\n          </tr>\n        </tbody>\n      </table>\n\n      <div class=\"tcs-box\" style=\"margin-top:14px;\">\n        <h4 style=\"color:#ffcc33; margin:0 0 8px; font-size:1.05rem;\">Privacy Policy Clarity Checklist (0\u2013200 points)</h4>\n        <p style=\"margin:0 0 10px;\">Each item is worth 50 points.</p>\n        <ul style=\"margin:0; padding-left:20px;\">\n          <li>Data retention described (+50)</li>\n          <li>Third-party sharing described (+50)</li>\n          <li>Contact method for data requests (+50)</li>\n          <li>Cookie/consent mechanism present (+50)</li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- Worked example -->\n    <div style=\"background:#07071f; border:1px solid #2a2a62; border-radius:14px; padding:26px; margin-bottom:30px;\">\n      <h2 style=\"color:#ffcc33; font-size:1.55rem; margin:0 0 10px;\">Worked Example: Building a TCS Score</h2>\n      <p style=\"color:#a8c7ff; margin:0 0 12px; line-height:1.8;\">\n        Here is a simple example showing how the category totals add up. The goal is not to \u201csell\u201d a score. The goal is to make the calculation obvious.\n      </p>\n\n      <table class=\"tcs-table\">\n        <thead>\n          <tr>\n            