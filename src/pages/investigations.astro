---
import Layout from '../layouts/Layout.astro';
const title = "Investigations";
const description = "Investigations Independent Investigations into the iGaming Industry This section is dedicated to long-form, evidence-based investigations into the onlin...";
const content = "<section class=\"tcs-section tcs-section--deep-navy\">\n  <div class=\"tcs-container\" style=\"max-width:980px; text-align:left;\">\n\n    <span class=\"tcs-label-pill\">Investigations</span>\n\n    <h2 class=\"tcs-heading-lg\" style=\"margin-top:12px;\">\n      Independent Investigations into the iGaming Industry\n    </h2>\n\n    <p class=\"tcs-text-lead\" style=\"margin-top:16px;\">\n      This section is dedicated to long-form, evidence-based investigations into the online casino and iGaming ecosystem.\n      Here, TopCasinoScout publishes verified findings that go beyond routine reviews \u2014 examining licensing claims,\n      review-site behaviour, systemic failures, and patterns that directly affect real players.\n    </p>\n\n    <p class=\"tcs-text\" style=\"margin-top:12px;\">\n      Our investigations are conducted using replicable methods, archived evidence, regulator cross-checks,\n      and direct comparison of public claims versus official records.  \n      Where serious inconsistencies or failures are identified, we document outcomes \u2014 not speculation \u2014\n      and publish supporting proof so readers, regulators, and industry professionals can verify our work independently.\n    </p>\n\n    <p class=\"tcs-text\" style=\"margin-top:12px;\">\n      This is not marketing content. It is consumer-protection reporting.\n    </p>\n\n    <div style=\"margin-top:28px;\">\n      <a href=\"/casino-review-ecosystem-failure-2025/\"\n         class=\"tcs-btn-primary\"\n         style=\"display:inline-block;\">\n        Read Investigation: Casino Review Ecosystem Failure 2025\n      </a>\n    </div>\n\n  </div>\n</section>";
---
<Layout title={title} description={description} slug="investigations">
  <div class="tcs-page-content" set:html={content} />

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Casino Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit Bonuses</a>
      <a href="/detailed-casino-reviews" class="il-link">📋 Casino Reviews</a>
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Bonus Finder</a>
      <a href="/casino-promo-codes" class="il-link">🎫 Promo Codes</a>
    </div>
  </div>
</div>

<style>
  .internal-links-block {
    background: rgba(255,204,51,.06);
    border-top: 1px solid rgba(255,204,51,.2);
    border-bottom: 1px solid rgba(255,204,51,.2);
    padding: 18px 24px;
    margin: 32px 0 0;
  }
  .il-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .il-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,204,51,.8);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .il-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .il-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
  }
  .il-link:hover {
    border-color: rgba(255,204,51,.5);
    background: rgba(255,204,51,.08);
    color: #ffcc33;
    text-decoration: none;
  }
</style>
</Layout>
