---
import Layout from '../layouts/Layout.astro';
const title = "Affiliate Disclosure";
const description = "Affiliate Disclosure & Trust Commitment TopCasinoScout operates with a strict transparency and player-first policy. This page explains how our partnersh...";
const content = "<section class=\"tcs-section tcs-section--deep-navy\">\n  <div class=\"tcs-container ad-container\">\n\n    <h1 class=\"tcs-heading-xl ad-title\">Affiliate Disclosure & Trust Commitment</h1>\n\n    <p class=\"tcs-text-lead ad-intro\">\n      TopCasinoScout operates with a strict transparency and player-first policy. \n      This page explains how our partnerships are structured, how we fund our \n      independent testing, and\u2014most importantly\u2014how we ensure that commercial \n      relationships never influence our <a href=\"/casino-rankings\">casino rankings</a>,\n      <a href=\"/casino-reviews\">reviews</a>, or recommendations.  \n      Our mission is to help players make informed, safe, and confident decisions \n      in an industry where trust has to be earned.\n    </p>\n\n    <!-- WHY DISCLOSURE MATTERS -->\n    <div class=\"ad-block\">\n      <h2 class=\"tcs-heading-lg\">Why Transparency Matters</h2>\n      <p>\n        Many comparison websites offer ratings without explaining how they operate. \n        We believe players deserve complete clarity. Disclosing how we generate \n        revenue helps demonstrate our independence and reinforces why \n        TopCasinoScout is a reliable, accountable resource for online gambling insights.\n        This page outlines:\n      </p>\n      <ul class=\"ad-list\">\n        <li>How our partner relationships work in practice</li>\n        <li>Which pages may include referral links</li>\n        <li>How we maintain full editorial independence</li>\n        <li>The safeguards we use to protect players from bias</li>\n      </ul>\n    </div>\n\n    <!-- HOW AFFILIATES WORK -->\n    <div class=\"ad-block\">\n      <h2 class=\"tcs-heading-lg\">How Partnership Links Support Our Work</h2>\n      <p>\n        When a player clicks one of our recommended casino links and chooses to sign up, \n        the operator may provide us with a referral fee. This practice is standard across \n        comparison and review industries (including finance, travel, and technology) \n        and allows us to offer TopCasinoScout as a free, high-quality resource.\n      </p>\n      <p>These funds directly support:</p>\n      <ul class=\"ad-list\">\n        <li>Independent testing of bonuses, payments, and KYC processes</li>\n        <li>Geo-specific accuracy for UK, CA, NZ and other regional pages</li>\n        <li>Audited <a href=\"/how-we-rate\">TCS Score evaluations</a> backed by real data</li>\n        <li>Our AI-powered Bonus Finder and comparison tools</li>\n        <li>Research and content promoting safer gambling practices</li>\n      </ul>\n\n      <p>\n        Importantly, using our links never changes the bonus you receive, your \n        payout speed, or any casino terms. Your experience remains the same \n        whether you visit directly or through our site.\n      </p>\n    </div>\n\n    <!-- EDITORIAL INDEPENDENCE -->\n    <div class=\"ad-block\">\n      <h2 class=\"tcs-heading-lg\">Editorial Independence & Rating Integrity</h2>\n      <p>\n        Our commercial relationships are entirely separate from our review process. \n        Casinos cannot pay to influence ratings or request preferred placement. \n        Every operator\u2014partnered or not\u2014is evaluated using our structured \n        <strong>TCS Score</strong> system, which measures:\n      </p>\n      <ul class=\"ad-list\">\n        <li>Bonus value, fairness, and transparency</li>\n        <li>Withdrawal reliability and payment speed</li>\n        <li>Strength of responsible gambling tools</li>\n        <li>Customer support quality and expertise</li>\n        <li>Game providers, fairness audits, and software integrity</li>\n        <li>Complaint handling, dispute outcomes, and reputation</li>\n      </ul>\n      <p>\n        If a partner casino fails our checks or develops unresolved complaints, \n        we adjust its ranking accordingly\u2014even if doing so reduces our revenue. \n        Protecting players always comes first.\n      </p>\n    </div>\n\n    <!-- LINK TRACKING & COOKIES -->\n    <div class=\"ad-block\">\n      <h2 class=\"tcs-heading-lg\">How Referral Tracking Works</h2>\n      <p>\n        Some links on our website use standard tracking parameters that allow \n        casinos to understand where a visitor originated. This tracking does not \n        identify you personally. No personal data is shared with us or with \n        operators. The system is anonymous and solely confirms referral activity.\n      </p>\n      <p>\n        For information about how we handle data, you can review our\n        <a href=\"/privacy-policy\">Privacy Policy</a> and \n        <a href=\"/cookie-policy\">Cookie Policy</a>.\n      </p>\n    </div>\n\n    <!-- CONFLICTS OF INTEREST -->\n    <div class=\"ad-block\">\n      <h2 class=\"tcs-heading-lg\">Protecting Against Conflicts of Interest</h2>\n      <p>To ensure that our reviews remain objective, TopCasinoScout enforces:</p>\n      <ul class=\"ad-list\">\n        <li>No paid ranking boosts or preferential placement</li>\n        <li>No removal of negative reviews in exchange for compensation</li>\n        <li>No operator influence over editorial content or ratings</li>\n        <li>Equal evaluation of partnered and non-partnered casinos</li>\n        <li>Recommendations that may include casinos offering no commission at all</li>\n      </ul>\n      <p>\n        These safeguards ensure that our recommendations genuinely reflect \n        quality\u2014not commercial influence.\n      </p>\n    </div>\n\n    <!-- RESPONSIBLE GAMBLING -->\n    <div class=\"ad-block\">\n      <h2 class=\"tcs-heading-lg\">Our Responsible Gambling Promise</h2>\n      <p>\n        Our mission extends beyond promoting bonuses or casino offers. We are \n        committed to supporting safer gambling, encouraging players to set limits, \n        stay within legal boundaries, and seek help whenever gambling stops being fun.\n      </p>\n      <p>\n        For tools, advice and resources, visit our \n        <a href=\"/responsible-gambling\">Responsible Gambling</a> page.\n      </p>\n    </div>\n\n  \n\n    <p class=\"tcs-text-muted ad-footnote\">\n      TopCasinoScout is an independently operated comparison resource. \n      18+ only. Gambling should be legal in your location. Always read an \n      operator\u2019s complete terms and conditions before depositing.\n    </p>\n\n  </div>\n</section>\n\n\n\n<section class=\"tcs-section tcs-section--trust\">\n  <div class=\"tcs-container\">\n\n    <h2 class=\"tcs-heading-lg\">Licensing, Regulatory Transparency & Player Protection</h2>\n\n    <p>\n      At TopCasinoScout, our commitment goes far beyond simply listing whether a casino holds a license. \n      We believe that players deserve clear, independently verified information about the legality, \n      safety, and fairness of every operator they interact with. Our team uses official regulatory \n      databases as the foundation of our research, then conducts extensive in-depth reviews to confirm \n      whether each casino operates ethically, transparently, and in accordance with industry standards.\n    </p>\n\n    <p>\n      We actively identify and <strong>blacklist operators engaged in predatory, deceptive, or illegal practices</strong>. \n      Publishing these warnings is a core part of our mission: safeguarding players by exposing unsafe \n      casinos and promoting accountability within the global gambling market. \n      Every review we publish reflects a neutral, evidence-driven audit designed to protect consumer welfare.\n    </p>\n\n    <h3 class=\"tcs-heading-md\">Licensing Authorities We Rely On</h3>\n\n    <p>\n      Below are the official regulatory bodies governing online gambling across major global jurisdictions. \n      We rely on these authorities to verify licensing status, monitor regulatory actions, and validate the \n      legitimacy of each operator we evaluate. These organizations enforce standards on fairness, security, \n      anti-fraud measures, and responsible gambling.\n    </p>\n\n    <ul class=\"tcs-list\">\n      <li><a href=\"https://www.gamblingcommission.gov.uk/public-register\" target=\"_blank\" rel=\"noopener noreferrer\">UK Gambling Commission (UKGC) \u2013 United Kingdom</a></li>\n      <li><a href=\"https://www.spielgluck.de/\" target=\"_blank\" rel=\"noopener noreferrer\">Gl\u00fccksspielbeh\u00f6rde \u2013 Germany</a></li>\n      <li><a href=\"http://anj.fr/\" target=\"_blank\" rel=\"noopener noreferrer\">ANJ \u2013 Autorit\u00e9 Nationale des Jeux (France)</a></li>\n      <li><a href=\"https://www.ordenacionjuego.es/\" target=\"_blank\" rel=\"noopener noreferrer\">DGOJ \u2013 Spain</a></li>\n      <li><a href=\"https://www.mga.org.mt/\" target=\"_blank\" rel=\"noopener noreferrer\">Malta Gaming Authority (MGA) \u2013 European Union</a></li>\n      <li><a href=\"https://www.gra.gi\" target=\"_blank\" rel=\"noopener noreferrer\">Gibraltar Regulatory Authority (GRA)</a></li>\n      <li><a href=\"https://www.gamblingcontrol.org/\" target=\"_blank\" rel=\"noopener noreferrer\">Alderney Gambling Control Commission (AGCC)</a></li>\n      <li><a href=\"https://www.isleofmangsc.com/gambling/\" target=\"_blank\" rel=\"noopener noreferrer\">Isle of Man Gambling Supervision Commission (GSC)</a></li>\n      <li><a href=\"https://www.curacao-egaming.com/\" target=\"_blank\" rel=\"noopener noreferrer\">Cura\u00e7ao eGaming \u2013 Cura\u00e7ao</a></li>\n      <li><a href=\"https://www.kahnawake.com/\" target=\"_blank\" rel=\"noopener noreferrer\">Kahnawake Gaming Commission \u2013 Canada</a></li>\n      <li><a href=\"https://www.nj.gov/oag/ca/onlinegaming.html\" target=\"_blank\" rel=\"noopener noreferrer\">New Jersey Division of Gaming Enforcement (DGE) \u2013 USA</a></li>\n      <li><a href=\"https://www.gamblingcommission.govt.nz/\" target=\"_blank\" rel=\"noopener noreferrer\">Department of Internal Affairs \u2013 New Zealand</a></li>\n      <li><a href=\"https://gamblingcommission.ca/index.html#:~:text=Gambling%20Commission%20Canada%20is%20an,provincial%20or%20territorial%20government%20regulator.\" target=\"_blank\" rel=\"noopener noreferrer\">Newfoundland & Labrador Gaming Control \u2013 Canada</a></li>\n    </ul>\n\n    <p>\n      These authorities operate public registers, and we encourage players to verify each operator\u2019s license \n      independently using the links above. Licensing alone, however, does not guarantee trustworthy conduct\u2014 \n      which is why we perform additional assessments using our <strong>TCS Score</strong> framework.\n    </p>\n\n    <h3 class=\"tcs-heading-md\">Why We Link to Licensing Authorities</h3>\n\n    <p>\n      Providing direct access to official regulators reinforces our commitment to accountability and \n      transparency. Licensing verification is the first step in our evaluation process, but not the final one. \n      We cross-reference regulatory information with real-world player feedback, payment behaviour, \n      dispute resolutions, and compliance audits to determine whether an operator is genuinely safe.\n    </p>\n\n    <p>\n      If a casino demonstrates unethical behaviour\u2014such as withholding withdrawals, breaching responsible \n      gambling obligations, misleading players, or operating without proper authorization\u2014we publicly \n      document these findings and blacklist the operator to warn and protect players worldwide.\n    </p>\n\n    <h3 class=\"tcs-heading-md\">Our Commitment to Player Welfare</h3>\n\n    <p>\n      Safeguarding players is at the core of everything we do. Every recommended casino must meet strict \n      standards for responsible gambling, including offering deposit limits, self-exclusion tools, reality \n      checks, and access to accredited support organizations. Our team continually monitors operators for \n      compliance and updates ratings when their conduct changes.\n    </p>\n\n    <p>\n      To learn more about safer gambling and protective tools, visit our \n      <a href=\"/responsible-gambling\" target=\"_blank\" rel=\"noopener noreferrer\">\n        Responsible Gambling\n      </a> page.\n    </p>\n\n  </div>\n\n<!-- CONTACT -->\n<div class=\"ad-block\">\n  <h2 class=\"tcs-heading-lg\">Questions or Feedback?</h2>\n  <p>\n    We believe transparency requires open communication. If you have questions \n    about our partnerships, rating methodology, editorial standards, or would \n    like to report a casino concern, our team is available through the following \n    dedicated channels:\n  </p>\n\n  <ul class=\"ad-list\">\n    <li><strong>Player Complaints & Safety Issues:</strong> \n      <a href=\"mailto:complaints@localhost\">complaints@localhost</a>\n    </li>\n\n    <li><strong>Editorial Team (Reviews, Accuracy, Data Requests):</strong> \n      <a href=\"mailto:team@localhost\">team@localhost</a>\n    </li>\n\n    <li><strong>General Support & Questions:</strong> \n      <a href=\"mailto:support@localhost\">support@localhost</a>\n    </li>\n\n    <li><strong>Affiliate & Partnership Inquiries:</strong> \n      <a href=\"mailto:partners@localhost\">partners@localhost</a>\n    </li>\n  </ul>\n\n  <p>\n    For non-urgent messages or additional contact options, you can also reach us directly through \n    our main form:\n  </p>\n\n  <a href=\"/contact-us\" \n     class=\"tcs-play-button\" \n     target=\"_blank\" \n     rel=\"noopener noreferrer\">\n    Contact Us\n  </a>\n</div>\n\n</section>";
---
<Layout title={title} description={description} slug="affiliate-disclosure">
  <div class="tcs-page-content" set:html={content} />

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/" class="il-link">🏠 Home</a>
      <a href="/detailed-casino-reviews" class="il-link">📋 Casino Reviews</a>
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit Bonuses</a>
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Bonus Finder</a>
    </div>
  </div>
</div>

<style>
  .internal-links-block {
    background: rgba(255,204,51,.06);
    border-top: 1px solid rgba(255,204,51,.2);
    border-bottom: 1px solid rgba(255,204,51,.2);
    padding: 18px 24px;
    margin: 32px 0 0;
  }
  .il-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .il-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,204,51,.8);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .il-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .il-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
  }
  .il-link:hover {
    border-color: rgba(255,204,51,.5);
    background: rgba(255,204,51,.08);
    color: #ffcc33;
    text-decoration: none;
  }
</style>
</Layout>
