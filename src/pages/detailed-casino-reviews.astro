function stars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5;
  let s = '★'.repeat(full);
  if (half) s += '½';
  return s;
}
---
<Layout title={title} description={description} slug="detailed-casino-reviews">

<div class="cr-page">

  <!-- HERO -->
  <section class="cr-hero">
    <div class="cr-container">
      <div class="cr-hero-badge"><span class="cr-badge-dot"></span> {casinos.length} CASINOS REVIEWED</div>
      <h1>Detailed Casino Reviews</h1>
      <p class="cr-hero-sub">Every casino independently tested for licensing, payout speed, bonus fairness and player protection. Ranked by our proprietary TCS Score.</p>
      <div class="cr-hero-btns">
        <a href="https://44deal.com" target="_blank" rel="nofollow noopener sponsored" class="cr-btn-primary">🎯 Claim Best Bonus For My Region</a>
        <a href="/casino-bonus-finder" class="cr-btn-secondary">🤖 AI Bonus Finder</a>
      </div>
    </div>
  </section>

  <!-- FILTER BAR -->
  <div class="cr-filter-bar">
    <div class="cr-container cr-filter-inner">
      <span class="cr-filter-label">Filter:</span>
      <button class="cr-filter-btn is-active" data-filter="all">All ({casinos.length})</button>
      <button class="cr-filter-btn" data-filter="top">Top Rated (4.5+)</button>
      <button class="cr-filter-btn" data-filter="crypto">Crypto Friendly</button>
      <button class="cr-filter-btn" data-filter="lowwager">Low Wagering</button>
    </div>
  </div>

  <!-- REVIEWS GRID -->
  <section class="cr-section">
    <div class="cr-container">
      <div class="cr-grid" id="casinoGrid">
        {casinos.map((casino, i) => (
          <div class="cr-card" data-rating={casino.rating} data-tag={casino.tag}>
            <div class="cr-card-head">
              <div class="cr-card-rank">#{i + 1}</div>
              <img
                src={`/wp-content/uploads/2025/11/${casino.logo}`}
                alt={`${casino.name} logo`}
                class="cr-card-logo"
                onerror="this.style.display='none'"
              />
              <div class="cr-card-info">
                <div class="cr-card-name">{casino.name}</div>
                <div class="cr-card-stars">
                  <span class="cr-stars">{stars(casino.rating)}</span>
                  <span class="cr-rating-num">{casino.rating}/5</span>
                </div>
              </div>
              {casino.tag && <div class="cr-card-tag">{casino.tag}</div>}
              <div class="cr-tcs-score">
                <div class="cr-tcs-label">TCS</div>
                <div class="cr-tcs-val">{casino.score.toLocaleString()}</div>
              </div>
            </div>

            <div class="cr-card-body">
              <div class="cr-card-bonus">
                <span class="cr-bonus-icon">🎁</span>
                <div>
                  <div class="cr-bonus-amount">{casino.bonus}</div>
                  <div class="cr-bonus-sub">Wagering: {casino.wagering} · Licence: {casino.license}</div>
                </div>
              </div>

              <div class="cr-score-bars">
                <div class="cr-bar-row">
                  <span>Bonus Value</span>
                  <div class="cr-bar-track"><div class="cr-bar-fill" style={`width:${Math.round((casino.score / 10000) * 100 * 1.1)}%`}></div></div>
                </div>
                <div class="cr-bar-row">
                  <span>Payout Speed</span>
                  <div class="cr-bar-track"><div class="cr-bar-fill" style={`width:${Math.round((casino.rating / 5) * 85)}%`}></div></div>
                </div>
                <div class="cr-bar-row">
                  <span>Trust Score</span>
                  <div class="cr-bar-track"><div class="cr-bar-fill" style={`width:${Math.round((casino.score / 10000) * 90)}%`}></div></div>
                </div>
              </div>
            </div>

            <div class="cr-card-foot">
              <a href={`/${casino.slug}`} class="cr-btn-read">Read Full Review</a>
              <a href="https://44deal.com" target="_blank" rel="nofollow noopener sponsored" class="cr-btn-claim">Claim Bonus →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="cr-cta-strip">
    <div class="cr-container cr-cta-inner">
      <div>
        <h2>Not sure which casino is right for you?</h2>
        <p>Let our AI match you to the best verified offer in your region in seconds.</p>
      </div>
      <a href="https://44deal.com" target="_blank" rel="nofollow noopener sponsored" class="cr-btn-primary">🎯 Find My Best Bonus Now →</a>
    </div>
  </section>

</div>

<script>
  // Filter functionality
  document.querySelectorAll('.cr-filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cr-filter-btn').forEach(b => b.classList.remove('is-active'));
      this.classList.add('is-active');
      const filter = this.getAttribute('data-filter');
      document.querySelectorAll('.cr-card').forEach(card => {
        const rating = parseFloat(card.getAttribute('data-rating') || '0');
        const tag = (card.getAttribute('data-tag') || '').toLowerCase();
        let show = true;
        if (filter === 'top') show = rating >= 4.5;
        else if (filter === 'crypto') show = tag.includes('crypto') || tag.includes('usdt');
        else if (filter === 'lowwager') show = tag.includes('low');
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .cr-page { background: #05051b; }
  .cr-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .cr-section { padding: 48px 0; }

  /* Hero */
  .cr-hero { background: linear-gradient(160deg, #0b0b2e 0%, #05051b 100%); padding: 64px 0 48px; text-align: center; border-bottom: 1px solid rgba(255,255,255,.07); }
  .cr-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(50,198,113,.12); border: 1px solid rgba(50,198,113,.35); border-radius: 999px; padding: 6px 16px; font-size: .72rem; font-weight: 700; letter-spacing: .1em; color: #32C671; text-transform: uppercase; margin-bottom: 20px; }
  .cr-badge-dot { width: 7px; height: 7px; background: #32C671; border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)} }
  .cr-hero h1 { font-size: clamp(2rem,4vw,3rem); font-weight: 800; color: #fff; margin-bottom: 16px; letter-spacing: -.03em; }
  .cr-hero-sub { color: rgba(255,255,255,.65); font-size: 1.05rem; max-width: 560px; margin: 0 auto 28px; line-height: 1.7; }
  .cr-hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* Buttons */
  .cr-btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 13px 28px; background: #ffcc33; color: #05051b; font-weight: 700; font-size: .95rem; border-radius: 9px; text-decoration: none; transition: background .15s, transform .1s; }
  .cr-btn-primary:hover { background: #f4c045; transform: translateY(-1px); text-decoration: none; }
  .cr-btn-secondary { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: transparent; color: #fff; font-weight: 600; font-size: .92rem; border-radius: 9px; border: 1.5px solid rgba(255,204,51,.4); text-decoration: none; transition: border-color .15s, background .15s; }
  .cr-btn-secondary:hover { border-color: #ffcc33; background: rgba(255,204,51,.08); text-decoration: none; }
  .cr-btn-read { display: inline-flex; align-items: center; padding: 9px 18px; background: transparent; color: rgba(255,255,255,.8); font-weight: 600; font-size: .85rem; border-radius: 7px; border: 1px solid rgba(255,255,255,.15); text-decoration: none; transition: border-color .15s; }
  .cr-btn-read:hover { border-color: rgba(255,255,255,.4); text-decoration: none; }
  .cr-btn-claim { display: inline-flex; align-items: center; padding: 9px 20px; background: #ffcc33; color: #05051b; font-weight: 700; font-size: .88rem; border-radius: 7px; text-decoration: none; transition: background .15s; }
  .cr-btn-claim:hover { background: #f4c045; text-decoration: none; }

  /* Filter bar */
  .cr-filter-bar { background: rgba(255,255,255,.02); border-bottom: 1px solid rgba(255,255,255,.07); padding: 14px 0; position: sticky; top: 68px; z-index: 10; backdrop-filter: blur(12px); }
  .cr-filter-inner { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .cr-filter-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.4); margin-right: 4px; }
  .cr-filter-btn { padding: 6px 16px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 999px; color: rgba(255,255,255,.7); font-size: .8rem; font-weight: 600; cursor: pointer; transition: all .15s; font-family: inherit; }
  .cr-filter-btn:hover, .cr-filter-btn.is-active { background: rgba(255,204,51,.1); border-color: rgba(255,204,51,.4); color: #ffcc33; }

  /* Cards */
  .cr-grid { display: flex; flex-direction: column; gap: 16px; }
  .cr-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; overflow: hidden; transition: border-color .2s, transform .15s; }
  .cr-card:hover { border-color: rgba(255,204,51,.3); transform: translateY(-2px); }
  .cr-card-head { display: flex; align-items: center; gap: 16px; padding: 18px 20px; border-bottom: 1px solid rgba(255,255,255,.06); flex-wrap: wrap; }
  .cr-card-rank { font-size: 1.1rem; font-weight: 800; color: #ffcc33; width: 32px; text-align: center; flex-shrink: 0; }
  .cr-card-logo { width: 52px; height: 52px; object-fit: contain; border-radius: 10px; background: rgba(255,255,255,.07); padding: 5px; flex-shrink: 0; }
  .cr-card-info { flex: 1; min-width: 0; }
  .cr-card-name { font-weight: 700; font-size: 1rem; color: #fff; margin-bottom: 4px; }
  .cr-card-stars { display: flex; align-items: center; gap: 6px; }
  .cr-stars { color: #ffcc33; font-size: .9rem; }
  .cr-rating-num { font-size: .78rem; color: rgba(255,255,255,.5); }
  .cr-card-tag { padding: 3px 10px; background: rgba(255,204,51,.12); border: 1px solid rgba(255,204,51,.3); border-radius: 999px; font-size: .7rem; font-weight: 700; color: #ffcc33; white-space: nowrap; }
  .cr-tcs-score { text-align: center; flex-shrink: 0; }
  .cr-tcs-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,204,51,.6); }
  .cr-tcs-val { font-size: 1rem; font-weight: 800; color: #ffcc33; }

  .cr-card-body { padding: 16px 20px; }
  .cr-card-bonus { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
  .cr-bonus-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
  .cr-bonus-amount { font-weight: 700; color: #ffcc33; font-size: .95rem; margin-bottom: 3px; }
  .cr-bonus-sub { font-size: .75rem; color: rgba(255,255,255,.45); }

  .cr-score-bars { display: flex; flex-direction: column; gap: 8px; }
  .cr-bar-row { display: flex; align-items: center; gap: 10px; font-size: .75rem; color: rgba(255,255,255,.5); }
  .cr-bar-row span { width: 90px; flex-shrink: 0; }
  .cr-bar-track { flex: 1; height: 5px; background: rgba(255,255,255,.08); border-radius: 999px; overflow: hidden; }
  .cr-bar-fill { height: 100%; background: linear-gradient(90deg, #ffcc33, #f4a800); border-radius: 999px; max-width: 95%; }

  .cr-card-foot { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-top: 1px solid rgba(255,255,255,.06); gap: 12px; }

  /* CTA Strip */
  .cr-cta-strip { background: rgba(255,204,51,.05); border-top: 1px solid rgba(255,204,51,.15); padding: 48px 0; }
  .cr-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cr-cta-inner h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
  .cr-cta-inner p { color: rgba(255,255,255,.6); font-size: .9rem; }

  @media (max-width: 600px) {
    .cr-card-head { gap: 10px; }
    .cr-tcs-score { display: none; }
    .cr-score-bars { display: none; }
  }
</style>

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Finder</a>
      <a href="/blacklisted-online-casinos" class="il-link">🚫 Blacklisted</a>
      <a href="/how-we-rate-online-casinos" class="il-link">📋 How We Rate</a>
    </div>
  </div>
</div>

</Layout>
