        <img src="/wp-content/uploads/2025/11/canada-480.webp" alt="Canada Casino Bonuses">
        <span>🇨🇦 Canada</span>
      </a>
      <a href="/new-zealand" class="hp-country-card">
        <img src="/wp-content/uploads/2025/11/new-zealand-480.webp" alt="NZ Casino Bonuses">
        <span>🇳🇿 New Zealand</span>
      </a>
      <a href="/ireland" class="hp-country-card">
        <img src="/wp-content/uploads/2025/11/ireland-480.webp" alt="Ireland Casino Bonuses">
        <span>🇮🇪 Ireland</span>
      </a>
      <a href="/australia" class="hp-country-card">
