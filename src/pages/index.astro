ba(255,74,74,.20) 0%, rgba(255,74,74,0) 55%);\n  }\n  #tcs-hero .tcs-pick-card:nth-child(3){\n    background:\n      linear-gradient(180deg, rgba(167,102,255,.22) 0%, rgba(5,5,27,.60) 58%, rgba(5,5,27,.92) 100%),\n      radial-gradient(900px 520px at 50% 0%, rgba(167,102,255,.22) 0%, rgba(167,102,255,0) 55%);\n  }\n\n  #tcs-hero .tcs-pick-card:nth-child(1) .tcs-pick-badge{\n    background: linear-gradient(135deg, rgba(255,204,51,1), rgba(255,170,0,1));\n    color: #051122;\n  }\n  #tcs-hero .tcs-pick-card:nth-child(2) .tcs-pick-badge{\n    background: linear-gradient(135deg, rgba(255,74,74,1), rgba(210,40,40,1));\n    color: #0b0818;\n  }\n  #tcs-hero .tcs-pick-card:nth-child(3) .tcs-pick-badge{\n    background: linear-gradient(135deg, rgba(167,102,255,1), rgba(120,70,210,1));\n    color: #0b0818;\n  }\n\n  @media (max-width: 1100px){\n    .tcs-pick-card{ min-height: 460px; }\n  }\n\n  @media (max-width: 980px){\n    #tcs-hero .tcs-hero-inner{\n      max-width: 1100px;\n      padding-left: 16px;\n      padding-right: 16px;\n    }\n    .tcs-hero-grid{\n      grid-template-columns: 1fr;\n      align-items: start;\n      min-height: 0;\n    }\n    .tcs-hero-tiles{ grid-template-columns: 1fr; }\n    .tcs-finder-meta{ display:none; }\n\n    .tcs-picks-stack{\n      grid-template-columns: 1fr;\n      gap: 12px;\n    }\n    .tcs-pick-card{\n      min-height: 0;\n      height: auto;\n    }\n  }\n</style>\n\n<script data-cfasync=\"false\">\n(function () {\n  var WORKER_URL = \"https://geo-detection.samuellloydgreen.workers.dev/\";\n\n  var metaEl = document.getElementById(\"tcs-finder-meta\");\n  var monthLineEl = document.getElementById(\"tcs-month-line\");\n  var outputEl = document.getElementById(\"tcs-picks-output\");\n  var refreshBtn = document.getElementById(\"tcs-refresh-finder\");\n\n  var termsModal = document.getElementById(\"tcs-terms-modal\");\n  var termsBody = document.getElementById(\"tcs-terms-body\");\n\n  function esc(s) {\n    if (s === null || s === undefined) return \"\";\n    return String(s)\n      .replace(/&/g, \"&amp;\")\n      .replace(/</g, \"&lt;\")\n      .replace(/>/g, \"&gt;\")\n      .replace(/\"/g, \"&quot;\")\n      .replace(/'/g, \"&#039;\");\n  }\n\n  function getMonthNameUTC() {\n    var months = [\"January\",\"February\",\"March\",\"April\",\"May\",\"June\",\"July\",\"August\",\"September\",\"October\",\"November\",\"December\"];\n    var d = new Date();\n    return months[d.getUTCMonth()];\n  }\n\n  function getCountryLabel(code) {\n    if (!code) return \"your country\";\n    var map = { GB:\"United Kingdom\", UK:\"United Kingdom\", IE:\"Ireland\", CA:\"Canada\", NZ:\"New Zealand\", US:\"United States\", GLOBAL:\"Global\" };\n    var upper = String(code).toUpperCase();\n    if (map[upper]) return map[upper];\n    return upper;\n  }\n\n  function setMonthLine() {\n    var m = getMonthNameUTC();\n    if (monthLineEl) monthLineEl.textContent = \"for \" + m;\n  }\n\n  function closeTerms() {\n    if (!termsModal) return;\n    termsModal.className = termsModal.className.replace(/\\bis-open\\b/g, \"\").trim();\n    termsModal.setAttribute(\"aria-hidden\", \"true\");\n    if (termsBody) termsBody.textContent = \"\";\n  }\n\n  function openTerms(text) {\n    if (!termsModal) return;\n    if (termsBody) termsBody.textContent = text || \"See the casino site for full terms.\";\n    if (termsModal.className.indexOf(\"is-open\") === -1) {\n      termsModal.className = (termsModal.className + \" is-open\").trim();\n    }\n    termsModal.setAttribute(\"aria-hidden\", \"false\");\n  }\n\n  function wireModalClose() {\n    if (!termsModal) return;\n\n    var closers = termsModal.querySelectorAll(\"[data-close='1']\");\n    for (var i = 0; i < closers.length; i++) {\n      (function (btn) {\n        btn.addEventListener(\"click\", function () {\n          closeTerms();\n        });\n      })(closers[i]);\n    }\n\n    document.addEventListener(\"keydown\", function (e) {\n      if (!e) return;\n      if (e.key === \"Escape\") closeTerms();\n    });\n  }\n\n  function renderSkeleton() {\n    if (!outputEl) return;\n    outputEl.innerHTML =\n      '<div class=\"tcs-picks-stack\">' +\n        '<div class=\"tcs-picks-skeleton\"></div>' +\n        '<div class=\"tcs-picks-skeleton\"></div>' +\n        '<div class=\"tcs-picks-skeleton\"></div>' +\n      '</div>';\n  }\n\n  function renderPickCard(offer, badgeText, kickerText) {\n    var brand = \"Unknown Casino\";\n    var bonus = \"Bonus details unavailable\";\n    var logo = \"\";\n    var link = \"#\";\n    var keyTerms = \"See the casino site for full terms.\";\n\n    if (offer) {\n      if (offer.casinoBrandName) brand = offer.casinoBrandName;\n      if (offer.bonusLabel) bonus = offer.bonusLabel;\n      if (offer.logoUrl) logo = offer.logoUrl;\n      if (offer.trackingUrl) link = offer.trackingUrl;\n      if (offer.keyTerms) keyTerms = offer.keyTerms;\n    }\n\n    var logoHTML = '<div class=\"tcs-pick-logo\"><span style=\"font-size:11px;opacity:.75;\">Logo</span></div>';\n    if (logo) {\n      logoHTML = '<div class=\"tcs-pick-logo\"><img src=\"' + esc(logo) + '\" alt=\"' + esc(brand) + ' logo\"></div>';\n    }\n\n    return ''\n      + '<article class=\"tcs-pick-card\">'\n      +   '<div class=\"tcs-pick-head\">'\n      +     logoHTML\n      +     '<div class=\"tcs-pick-badge\">' + esc(badgeText) + '</div>'\n      +   '</div>'\n      +   '<div class=\"tcs-pick-body\">'\n      +     '<div class=\"tcs-pick-kicker\">' + esc(kickerText) + '</div>'\n      +     '<div class=\"tcs-pick-brand\">' + esc(brand) + '</div>'\n      +     '<div class=\"tcs-pick-bonus\">' + esc(bonus) + '</div>'\n      +   '</div>'\n      +   '<div class=\"tcs-pick-foot\">'\n      +     '<button type=\"button\" class=\"tcs-pick-terms\" data-tnc=\"' + esc(keyTerms) + '\">T&amp;Cs apply</button>'\n      +     '<a class=\"tcs-pick-claim\" href=\"' + esc(link) + '\" target=\"_blank\" rel=\"nofollow sponsored noopener\">'\n      +       '<span>Play Now</span>'\n      +       '<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M5 12h10M13 6l6 6-6 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>'\n      +     '</a>'\n      +   '</div>'\n      + '</article>';\n  }\n\n  function bindTermsButtons() {\n    if (!outputEl) return;\n    var btns = outputEl.querySelectorAll(\".tcs-pick-terms\");\n    for (var i = 0; i < btns.length; i++) {\n      (function (btn) {\n        btn.addEventListener(\"click\", function () {\n          var t = btn.getAttribute(\"data-tnc\");\n          openTerms(t);\n        });\n      })(btns[i]);\n    }\n  }\n\n  function buildUrl(countryOverride) {\n    var url = WORKER_URL;\n    if (countryOverride) {\n      if (url.indexOf(\"?\") === -1) url = url + \"?country=\" + encodeURIComponent(countryOverride);\n      else url = url + \"&country=\" + encodeURIComponent(countryOverride);\n    }\n    return url;\n  }\n\n  function loadTopPicks(countryOverride) {\n    setMonthLine();\n    renderSkeleton();\n\n    var month = getMonthNameUTC();\n    if (metaEl) metaEl.textContent = \"Loading picks for \" + month + \"...\";\n\n    fetch(buildUrl(countryOverride), { method: \"GET\", cache: \"no-store\" })\n      .then(function (res) {\n        if (!res.ok) throw new Error(\"HTTP \" + res.status);\n        return res.json();\n      })\n      .then(function (data) {\n        var code = null;\n        if (countryOverride) code = countryOverride;\n        else {\n          if (data) {\n            if (data.country) code = data.country;\n          }\n        }\n\n        var countryName = getCountryLabel(code);\n        if (metaEl) metaEl.textContent = \"Detected: \" + countryName;\n\n        var bestA = null;\n        var bestB = null;\n        var bestC = null;\n\n        if (data) {\n          if (data.bestByTcs) {\n            if (data.bestByTcs.length) bestA = data.bestByTcs[0];\n          }\n          if (data.bestNoDeposit) {\n            if (data.bestNoDeposit.length) bestB = data.bestNoDeposit[0];\n          }\n          if (data.bestByWagering) {\n            if (data.bestByWagering.length) bestC = data.bestByWagering[0];\n          }\n        }\n\n        if (!outputEl) return;\n\n        outputEl.innerHTML =\n          '<div class=\"tcs-picks-stack\">' +\n            renderPickCard(bestA, \"Top Pick\", \"Best overall value\") +\n            renderPickCard(bestB, \"No Deposit\", \"Best no-deposit\") +\n            renderPickCard(bestC, \"Best Terms\", \"Lowest wagering\") +\n          '</div>';\n\n        bindTermsButtons();\n      })\n      .catch(function (err) {\n        if (metaEl) metaEl.textContent = \"Could not load picks. Please refresh.\";\n        if (outputEl) {\n          outputEl.innerHTML =\n            '<div class=\"tcs-picks-stack\">' +\n              '<div class=\"tcs-pick-card\"><div class=\"tcs-pick-body\"><div class=\"tcs-pick-brand\">Error loading offers</div><div class=\"tcs-pick-bonus\">Please try again in a moment.</div></div></div>' +\n            '</div>';\n        }\n        if (window && window.console) console.error(\"TCS homepage picks error:\", err);\n      });\n  }\n\n  function boot() {\n    wireModalClose();\n\n    if (refreshBtn) {\n      refreshBtn.addEventListener(\"click\", function () {\n        loadTopPicks(null);\n      });\n    }\n\n    loadTopPicks(null);\n  }\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n\n\n\n<!-- SECTION B \u2014 RESOURCES + \u201cBUILT FOR PLAYERS\u201d (TCS WARDROBE v2 DARK) -->\n<section class=\"tcs-section tcs-section--dark\" id=\"tcs-section-b\">\n  <div class=\"tcs-hero-inner tcs-hero-modern tcs-b2-wrap\">\n\n    <div class=\"tcs-b2-grid\">\n\n      <!-- LEFT: 4 RESOURCE BOXES -->\n      <div class=\"tcs-b2-left\" aria-label=\"Explore key resources\">\n\n        <h2 class=\"tcs-b2-title\">Start here: the pages tha