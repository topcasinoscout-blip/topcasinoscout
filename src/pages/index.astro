      <div class="hp-stat"><span class="hp-stat-num">100%</span><span class="hp-stat-label">Independent</span></div>
    </div>
  </div>
</section>

<style>
  /* ── Homepage-scoped styles ── */
  .hp-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .hp-section { padding: 64px 0; background: #05051b; }
  .hp-section--dark { background: #080829; }

  /* Hero */
  .hp-hero {
    background: linear-gradient(160deg, #0b0b2e 0%, #05051b 100%);
    padding: 80px 0 64px;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .hp-hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(50,198,113,.12); border: 1px solid rgba(50,198,113,.35);
    border-radius: 999px; padding: 6px 16px;
    font-size: .75rem; font-weight: 700; letter-spacing: .1em;
    color: #32C671; text-transform: uppercase; margin-bottom: 24px;
  }
  .hp-badge-dot { width: 8px; height: 8px; background: #32C671; border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.3)} }
  .hp-hero-title { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -.03em; margin-bottom: 20px; color: #fff; }
  .hp-gold { color: #ffcc33; }
  .hp-hero-sub { font-size: 1.1rem; color: rgba(255,255,255,.7); max-width: 620px; margin: 0 auto 32px; line-height: 1.7; }
  .hp-hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 16px; }
  .hp-hero-disclaimer { font-size: .75rem; color: rgba(255,255,255,.35); }

  /* Buttons */
  .hp-btn-primary {
    display: inline-flex; align-items: center; padding: 14px 32px;
    background: #ffcc33; color: #05051b; font-weight: 700; font-size: 1rem;
    border-radius: 8px; text-decoration: none; transition: background .15s, transform .1s;
  }
  .hp-btn-primary:hover { background: #f4c045; transform: translateY(-1px); text-decoration: none; }
  .hp-btn-secondary {
    display: inline-flex; align-items: center; padding: 13px 28px;
    background: transparent; color: #fff; font-weight: 600; font-size: .95rem;
    border-radius: 8px; border: 1.5px solid rgba(255,204,51,.4);
    text-decoration: none; transition: border-color .15s, background .15s;
  }
  .hp-btn-secondary:hover { border-color: #ffcc33; background: rgba(255,204,51,.08); text-decoration: none; }
  .hp-btn-outline {
    display: inline-flex; align-items: center; padding: 13px 28px;
    background: transparent; color: rgba(255,255,255,.7); font-weight: 600; font-size: .95rem;
    border-radius: 8px; border: 1.5px solid rgba(255,255,255,.2);
    text-decoration: none; transition: border-color .15s;
  }
  .hp-btn-outline:hover { border-color: rgba(255,255,255,.5); text-decoration: none; }
  .hp-btn-claim {
    display: inline-flex; align-items: center; padding: 10px 22px;
    background: #ffcc33; color: #05051b; font-weight: 700; font-size: .88rem;
    border-radius: 7px; text-decoration: none; white-space: nowrap;
    transition: background .15s; flex-shrink: 0;
  }
  .hp-btn-claim:hover { background: #f4c045; text-decoration: none; }

  /* Section headings */
  .hp-section-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; margin-bottom: 10px; color: #fff; text-align: center; }
  .hp-section-sub { color: rgba(255,255,255,.6); text-align: center; max-width: 600px; margin: 0 auto 40px; line-height: 1.6; }

  /* Casino table */
  .hp-table-header {
    display: grid; grid-template-columns: 80px 1fr 1.5fr 120px 140px;
    gap: 16px; padding: 10px 20px;
    font-size: .75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: rgba(255,255,255,.4);
    border-bottom: 1px solid rgba(255,255,255,.08);
    margin-bottom: 8px;
  }
  .hp-casino-row {
    display: grid; grid-template-columns: 80px 1fr 1.5fr 120px 140px;
    gap: 16px; align-items: center;
    padding: 16px 20px;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px; margin-bottom: 10px;
    transition: border-color .2s, background .2s;
  }
  .hp-casino-row:hover { border-color: rgba(255,204,51,.3); background: rgba(255,204,51,.04); }
  .hp-casino-rank { font-size: 1.1rem; font-weight: 800; color: #ffcc33; text-align: center; }
  .hp-casino-logo-wrap { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .hp-casino-logo { width: 52px; height: 52px; object-fit: contain; border-radius: 10px; background: rgba(255,255,255,.06); padding: 4px; flex-shrink: 0; }
  .hp-casino-name { font-weight: 700; font-size: .95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .hp-bonus-amount { font-weight: 700; color: #ffcc33; font-size: .95rem; margin-bottom: 3px; }
  .hp-bonus-sub { font-size: .75rem; color: rgba(255,255,255,.5); }
  .hp-casino-stars { display: flex; flex-direction: column; gap: 2px; }
  .hp-stars { color: #ffcc33; font-size: .9rem; }
  .hp-rating { font-size: .75rem; color: rgba(255,255,255,.5); }
  .hp-table-footer { text-align: center; margin-top: 24px; }

  @media (max-width: 768px) {
    .hp-table-header { display: none; }
    .hp-casino-row { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto auto; gap: 10px; }
    .hp-casino-rank { grid-column: 1; grid-row: 1; }
    .hp-casino-logo-wrap { grid-column: 2; grid-row: 1; }
    .hp-casino-bonus { grid-column: 1 / 3; grid-row: 2; }
    .hp-casino-stars { grid-column: 1; grid-row: 3; }
    .hp-btn-claim { grid-column: 2; grid-row: 3; }
  }

  /* Cards grid */
  .hp-cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 768px) { .hp-cards-grid { grid-template-columns: 1fr; } }
  .hp-card {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px; overflow: hidden; text-decoration: none; color: #fff;
    transition: border-color .2s, transform .15s;
    display: flex; flex-direction: column;
  }
  .hp-card:hover { border-color: rgba(255,204,51,.35); transform: translateY(-3px); text-decoration: none; }
  .hp-card-img { width: 100%; height: 180px; object-fit: cover; }
  .hp-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .hp-card-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
  .hp-card-text { color: rgba(255,255,255,.6); font-size: .9rem; line-height: 1.6; flex: 1; margin-bottom: 14px; }
  .hp-card-link { color: #ffcc33; font-weight: 700; font-size: .88rem; }

  /* Trust */
  .hp-trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 900px) { .hp-trust-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .hp-trust-grid { grid-template-columns: 1fr; } }
  .hp-trust-item {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px; padding: 24px; text-align: center;
  }
  .hp-trust-icon { font-size: 2rem; margin-bottom: 12px; }
  .hp-trust-item h3 { font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
  .hp-trust-item p { font-size: .88rem; color: rgba(255,255,255,.6); line-height: 1.6; }

  /* Countries */
  .hp-countries-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; }
  @media (max-width: 900px) { .hp-countries-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 480px) { .hp-countries-grid { grid-template-columns: repeat(2, 1fr); } }
  .hp-country-card {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px; padding: 16px 10px; text-decoration: none; color: #fff;
    font-size: .85rem; font-weight: 600; text-align: center;
    transition: border-color .2s, background .2s;
  }
  .hp-country-card:hover { border-color: rgba(255,204,51,.35); background: rgba(255,204,51,.04); text-decoration: none; }
  .hp-country-card img { width: 60px; height: 60px; object-fit: cover; border-radius: 50%; border: 2px solid rgba(255,255,255,.15); }

  /* About strip */
  .hp-about-strip { display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center; }
  @media (max-width: 768px) { .hp-about-strip { grid-template-columns: 1fr; } }
  .hp-about-stats { display: flex; gap: 32px; flex-wrap: wrap; }
  .hp-stat { display: flex; flex-direction: column; align-items: center; }
  .hp-stat-num { font-size: 1.8rem; font-weight: 800; color: #ffcc33; }
  .hp-stat-label { font-size: .78rem; color: rgba(255,255,255,.5); text-align: center; margin-top: 2px; }
</style>

</Layout>
