<style>
  .hp-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .hp-section { padding: 64px 0; background: #05051b; }
  .hp-section--dark { background: #080829; }

  /* ── HERO ── */
  .hp-hero {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255,204,51,.12) 0%, transparent 70%),
      linear-gradient(180deg, #0b0b2e 0%, #05051b 100%);
    padding: 96px 0 80px;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .hp-hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(50,198,113,.12); border: 1px solid rgba(50,198,113,.35);
    border-radius: 999px; padding: 6px 18px;
    font-size: .72rem; font-weight: 700; letter-spacing: .12em;
    color: #32C671; text-transform: uppercase; margin-bottom: 28px;
  }
  .hp-badge-dot { width: 7px; height: 7px; background: #32C671; border-radius: 50%; animation: pulse 2s infinite; flex-shrink: 0; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)} }

  .hp-hero-title {
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    font-weight: 800; line-height: 1.08;
    letter-spacing: -.03em; margin-bottom: 22px; color: #fff;
  }
  .hp-gold { color: #ffcc33; }
  .hp-hero-sub {
    font-size: clamp(.95rem, 1.5vw, 1.15rem);
    color: rgba(255,255,255,.65);
    max-width: 600px; margin: 0 auto 40px; line-height: 1.75;
  }

  /* ── MEGA CTA BUTTON ── */
  .hp-cta-wrap { margin-bottom: 24px; }
  .hp-mega-btn {
    display: inline-flex; align-items: center; gap: 16px;
    background: linear-gradient(135deg, #ffcc33 0%, #f4a800 100%);
    color: #05051b;
    padding: 20px 36px;
    border-radius: 14px;
    text-decoration: none;
    box-shadow: 0 0 0 0 rgba(255,204,51,.5);
    animation: glow 2.5s ease-in-out infinite;
    transition: transform .15s, box-shadow .15s;
    max-width: 560px;
    width: 100%;
  }
  .hp-mega-btn:hover { transform: translateY(-2px); text-decoration: none; box-shadow: 0 12px 40px rgba(255,204,51,.4); animation: none; }
  @keyframes glow {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,204,51,.4); }
    50% { box-shadow: 0 0 0 12px rgba(255,204,51,0); }
  }
  .hp-mega-btn--compact { max-width: 380px; padding: 16px 28px; animation: none; }
  .hp-mega-btn-icon { font-size: 1.8rem; flex-shrink: 0; }
  .hp-mega-btn-text { display: flex; flex-direction: column; align-items: flex-start; gap: 3px; }
  .hp-mega-btn-top { font-size: 1.15rem; font-weight: 800; letter-spacing: -.01em; line-height: 1.2; }
  .hp-mega-btn-sub { font-size: .78rem; font-weight: 600; opacity: .7; }

  .hp-cta-sub {
    margin-top: 14px;
    font-size: .8rem; color: rgba(255,255,255,.45);
    display: flex; align-items: center; justify-content: center; gap: 4px; flex-wrap: wrap;
  }
  .hp-cta-check { color: #32C671; font-weight: 700; }

  /* Trust bar */
  .hp-trust-bar {
    display: flex; align-items: center; justify-content: center;
    gap: 10px; flex-wrap: wrap; margin-top: 32px;
  }
  .hp-trust-pill {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px; padding: 7px 16px;
    font-size: .78rem; font-weight: 600; color: rgba(255,255,255,.7);
  }

  /* Casino table */
  .hp-table-header {
    display: grid; grid-template-columns: 70px 1fr 1.5fr 120px 150px;
    gap: 16px; padding: 10px 20px;
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: rgba(255,255,255,.35);
    border-bottom: 1px solid rgba(255,255,255,.08); margin-bottom: 10px;
  }
  .hp-casino-row {
    display: grid; grid-template-columns: 70px 1fr 1.5fr 120px 150px;
    gap: 16px; align-items: center;
    padding: 16px 20px;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px; margin-bottom: 10px;
    transition: border-color .2s, background .2s;
  }
  .hp-casino-row:hover { border-color: rgba(255,204,51,.35); background: rgba(255,204,51,.03); }
  .hp-casino-rank { font-size: 1.1rem; font-weight: 800; color: #ffcc33; text-align: center; }
  .hp-casino-logo-wrap { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .hp-casino-logo { width: 52px; height: 52px; object-fit: contain; border-radius: 10px; background: rgba(255,255,255,.07); padding: 5px; flex-shrink: 0; }
  .hp-casino-name { font-weight: 700; font-size: .95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .hp-bonus-amount { font-weight: 700; color: #ffcc33; font-size: .95rem; margin-bottom: 3px; }
  .hp-bonus-sub { font-size: .73rem; color: rgba(255,255,255,.45); }
  .hp-casino-stars { display: flex; flex-direction: column; gap: 2px; }
  .hp-stars { color: #ffcc33; font-size: .88rem; }
  .hp-rating { font-size: .73rem; color: rgba(255,255,255,.45); }
  .hp-table-footer { text-align: center; margin-top: 24px; }

  @media (max-width: 800px) {
    .hp-table-header { display: none; }
    .hp-casino-row { grid-template-columns: 56px 1fr auto; grid-template-rows: auto auto; gap: 8px; }
    .hp-casino-rank { grid-row: 1; }
    .hp-casino-logo-wrap { grid-row: 1; grid-column: 2; }
    .hp-btn-claim { grid-row: 1; grid-column: 3; }
    .hp-casino-bonus { grid-row: 2; grid-column: 1 / 4; }
    .hp-casino-stars { display: none; }
  }

  /* CTA strip */
  .hp-cta-strip {
    background: linear-gradient(135deg, rgba(255,204,51,.08) 0%, rgba(255,204,51,.03) 100%);
    border-top: 1px solid rgba(255,204,51,.15);
    border-bottom: 1px solid rgba(255,204,51,.15);
    padding: 48px 0;
  }
  .hp-cta-strip-inner { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .hp-cta-strip-title { font-size: clamp(1.2rem,2.5vw,1.6rem); font-weight: 800; margin-bottom: 6px; }
  .hp-cta-strip-sub { color: rgba(255,255,255,.6); font-size: .9rem; }

  /* Buttons */
  .hp-btn-primary { display:inline-flex;align-items:center;padding:13px 28px;background:#ffcc33;color:#05051b;font-weight:700;font-size:.95rem;border-radius:8px;text-decoration:none;transition:background .15s,transform .1s; }
  .hp-btn-primary:hover { background:#f4c045;transform:translateY(-1px);text-decoration:none; }
  .hp-btn-secondary { display:inline-flex;align-items:center;padding:12px 24px;background:transparent;color:#fff;font-weight:600;font-size:.9rem;border-radius:8px;border:1.5px solid rgba(255,204,51,.4);text-decoration:none;transition:border-color .15s,background .15s; }
  .hp-btn-secondary:hover { border-color:#ffcc33;background:rgba(255,204,51,.08);text-decoration:none; }
  .hp-btn-outline { display:inline-flex;align-items:center;padding:12px 24px;background:transparent;color:rgba(255,255,255,.6);font-weight:600;font-size:.9rem;border-radius:8px;border:1.5px solid rgba(255,255,255,.2);text-decoration:none;transition:border-color .15s; }
  .hp-btn-outline:hover { border-color:rgba(255,255,255,.5);text-decoration:none; }
  .hp-btn-claim { display:inline-flex;align-items:center;padding:10px 20px;background:#ffcc33;color:#05051b;font-weight:700;font-size:.85rem;border-radius:7px;text-decoration:none;white-space:nowrap;transition:background .15s;flex-shrink:0; }
  .hp-btn-claim:hover { background:#f4c045;text-decoration:none; }

  /* Section headings */
  .hp-section-title { font-size:clamp(1.4rem,3vw,2rem);font-weight:800;margin-bottom:10px;color:#fff;text-align:center; }
  .hp-section-sub { color:rgba(255,255,255,.55);text-align:center;max-width:580px;margin:0 auto 40px;line-height:1.65;font-size:.95rem; }

  /* Cards */
  .hp-cards-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:24px; }
  @media (max-width:768px) { .hp-cards-grid { grid-template-columns:1fr; } }
  .hp-card { background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;overflow:hidden;text-decoration:none;color:#fff;transition:border-color .2s,transform .15s;display:flex;flex-direction:column; }
  .hp-card:hover { border-color:rgba(255,204,51,.35);transform:translateY(-3px);text-decoration:none; }
  .hp-card-img { width:100%;height:180px;object-fit:cover; }
  .hp-card-body { padding:20px;flex:1;display:flex;flex-direction:column; }
  .hp-card-title { font-size:1.05rem;font-weight:700;margin-bottom:8px; }
