---
import Layout from '../layouts/Layout.astro';
const title = "Contact US";
const description = "Contact TopCasinoScout TopCasinoScout is an independent casino comparison site. If you have questions about our reviews, bonus accuracy, player safety, ...";
const content = "<section class=\"tcs-section tcs-section--navy\">\n  <div class=\"tcs-container contact-container\">\n\n    <h1 class=\"tcs-heading-xl\">Contact TopCasinoScout</h1>\n\n    <p class=\"tcs-text-lead contact-intro\">\n      TopCasinoScout is an independent casino comparison site. If you have questions about our\n      reviews, bonus accuracy, player safety, or anything related to our ratings, we want to hear from you.\n      Our team monitors all inboxes daily and aims to respond to most messages within <strong>24\u201348 hours</strong>.\n    </p>\n\n    <!-- PRIMARY CONTACT CARD -->\n    <div class=\"contact-box\">\n      <h2 class=\"tcs-heading-lg\">General Contact &amp; Player Questions</h2>\n      <p>\n        For general enquiries about our rankings, bonus pages, or how our TCS Score works, please email:\n      </p>\n      <a href=\"mailto:info@localhost\" class=\"contact-email\">info@localhost</a>\n      <p style=\"margin-top:10px;font-size:.9rem;color:#9fb4ff;\">\n        We are happy to clarify how we reviewed a casino, explain our methodology, or provide additional\n        context about any rating on the site.\n      </p>\n    </div>\n\n    <!-- CONTACT CHANNELS GRID -->\n    <div class=\"contact-grid\">\n\n      <!-- Complaints -->\n      <div class=\"contact-block\">\n        <h2 class=\"tcs-heading-lg\">Player Complaints &amp; Safety Concerns</h2>\n        <p>\n          If you believe a casino we list is acting unfairly, using predatory terms, or breaching its licence,\n          please share as much detail as possible (screenshots, emails, terms, transaction IDs). This helps us\n          investigate and, where necessary, <strong>blacklist unsafe operators</strong>.\n        </p>\n        <p>\n          Email: <a href=\"mailto:complaints@localhost\" class=\"contact-email-inline\">complaints@localhost</a>\n        </p>\n      </div>\n\n      <!-- Review updates -->\n      <div class=\"contact-block\">\n        <h2 class=\"tcs-heading-lg\">Review Updates &amp; Accuracy</h2>\n        <p>\n          Operators and players can report outdated information, bonus changes, or factual errors in our content.\n          We verify every request against live terms and regulatory sources before updating a review.\n        </p>\n        <p>\n          Email: <a href=\"mailto:reviews@localhost\" class=\"contact-email-inline\">reviews@localhost</a>\n        </p>\n        <p style=\"font-size:.85rem;color:#9fb4ff;margin-top:4px;\">\n          Before contacting us about a known issue, you may also check our\n          <a href=\"/complaints-transparency-report\">Complaints &amp; Transparency Report</a>.\n        </p>\n      </div>\n\n      <!-- Partnerships -->\n      <div class=\"contact-block\">\n        <h2 class=\"tcs-heading-lg\">Licensed Operator Partnerships</h2>\n        <p>\n          Licensed casino brands can contact us about listing requests, bonus verification, or commercial partnerships.\n          Every operator is still reviewed independently under our TCS Score framework before being recommended.\n        </p>\n        <p>\n          Email: <a href=\"mailto:partnerships@localhost\" class=\"contact-email-inline\">partnerships@localhost</a>\n        </p>\n        <p style=\"font-size:.85rem;color:#9fb4ff;margin-top:4px;\">\n          Please include your full legal entity name, licence number, and primary regulatory authority.\n        </p>\n      </div>\n\n      <!-- Media / press -->\n      <div class=\"contact-block\">\n        <h2 class=\"tcs-heading-lg\">Media, Research &amp; Press</h2>\n        <p>\n          Journalists, researchers, and consumer advocates are welcome to reach out for comments, interviews,\n          or data about casino safety trends and blacklisted operators.\n        </p>\n        <p>\n          Email: <a href=\"mailto:press@localhost\" class=\"contact-email-inline\">press@localhost</a>\n        </p>\n      </div>\n\n      <!-- Responsible gambling -->\n      <div class=\"contact-block\">\n        <h2 class=\"tcs-heading-lg\">Responsible Gambling &amp; Welfare</h2>\n        <p>\n          We regularly update our responsible gambling guides and link to accredited support organisations.\n          If you represent a treatment provider, regulator, or charity and would like us to feature your resources,\n          please contact:\n        </p>\n        <p>\n          Email: <a href=\"mailto:rg@localhost\" class=\"contact-email-inline\">rg@localhost</a>\n        </p>\n        <p style=\"font-size:.85rem;color:#ffb366;margin-top:4px;\">\n          <strong>Important:</strong> we cannot provide personalised mental-health or financial counselling.\n          If gambling is harming you or someone close to you, please contact a professional support service\n          listed on our <a href=\"/responsible-gambling\">Responsible Gambling</a> page.\n        </p>\n      </div>\n\n    </div><!-- /.contact-grid -->\n\n    <!-- FINAL NOTE -->\n    <p class=\"contact-footer-text\">\n      TopCasinoScout is an independent comparison and review platform. We do not operate casinos,\n      process payments, or handle player accounts. For issues such as deposits, withdrawals, KYC checks,\n      or locked accounts, you must contact the casino operator directly. We can, however, use your evidence\n      to reassess a casino\u2019s TCS Score and, where appropriate, issue warnings or blacklist updates.\n    </p>\n\n  </div>\n</section>\n\n<style>\n  .contact-container{max-width:900px;margin:0 auto}\n  .contact-intro{max-width:800px}\n  .contact-box{\n    background:#0e0a33;\n    border:1px solid #1b1a4d;\n    padding:26px 28px;\n    border-radius:14px;\n    margin:32px 0 32px;\n    box-shadow:0 0 14px rgba(255,204,51,.06)\n  }\n  .contact-email{\n    display:inline-block;\n    margin-top:8px;\n    font-size:1.15rem;\n    font-weight:700;\n    color:#ffcc33;\n    text-decoration:none\n  }\n  .contact-email:hover{opacity:.9}\n  .contact-email-inline{\n    font-weight:600;\n    color:#ffcc33;\n    text-decoration:none\n  }\n  .contact-email-inline:hover{opacity:.9}\n\n  .contact-grid{\n    display:grid;\n    grid-template-columns:minmax(0,1fr) minmax(0,1fr);\n    gap:26px;\n    margin-top:10px\n  }\n  .contact-block{\n    background:#080829;\n    border-radius:14px;\n    border:1px solid #1b1a4d;\n    padding:20px 20px 18px;\n    color:#d0e3ff;\n    box-shadow:0 0 10px rgba(0,0,0,.4)\n  }\n  .contact-footer-text{\n    margin-top:40px;\n    font-size:.95rem;\n    color:#8fa4cc;\n    text-align:center\n  }\n\n  @media (max-width: 900px){\n    .contact-grid{\n      grid-template-columns:1fr;\n    }\n  }\n</style>";
---
<Layout title={title} description={description} slug="contact-us">
  <div class="tcs-page-content" set:html={content} />

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/" class="il-link">🏠 Home</a>
      <a href="/detailed-casino-reviews" class="il-link">📋 Casino Reviews</a>
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit Bonuses</a>
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Bonus Finder</a>
    </div>
  </div>
</div>

<style>
  .internal-links-block {
    background: rgba(255,204,51,.06);
    border-top: 1px solid rgba(255,204,51,.2);
    border-bottom: 1px solid rgba(255,204,51,.2);
    padding: 18px 24px;
    margin: 32px 0 0;
  }
  .il-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .il-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,204,51,.8);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .il-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .il-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
  }
  .il-link:hover {
    border-color: rgba(255,204,51,.5);
    background: rgba(255,204,51,.08);
    color: #ffcc33;
    text-decoration: none;
  }
</style>
</Layout>
