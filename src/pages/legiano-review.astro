r;\n        overflow:hidden;\n      }\n      .tcs-review-hero-media-inner img {\n        width:100%;\n        height:100%;\n        object-fit:cover;\n        display:block;\n      }\n      .tcs-review-hero-media-placeholder {\n        text-align:center;\n        padding:22px 16px;\n      }\n      .tcs-review-hero-media-placeholder h3 {\n        margin:0 0 6px;\n        font-size:.95rem;\n        color:#ffcc33;\n        letter-spacing:.08em;\n        text-transform:uppercase;\n      }\n      .tcs-review-hero-media-placeholder p {\n        margin:0;\n        font-size:.85rem;\n        color:#a8c7ff;\n      }\n\n      /* CONTENT GRID */\n      .tcs-review-grid {\n        display:grid;\n        grid-template-columns:minmax(0,1.5fr) minmax(0,1.1fr);\n        gap:32px;\n        margin-top:16px;\n      }\n      .tcs-review-block {\n        background:#080826;\n        border-radius:18px;\n        border:1px solid #241e67;\n        padding:24px 22px 22px;\n        box-shadow:0 0 24px rgba(0,0,0,.45);\n        margin-bottom:24px;\n      }\n      .tcs-review-block h2 {\n        margin:0 0 12px;\n        font-size:1.25rem;\n        color:#ffcc33;\n      }\n      .tcs-review-block h3 {\n        margin:0 0 10px;\n        font-size:1.05rem;\n        color:#ffea9c;\n      }\n      .tcs-review-block p {\n        margin:0 0 10px;\n        font-size:.95rem;\n        line-height:1.7;\n        color:#d5e0ff;\n      }\n      .tcs-review-block ul {\n        margin:0 0 8px;\n        padding-left:18px;\n        font-size:.95rem;\n        line-height:1.7;\n        color:#d5e0ff;\n      }\n      .tcs-tagline {\n        font-size:.82rem;\n        color:#8fa1ff;\n        margin-top:6px;\n      }\n\n      .tcs-label-pill {\n        display:inline-block;\n        padding:4px 10px;\n        border-radius:999px;\n        background:#140f3f;\n        border:1px solid #38318c;\n        font-size:.75rem;\n        letter-spacing:.1em;\n        text-transform:uppercase;\n        color:#a8c7ff;\n        margin-bottom:10px;\n      }\n\n      .tcs-verdict-box {\n        border:1px solid #3b348f;\n        background:radial-gradient(circle at top left,#1b134e,#05051b);\n      }\n      .tcs-verdict-highlight {\n        font-size:1.02rem;\n        font-weight:600;\n        color:#ffea9c;\n        margin-bottom:8px;\n      }\n      .tcs-internal-links {\n        margin-top:16px;\n        font-size:.9rem;\n        color:#9eb6ff;\n      }\n      .tcs-internal-links a {\n        color:#ffcc33;\n        text-decoration:none;\n      }\n      .tcs-internal-links a:hover {\n        text-decoration:underline;\n      }\n\n      @media (max-width: 900px) {\n        .tcs-review-hero {\n          grid-template-columns:1fr;\n        }\n        .tcs-review-hero-media {\n          order:-1;\n        }\n        .tcs-review-grid {\n          grid-template-columns:1fr;\n        }\n      }\n    </style>\n\n    <!-- HERO SECTION -->\n    <div class=\"tcs-review-hero\">\n      <div class=\"tcs-review-hero-main\">\n        <div class=\"tcs-review-hero-topline\">\n          TopCasinoScout Score \u2022 Legiano Casino\n        </div>\n\n        <div class=\"tcs-review-hero-row\">\n          <div class=\"tcs-review-hero-left\">\n            <div class=\"tcs-review-logo-circle\">\n              <!-- Swap this placeholder with the real Legiano logo -->\n              <img src=\"LEGIANO-LOGO-PLACEHOLDER.png\" alt=\"Legiano Casino logo\">\n            </div>\n\n            <div class=\"tcs-review-title\">\n              <h2>Legiano Casino</h2>\n\n              <!-- \u2605 RATING: 8,700 TCS \u2192 4.35 / 5.0 \u2192 87% fill -->\n              <div class=\"tcs-rating\">\n                <div class=\"tcs-stars\" style=\"--tcs-fill:87%;\" aria-label=\"4.35 out of 5 stars\">\n                  <div class=\"tcs-stars-base\">\n                    <span>\u2605</span><span>\u2605</span><span>\u2605</span><span>\u2605</span><span>\u2605</span>\n                  </div>\n                  <div class=\"tcs-star