---
import Layout from '../layouts/Layout.astro';
const title = "Accessibility Statement";
const description = "Trust, Transparency & Inclusion Accessibility Statement TopCasinoScout is committed to ensuring that our website and all published casino reviews , bonu...";
const content = "<section class=\"tcs-section tcs-section--deep-navy\">\n  <div class=\"tcs-container accessibility-container\">\n\n    <span class=\"tcs-label-pill\">Trust, Transparency & Inclusion</span>\n    <h1 class=\"tcs-heading-xl\" style=\"margin-top:8px;\">Accessibility Statement</h1>\n\n    <p class=\"tcs-text-lead accessibility-intro\">\n      TopCasinoScout is committed to ensuring that our website and all published\n      <a href=\"/casino-reviews\">casino reviews</a>,\n      <a href=\"/top-casino-bonuses\">bonus comparisons</a>,\n      and <a href=\"/casino-rankings\">rankings</a> are accessible and usable\n      for all visitors, including people with disabilities. We believe every player deserves\n      fair access to independent information, responsible-gambling resources, and transparent\n      casino insights\u2014regardless of device, location or access needs.\n    </p>\n\n    <p class=\"accessibility-meta\">\n      This statement is prepared and maintained by the TopCasinoScout editorial and product teams as\n      part of our broader quality standards, alongside our\n      <a href=\"/editorial-policy/\">Editorial Policy</a>,\n      <a href=\"/complaints-transparency-report/\">Transparency Report</a>\n      and <a href=\"/responsible-gambling\">Responsible Gambling</a> framework.\n    </p>\n\n    <!-- COMMITMENT -->\n    <div class=\"accessibility-block\">\n      <h2 class=\"tcs-heading-lg\">Our Accessibility Commitment</h2>\n      <p>\n        We aim to follow recognised accessibility standards, including the\n        <strong>Web Content Accessibility Guidelines (WCAG) 2.1</strong> at Level AA where practical,\n        so that our content is <strong>perceivable, operable, understandable and robust</strong>.\n        Our goal is that users who rely on assistive technologies can:\n      </p>\n      <ul class=\"accessibility-list\">\n        <li>Navigate casino reviews and rankings using screen readers and keyboards</li>\n        <li>Understand bonus terms and comparison tables without relying on colour alone</li>\n        <li>Access responsible-gambling information in a clear, readable format</li>\n        <li>Use the site comfortably on desktop, tablet and mobile devices</li>\n      </ul>\n      <p>\n        Accessibility is an ongoing process, not a one-time project. We review key pages regularly\n        as we add new countries, tools and features.\n      </p>\n    </div>\n\n    <!-- ACTIONS -->\n    <div class=\"accessibility-block\">\n      <h2 class=\"tcs-heading-lg\">How We Design & Test for Accessibility</h2>\n      <p>\n        TopCasinoScout continuously improves accessibility across the site through a combination\n        of <strong>manual review, user feedback and technical audits</strong>. Our current efforts include:\n      </p>\n      <ul class=\"accessibility-list\">\n        <li>Using logical heading structures (H1\u2013H4) and semantic HTML elements</li>\n        <li>Maintaining clear navigation and consistent layouts across all casino guides</li>\n        <li>Ensuring readable font sizes and high-contrast colour palettes for text and buttons</li>\n        <li>Providing descriptive alt text for logos, icons and key graphics</li>\n        <li>Keeping menus, filters and buttons fully keyboard-accessible</li>\n        <li>Testing core pages with screen readers and built-in browser accessibility tools</li>\n        <li>Reviewing new features\u2014such as geo-specific bonus tables and the\n          <a href=\"/casino-bonus-finder/\">AI Bonus Finder</a>\u2014for accessibility at launch</li>\n      </ul>\n      <p>\n        When we identify accessibility issues, we prioritise fixes on our most-visited content:\n        country hubs, safety guides, banking explainers and casino comparison tables.\n      </p>\n    </div>\n\n    <!-- KNOWN LIMITATIONS -->\n    <div class=\"accessibility-block\">\n      <h2 class=\"tcs-heading-lg\">Known Limitations & Third-Party Content</h2>\n      <p>\n        While we aim for broad WCAG 2.1 alignment, some limitations may still exist:\n      </p>\n      <ul class=\"accessibility-list\">\n        <li>Older images may not yet have full descriptive alt text</li>\n        <li>Historical screenshots from casinos might contain small or low-contrast text</li>\n        <li>Some third-party widgets and affiliate tools may not fully support assistive technology</li>\n      </ul>\n      <p>\n        When we are made aware of an accessibility problem\u2014especially one that prevents a user\n        from understanding safety information or bonus terms\u2014we investigate and attempt to resolve\n        it as quickly as possible, or provide an accessible alternative.\n      </p>\n    </div>\n\n    <!-- CONTACT -->\n    <div class=\"accessibility-block\">\n      <h2 class=\"tcs-heading-lg\">Feedback, Requests & Support</h2>\n      <p>\n        If you experience any difficulty using TopCasinoScout\u2014for example, if a casino table,\n        review or responsible-gambling page is hard to read or navigate\u2014please tell us. Your\n        feedback directly informs our next round of improvements.\n      </p>\n\n      <div class=\"accessibility-contact-row\">\n        <a href=\"/contact-us\"\n           class=\"tcs-btn-primary\"\n           target=\"_blank\"\n           rel=\"noopener noreferrer\">\n          Contact Accessibility & Support\n        </a>\n        <p class=\"accessibility-contact-note\">\n          When contacting us, please include the page URL, your device/browser, and any assistive\n          technology you are using (for example, screen reader name and version). This helps our\n          team reproduce and fix the issue more quickly.\n        </p>\n      </div>\n\n      <p>\n        We aim to respond to accessibility-related inquiries within <strong>72 hours</strong>.\n        For urgent responsible-gambling concerns, please visit our\n        <a href=\"/responsible-gambling\">Responsible Gambling</a> page,\n        which lists independent helplines and support organisations.\n      </p>\n    </div>\n\n    <!-- RESPONSIBLE PLAY NOTE -->\n    <p class=\"tcs-text-muted accessibility-footnote\">\n      Accessibility, editorial independence and responsible play are core parts of the\n      TopCasinoScout quality standard. Our goal is to provide <strong>accurate, transparent and\n      accessible information</strong> so that every player can make informed, safe decisions online.\n    </p>\n\n    <p class=\"accessibility-reviewed\">\n      Last reviewed: <strong>2025</strong> \u2022 This statement will be updated as our platform and\n      accessibility work evolve.\n    </p>\n\n  </div>\n</section>\n\n<style>\n  .accessibility-container{max-width:900px;margin:0 auto}\n  .accessibility-intro{max-width:820px}\n  .accessibility-meta{\n    margin-top:10px;\n    font-size:0.95rem;\n    color:#a9baf5;\n  }\n  .accessibility-block{margin-top:34px;color:#d0e3ff}\n  .accessibility-block p{line-height:1.75}\n  .accessibility-list{margin:10px 0 0;padding-left:1rem}\n  .accessibility-list li{margin-bottom:6px;line-height:1.7}\n  .accessibility-contact-row{\n    margin:14px 0 10px;\n    display:flex;\n    flex-wrap:wrap;\n    gap:14px;\n    align-items:flex-start;\n  }\n  .accessibility-contact-note{\n    max-width:520px;\n    font-size:0.9rem;\n    color:#c0cffc;\n  }\n  .accessibility-footnote{\n    margin-top:32px;\n    font-size:.85rem;\n    color:#9fb0ff;\n  }\n  .accessibility-reviewed{\n    margin-top:8px;\n    font-size:0.8rem;\n    color:#7f8fe0;\n  }\n  @media(max-width:720px){\n    .accessibility-contact-row{\n      flex-direction:column;\n      align-items:flex-start;\n    }\n  }\n</style>";
---
<Layout title={title} description={description} slug="accessibility-statement">
  <div class="tcs-page-content" set:html={content} />
</Layout>
