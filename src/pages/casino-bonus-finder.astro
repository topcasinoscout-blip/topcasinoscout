---
import Layout from '../layouts/Layout.astro';
const title = "AI Bonus Finder";
const description = "LIVE BONUS SCAN \u2022 COUNTRY-MATCHED Casino Bonus Finder Find the best online casino bonuses for your country in seconds. Compare high-value welcome offers...";
const content = "<!-- WRAPPER & STYLES -->\n<section class=\"tcs-section tcs-section--dark\">\n  <div class=\"tcs-container\">\n\n    <!-- Hero Section (compact + stronger intent match) -->\n    <header class=\"tcs-hero-cover\">\n      <div class=\"tcs-hero-inner tcs-hero-modern\" style=\"padding-bottom: 16px; text-align:center;\">\n\n        <!-- Green pill badge -->\n        <div\n          style=\"\n            display:inline-block;\n            background:#32C671;\n            color:#051122;\n            font-size:0.75rem;\n            font-weight:700;\n            padding:4px 10px;\n            border-radius:999px;\n            margin-bottom:10px;\n            letter-spacing:0.5px;\n          \"\n        >\n          LIVE BONUS SCAN \u2022 COUNTRY-MATCHED\n        </div>\n\n        <!-- Main H1 -->\n        <h1\n          style=\"\n            font-size: clamp(1.7rem, 3vw, 2.35rem);\n            margin:8px 0 10px;\n            font-weight: 800;\n            color:#F4C045;\n            line-height:1.2;\n          \"\n        >\n          Casino Bonus Finder\n        </h1>\n\n        <!-- Stronger subtext -->\n        <div style=\"font-size:clamp(0.95rem,1.2vw,1.05rem); color:#d8e4ff; line-height:1.55; font-weight:500; max-width:820px; margin:0 auto;\">\n          Find the best online casino bonuses for your country in seconds.<br>\n          Compare <strong>high-value welcome offers</strong>, <strong>no deposit bonuses</strong>, and <strong>low wagering deals</strong> without digging through fine print.\n        </div>\n\n        <!-- Compact trust / utility strip -->\n        <div style=\"display:flex; flex-wrap:wrap; justify-content:center; gap:10px; margin-top:16px;\">\n          <span style=\"display:inline-block; padding:8px 12px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.10); color:#cbd6ff; font-size:0.88rem; font-weight:700;\">\n            Country eligibility checked\n          </span>\n          <span style=\"display:inline-block; padding:8px 12px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.10); color:#cbd6ff; font-size:0.88rem; font-weight:700;\">\n            Wagering compared\n          </span>\n          <span style=\"display:inline-block; padding:8px 12px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.10); color:#cbd6ff; font-size:0.88rem; font-weight:700;\">\n            Real bonus terms surfaced\n          </span>\n        </div>\n\n        <!-- Intent paragraph -->\n        <p style=\"max-width:860px; margin:16px auto 0; color:#a8c7ff; line-height:1.7; font-size:0.98rem;\">\n          This casino bonus comparison tool is built for players who want a fast shortlist, not marketing fog. We show the key details that shape real value: <strong>wagering requirements</strong>, <strong>minimum deposit</strong>, <strong>promo codes</strong>, and the bonus terms that usually decide whether an offer is worth claiming.\n        </p>\n      </div>\n    </header>\n\n    <!-- Status / Loader (auto-launch) -->\n    <div\n      class=\"tcs-hero-cta-row-modern\"\n      id=\"hero-stats\"\n      style=\"margin-top: 8px; margin-bottom: 12px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; display:none;\"\n    >\n      <div class=\"tcs-hero-stat\" style=\"text-align: center;\">\n        <div\n          class=\"tcs-hero-spinner\"\n          style=\"width: 18px; height: 18px; border: 3px solid rgba(50,198,113,0.3); border-top-color: #32C671; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 6px;\"\n        ></div>\n        <div id=\"hero-status-text\" class=\"tcs-hero-stat-label\" style=\"font-size: 0.9rem;\">\n          Launching Bonus Finder...\n        </div>\n      </div>\n    </div>\n\n    <div class=\"tcs-hero-divider\" style=\"margin-top: 4px;\"></div>\n\n    <!-- WIDGET WINDOWS -->\n    <div\n      id=\"tcs-windows-container\"\n      class=\"tcs-section--deep-navy\"\n      style=\"display: none; animation: fadeIn 0.6s ease-in-out; padding-top: 1px; padding-bottom: 1px;\"\n    >\n\n      <!-- Meta row: country + verified time + override -->\n      <div\n        id=\"tcs-meta-row\"\n        style=\"display:none; margin-bottom: 24px; padding: 12px 16px; border-radius: 6px; background: rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); color:#e0e7ff; font-size:0.9rem; display:flex; flex-wrap:wrap; justify-content:space-between; gap:8px;\"\n      >\n        <div>\n          Best available offers for\n          <strong id=\"tcs-country-label\">your region</strong>.\n        </div>\n        <div>\n          <span id=\"tcs-verified-text\">Verified by AI just now.</span>\n        </div>\n      </div>\n\n      <!-- WINDOWS IN A ROW -->\n      <div class=\"tcs-windows-grid\">\n        <!-- Highest Value -->\n        <div\n          class=\"tcs-finder-window\"\n          style=\"padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);\"\n        >\n          <h2\n            class=\"tcs-heading-lg\"\n            style=\"margin-bottom: 20px; color: #32C671; font-weight: 800; text-transform: uppercase;\"\n          >\n            Highest Value Casino Bonuses\n          </h2>\n          <div id=\"grid-highest\" class=\"bonus-grid\"></div>\n        </div>\n\n        <!-- No Deposit -->\n        <div\n          class=\"tcs-finder-window\"\n          style=\"padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);\"\n        >\n          <h2\n            class=\"tcs-heading-lg\"\n            style=\"margin-bottom: 20px; color: #00D26A; font-weight: 800; text-transform: uppercase;\"\n          >\n            Best No Deposit Bonuses\n          </h2>\n          <div id=\"grid-no-deposit\" class=\"bonus-grid\"></div>\n        </div>\n\n        <!-- Best Wagering -->\n        <div\n          class=\"tcs-finder-window\"\n          style=\"padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);\"\n        >\n          <h2\n            class=\"tcs-heading-lg\"\n            style=\"margin-bottom: 20px; color: #32C671; font-weight: 800; text-transform: uppercase;\"\n          >\n            Best Low Wagering Bonuses\n          </h2>\n          <div id=\"grid-wagering\" class=\"bonus-grid\"></div>\n        </div>\n      </div>\n\n      <!-- No results fallback -->\n      <div id=\"tcs-no-results\" style=\"display:none; text-align:center; margin-top:16px;\">\n        <p\n          class=\"tcs-text-lead\"\n          style=\"color:#ffb3b3; font-size:1rem; margin-bottom:12px;\"\n        >\n          No offers are currently available in your detected region.\n        </p>\n        <button\n          type=\"button\"\n          id=\"tcs-global-btn\"\n          style=\"padding:10px 16px; border-radius:4px; border:none; background:#32C671; color:#ffffff; font-weight:600; cursor:pointer; font-size:0.9rem;\"\n        >\n          See global offers instead\n        </button>\n      </div>\n\n    </div>\n\n    <!-- Footer -->\n    <footer style=\"margin-top: 40px; text-align: center;\">\n      <p class=\"tcs-text-muted\" style=\"max-width: 860px; margin-left: auto; margin-right: auto;\">\n        Offers are shown for comparison purposes only. Terms, eligibility, wagering rules, and withdrawal conditions can change, so always confirm the full details on the operator\u2019s site before depositing.\n      </p>\n    </footer>\n\n  </div>\n</section>\n\n<!-- STYLES -->\n<style>\n  .hidden { display: none !important; }\n  @keyframes spin { 100% { transform: rotate(360deg); } }\n  @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }\n\n  #tcs-windows-container {\n    background-color: #05051b;\n  }\n\n  /* Grid for each category */\n  .bonus-grid {\n    display: grid;\n    grid-template-columns: minmax(0, 1fr);\n    gap: 20px;\n  }\n\n  /* Card base \u2013 updated to match the reference style */\n  .bonus-card {\n    position: relative;\n    background: radial-gradient(circle at top left, #18253f 0%, #05091a 55%, #040515 100%);\n    border-radius: 22px;\n    padding: 22px 22px 20px;\n    color: #ffffff;\n    border: 1px solid rgba(120, 144, 255, 0.25);\n    box-shadow: 0 14px 35px rgba(0, 0, 0, 0.55);\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    overflow: hidden;\n    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;\n  }\n  .bonus-card:hover {\n    transform: translateY(-3px);\n    border-color: rgba(50, 198, 113, 0.6);\n    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.75);\n  }\n\n  /* New offer card layout */\n  .tcs-offer-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n  }\n\n  .tcs-offer-logo-wrap {\n    width: 52px;\n    height: 52px;\n    border-radius: 14px;\n    background: rgba(15, 18, 36, 0.9);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    flex-shrink: 0;\n  }\n  .tcs-offer-logo {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n  }\n\n  .tcs-offer-title-block {\n    flex: 1 1 auto;\n    min-width: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n  }\n\n  .tcs-offer-casino {\n    font-size: 1.1rem;\n    font-weight: 700;\n    letter-spacing: 0.01em;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n\n  .tcs-offer-rating {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 0.82rem;\n    color: #c3d4ff;\n  }\n  .tcs-offer-stars {\n    font-size: 0.9rem;\n  }\n  .tcs-offer-rating-score {\n    opacity: 0.85;\n  }\n\n  /* =========================================================\n     RIBBONS (NO-CLIP VERSION)\n     ========================================================= */\n  .tcs-top-pick-ribbon,\n  .tcs-freespins-ribbon,\n  .tcs-best-terms-ribbon {\n    position: absolute;\n    top: 16px;\n    right: -52px;\n    width: auto;\n    height: auto;\n    overflow: visible;\n    pointer-events: none;\n    transform: rotate(45deg);\n    z-index: 5;\n  }\n\n  .tcs-top-pick-ribbon span,\n  .tcs-freespins-ribbon span,\n  .tcs-best-terms-ribbon span {\n    display: block;\n    white-space: nowrap;\n    line-height: 1;\n    font-weight: 700;\n    font-size: 0.74rem;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    padding: 6px 64px;\n    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.5);\n  }\n\n  .tcs-top-pick-ribbon span {\n    background: linear-gradient(135deg, #ffb300, #ff7a00);\n    color: #101215;\n  }\n\n  .tcs-freespins-ribbon span {\n    background: linear-gradient(135deg, #ff4b5c, #d1002f);\n    color: #fff7f7;\n  }\n\n  .tcs-best-terms-ribbon span {\n    background: linear-gradient(135deg, #a96dff, #5b2cff);\n    color: #f7f3ff;\n  }\n\n  .tcs-offer-main {\n    text-align: center;\n    padding: 10px 6px 2px;\n    border-top: 1px solid rgba(255,255,255,0.05);\n    border-bottom: 1px solid rgba(255,255,255,0.05);\n  }\n\n  .tcs-offer-tag {\n    font-size: 0.78rem;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    color: #45e78b;\n    margin-bottom: 6px;\n    font-weight: 700;\n  }\n\n  .tcs-offer-headline {\n    font-size: 1.6rem;\n    font-weight: 800;\n    line-height: 1.15;\n    margin-bottom: 4px;\n  }\n\n  .tcs-offer-subline {\n    font-size: 0.95rem;\n    color: #c4d5ff;\n    opacity: 0.9;\n  }\n\n  .tcs-offer-meta-grid {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 18px;\n    margin-top: 10px;\n    font-size: 0.82rem;\n    color: #a8b5e6;\n  }\n  .tcs-offer-meta-item {\n    text-align: center;\n  }\n  .tcs-offer-meta-label {\n    display: block;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n    font-size: 0.73rem;\n    opacity: 0.75;\n    margin-bottom: 3px;\n  }\n  .tcs-offer-meta-value {\n    font-weight: 600;\n    color: #ffffff;\n  }\n\n  .tcs-offer-promo-row {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    margin-top: 10px;\n    font-size: 0.82rem;\n  }\n  .tcs-offer-promo-label {\n    opacity: 0.8;\n  }\n  .tcs-offer-promo-code {\n    color: #32C671;\n    font-weight: 700;\n    background: rgba(50, 198, 113, 0.1);\n    padding: 2px 8px;\n    border-radius: 4px;\n    white-space: nowrap;\n  }\n\n  .tcs-offer-cta {\n    display: block;\n    margin-top: 16px;\n    padding: 12px 18px;\n    text-align: center;\n    border-radius: 999px;\n    background: linear-gradient(135deg, #32C671, #1faa59);\n    color: #ffffff;\n    font-weight: 700;\n    text-decoration: none;\n    font-size: 0.98rem;\n    box-shadow: 0 10px 20px rgba(25, 145, 84, 0.45);\n    cursor: pointer;\n    transition: transform 0.16s ease, box-shadow 0.16s ease, filter 0.16s ease;\n  }\n  .tcs-offer-cta:hover {\n    transform: translateY(-2px);\n    filter: brightness(1.06);\n    box-shadow: 0 14px 26px rgba(25, 145, 84, 0.65);\n  }\n\n  .tcs-offer-terms {\n    margin-top: 10px;\n    font-style: italic;\n    font-size: 0.78rem;\n    text-align: center;\n    color: #9aa7d7;\n    opacity: 0.9;\n  }\n\n  /* Carousel footer */\n  .tcs-offer-carousel-footer {\n    margin-top: 10px;\n    font-size: 0.8rem;\n    color:#a8c7ff;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n  }\n  .tcs-offer-carousel-footer button {\n    background:none;\n    border:none;\n    color:#ffb74d;\n    text-decoration:underline;\n    cursor:pointer;\n    padding:0;\n    font-size:0.8rem;\n  }\n\n  /* Layout of the three windows */\n  .tcs-windows-grid {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 24px;\n    align-items: stretch;\n  }\n  .tcs-finder-window {\n    flex: 1 1 320px;\n    min-width: 0;\n  }\n\n  @media (max-width: 640px) {\n    .bonus-card {\n      padding: 18px 16px 18px;\n      border-radius: 18px;\n    }\n    .tcs-offer-headline {\n      font-size: 1.4rem;\n    }\n    .tcs-offer-meta-grid {\n      gap: 12px;\n    }\n  }\n</style>\n\n\n<!-- JAVASCRIPT LOGIC (no async/await, Rocket Loader safe, array-ready) -->\n<script data-cfasync=\"false\">\n(function () {\n  var WORKER_URL = \"https://geo-detection.samuellloydgreen.workers.dev/\";\n\n  var elements = {\n    statsContainer: document.getElementById(\"hero-stats\"),\n    gridHighest: document.getElementById(\"grid-highest\"),\n    gridNoDeposit: document.getElementById(\"grid-no-deposit\"),\n    gridWagering: document.getElementById(\"grid-wagering\"),\n    windowsContainer: document.getElementById(\"tcs-windows-container\")\n  };\n\n  var statusTextEl = null;\n  var metaRowEl = null;\n  var countryLabelEl = null;\n  var verifiedTextEl = null;\n  var changeCountryToggleEl = null;\n  var countryOverrideEl = null;\n  var countrySelectEl = null;\n  var applyCountryBtnEl = null;\n  var noResultsEl = null;\n  var globalBtnEl = null;\n\n  var lastOverrideCountry = null;\n  var isScanning = false;\n\n  // Carousel state per slot\n  var carousels = {\n    highest: { offers: [], index: 0, containerKey: \"grid-highest\" },\n    nodeposit: { offers: [], index: 0, containerKey: \"grid-no-deposit\" },\n    wagering: { offers: [], index: 0, containerKey: \"grid-wagering\" }\n  };\n\n  function getCountryLabel(code) {\n    if (!code) {\n      return \"your region\";\n    }\n    var map = {\n      GB: \"United Kingdom\",\n      UK: \"United Kingdom\",\n      IE: \"Ireland\",\n      CA: \"Canada\",\n      NZ: \"New Zealand\",\n      US: \"United States\",\n      RU: \"Russia\",\n      GLOBAL: \"Global (all available offers)\"\n    };\n    var upper = String(code).toUpperCase();\n    if (map[upper]) {\n      return map[upper];\n    }\n    return upper;\n  }\n\n  function getStarRating(score) {\n    if (!score || isNaN(score)) {\n      return \"N/A\";\n    }\n    var maxScore = 10000;\n    var stars = Math.round((score / maxScore) * 5);\n    var out = \"\";\n    var i;\n    for (i = 0; i < stars; i++) {\n      out += \"\\u2605\";\n    }\n    for (i = stars; i < 5; i++) {\n      out += \"\\u2606\";\n    }\n    return out;\n  }\n\n  function renderCard(offer, index, total, slotKey) {\n    if (!offer) {\n      return \"\";\n    }\n\n    var casinoName = offer.casinoBrandName || \"Unknown Casino\";\n    var bonusLabel = offer.bonusLabel || \"Bonus details unavailable\";\n    var keyTerms = offer.keyTerms || \"See casino site for full terms.\";\n    var wagering = offer.wageringRequirements || \"See terms\";\n    var minDeposit = offer.minimumDeposit || \"N/A\";\n    var promoCode = offer.promoCode || null;\n    var ratingStars = getStarRating(offer.internalTcsScore);\n    var numericRating = offer.starRating;\n    var logo = offer.logoUrl || \"\";\n    var freeSpins = offer.freeSpins;\n    var category = offer.category || \"Welcome Bonus\";\n\n    var hasFreeSpins = false;\n    if (freeSpins !== null) {\n      if (freeSpins !== undefined) {\n        var fsStr = String(freeSpins).trim();\n        if (fsStr !== \"\") {\n          if (fsStr !== \"-\") {\n            if (fsStr !== \"0\") {\n              hasFreeSpins = true;\n              freeSpins = fsStr;\n            }\n          }\n        }\n      }\n    }\n\n    var link = \"#\";\n    if (offer.trackingUrl) {\n      if (offer.trackingUrl !== \"undefined\") {\n        link = offer.trackingUrl;\n      }\n    }\n\n    var promoHTML;\n    if (promoCode) {\n      promoHTML =\n        '<span class=\"tcs-offer-promo-code\">' +\n        promoCode +\n        \"</span>\";\n    } else {\n      promoHTML = \"<span class=\\\"tcs-offer-promo-code\\\" style=\\\"opacity:0.7;\\\">-</span>\";\n    }\n\n    var logoHTML = \"\";\n    if (logo) {\n      logoHTML =\n        '<div class=\"tcs-offer-logo-wrap\"><img src=\"' +\n        logo +\n        '\" alt=\"' +\n        casinoName +\n        ' logo\" class=\"tcs-offer-logo\"></div>';\n    } else {\n      logoHTML =\n        '<div class=\"tcs-offer-logo-wrap\"><span style=\"font-size:0.75rem;opacity:0.7;\">Logo</span></div>';\n    }\n\n    var ratingDisplay = ratingStars;\n    if (numericRating !== null) {\n      if (numericRating !== undefined) {\n        if (numericRating !== \"\") {\n          ratingDisplay =\n            String(numericRating) + \" / 5 (\" + ratingStars + \")\";\n        }\n      }\n    }\n\n    var html = \"\";\n    html += '<article class=\"bonus-card tcs-offer-card\">';\n\n    if (slotKey === \"highest\" && index === 0) {\n      html += '<div class=\"tcs-top-pick-ribbon\"><span>&nbsp;&nbsp;&nbsp;Top Pick</span></div>';\n    }\n\n    if (slotKey === \"nodeposit\") {\n      html += '<div class=\"tcs-freespins-ribbon\"><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Free Spins</span></div>';\n    }\n\n    if (slotKey === \"wagering\" && index === 0) {\n      html += '<div class=\"tcs-best-terms-ribbon\"><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Best Terms</span></div>';\n    }\n\n    html += '<div class=\"tcs-offer-header\">';\n    html += logoHTML;\n    html += '<div class=\"tcs-offer-title-block\">';\n    html += '<div class=\"tcs-offer-casino\">' + casinoName + \"</div>\";\n    html += '<div class=\"tcs-offer-rating\">';\n    html += '<span class=\"tcs-offer-rating-score\">' + ratingDisplay + \"</span>\";\n    html += \"</div>\";\n    html += \"</div>\";\n    html += \"</div>\";\n    html += \"</div>\";\n\n    html += '<div class=\"tcs-offer-main\">';\n    html +=\n      '<div class=\"tcs-offer-tag\">' +\n      String(category).toUpperCase() +\n      \"</div>\";\n    html +=\n      '<div class=\"tcs-offer-headline\">' +\n      bonusLabel +\n      \"</div>\";\n\n    if (hasFreeSpins) {\n      html +=\n        '<div class=\"tcs-offer-subline\">+' +\n        \" \" +\n        freeSpins +\n        \" Free Spins</div>\";\n    } else {\n      html +=\n        '<div class=\"tcs-offer-subline\">Checked against TopCasinoScout scoring signals.</div>';\n    }\n\n    html += '<div class=\"tcs-offer-meta-grid\">';\n\n    html +=\n      '<div class=\"tcs-offer-meta-item\">' +\n      '<span class=\"tcs-offer-meta-label\">Wagering</span>' +\n      '<span class=\"tcs-offer-meta-value\">' +\n      wagering +\n      \"</span>\" +\n      \"</div>\";\n\n    html +=\n      '<div class=\"tcs-offer-meta-item\">' +\n      '<span class=\"tcs-offer-meta-label\">Min Deposit</span>' +\n      '<span class=\"tcs-offer-meta-value\">' +\n      minDeposit +\n      \"</span>\" +\n      \"</div>\";\n\n    html +=\n      '<div class=\"tcs-offer-meta-item\">' +\n      '<span class=\"tcs-offer-meta-label\">Promo Code</span>' +\n      '<span class=\"tcs-offer-meta-value\">' +\n      (promoCode ? promoCode : \"-\") +\n      \"</span>\" +\n      \"</div>\";\n\n    html += \"</div>\";\n    html += \"</div>\";\n\n    html += '<div class=\"tcs-offer-promo-row\">';\n    html += '<span class=\"tcs-offer-promo-label\">Use code:</span>';\n    html += promoHTML;\n    html += \"</div>\";\n\n    html +=\n      '<a href=\"' +\n      link +\n      '\" target=\"_blank\" rel=\"noopener noreferrer nofollow\" class=\"tcs-offer-cta\">' +\n      \"Claim Bonus\" +\n      \"</a>\";\n\n    html +=\n      '<div class=\"tcs-offer-terms\">\"' +\n      keyTerms +\n      '\"</div>';\n\n    if (total > 1) {\n      var humanIndex = index + 1;\n      var nextId = \"tcs-next-\" + slotKey;\n      html += '<div class=\"tcs-offer-carousel-footer\">';\n      html +=\n        \"<span>Offer \" +\n        humanIndex +\n        \" of \" +\n        total +\n        \"</span>\";\n      html +=\n        '<button type=\"button\" id=\"' +\n        nextId +\n        '\">Show another offer</button>';\n      html += \"</div>\";\n    }\n\n    html += \"</article>\";\n    return html;\n  }\n\n  function renderCarouselSlot(slotKey, emptyMessage) {\n    var slot = carousels[slotKey];\n    if (!slot) {\n      return;\n    }\n\n    var container = null;\n    if (slot.containerKey === \"grid-highest\") {\n      container = elements.gridHighest;\n    } else if (s