const description = "html, body { margin: 0 !important; padding: 0 !important; background: #050505 !important; } body { min-height: 50vh; overflow-x: hidden; } header, foote...";
const content = "<style>\n  html, body {\n    margin: 0 !important;\n    padding: 0 !important;\n    background: #050505 !important;\n  }\n\n  body {\n    min-height: 50vh;\n    overflow-x: hidden;\n  }\n\n  header,\n  footer,\n  nav,\n  .site-header,\n  .site-footer,\n  .top-bar,\n  .main-header,\n  .main-footer,\n  .header,\n  .footer,\n  .navbar,\n  .site-navigation,\n  .ast-header-break-point,\n  .ast-primary-header-bar,\n  .ast-above-header-wrap,\n  .ast-below-header-wrap,\n  .ast-footer-overlay,\n  #masthead,\n  #colophon {\n    display: none !important;\n    visibility: hidden !important;\n    height: 0 !important;\n    min-height: 0 !important;\n    overflow: hidden !important;\n    margin: 0 !important;\n    padding: 0 !important;\n  }\n\n  #page,\n  .site,\n  .site-content,\n  .content-area,\n  .entry-content,\n  .post-content,\n  .container,\n  .wrap,\n  .ast-container {\n    margin: 0 !important;\n    padding: 0 !important;\n    max-width: 100% !important;\n    width: 100% !important;\n  }\n\n  body.page,\n  body.single,\n  article,\n  main {\n    margin: 0 !important;\n    padding: 0 !important;\n  }\n\n  @keyframes tcs-soft-pulse {\n    0% {\n      box-shadow: 0 14px 30px rgba(217,172,29,.22), 0 0 0 rgba(240,198,58,0);\n      transform: translateY(0);\n    }\n    50% {\n      box-shadow: 0 16px 36px rgba(217,172,29,.30), 0 0 24px rgba(240,198,58,.18);\n      transform: translateY(-1px);\n    }\n    100% {\n      box-shadow: 0 14px 30px rgba(217,172,29,.22), 0 0 0 rgba(240,198,58,0);\n      transform: translateY(0);\n    }\n  }\n</style>\n\n<div id=\"tcs-age-gate\" style=\"\n  position:fixed;\n  inset:0;\n  z-index:99999;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  padding:20px;\n  background:rgba(0,0,0,.88);\n  backdrop-filter:blur(8px);\n  font-family:Inter, Arial, sans-serif;\n\">\n  <div style=\"\n    width:100%;\n    max-width:460px;\n    background:linear-gradient(180deg,#0e1228 0%,#050505 100%);\n    border:1px solid rgba(255,255,255,.08);\n    border-radius:24px;\n    padding:30px 24px;\n    text-align:center;\n    box-shadow:0 20px 70px rgba(0,0,0,.65);\n  \">\n    <div style=\"\n      display:inline-flex;\n      align-items:center;\n      justify-content:center;\n      width:68px;\n      height:68px;\n      border-radius:50%;\n      background:linear-gradient(180deg,#f0c63a 0%,#d9ac1d 100%);\n      color:#111;\n      font-size:0.8rem;\n      font-weight:900;\n      margin-bottom:18px;\n    \">TCS Rewards</div>\n\n    <!-- STEP 1: AGE -->\n    <div id=\"tcs-age-step\">\n      <h2 style=\"\n        margin:0 0 12px;\n        color:#fff;\n        font-size:1.85rem;\n        line-height:1.15;\n        font-weight:900;\n      \">\n        Age Restricted Content\n      </h2>\n\n      <p style=\"\n        margin:0 auto;\n        max-width:360px;\n        color:#c7d0e6;\n        font-size:1rem;\n        line-height:1.7;\n      \">\n        This page contains 18+ content. Are you aged 18 or over?\n      </p>\n\n      <div style=\"\n        display:grid;\n        grid-template-columns:1fr 1fr;\n        gap:12px;\n        margin-top:24px;\n      \">\n        <button id=\"tcs-age-yes\" type=\"button\" style=\"\n          border:none;\n          cursor:pointer;\n          border-radius:18px;\n          padding:16px 18px;\n          font-size:1rem;\n          font-weight:900;\n          color:#111;\n          background:linear-gradient(180deg,#f0c63a 0%,#d9ac1d 100%);\n          box-shadow:0 14px 30px rgba(217,172,29,.26);\n        \">\n          Yes, I am 18+\n        </button>\n\n        <button id=\"tcs-age-no\" type=\"button\" style=\"\n          border:1px solid rgba(255,255,255,.14);\n          cursor:pointer;\n          border-radius:18px;\n          padding:16px 18px;\n          font-size:1rem;\n          font-weight:800;\n          color:#fff;\n          background:rgba(255,255,255,.04);\n        \">\n          No\n        </button>\n      </div>\n\n      <p style=\"\n        margin:16px 0 0;\n        color:#7f8aa8;\n        font-size:.82rem;\n        line-height:1.6;\n      \">\n        By entering, you confirm you are of legal age to view this content in your region.\n      </p>\n    </div>\n\n    <!-- STEP 2: ACCESS CODE -->\n    <div id=\"tcs-code-step\" style=\"display:none;\">\n      <h2 style=\"\n        margin:0 0 12px;\n        color:#fff;\n        font-size:1.85rem;\n        line-height:1.15;\n        font-weight:900;\n      \">\n        Enter The Hidden Access Key\n      </h2>\n\n      <p style=\"\n        margin:0 auto;\n        max-width:360px;\n        color:#c7d0e6;\n        font-size:1rem;\n        line-height:1.7;\n      \">\n        Use the stream code to unlock this month\u2019s private viewer reward.\n      </p>\n\n      <div style=\"margin-top:20px;\">\n        <input\n          id=\"tcs-access-code\"\n          type=\"text\"\n          placeholder=\"Enter Access Key\"\n          autocomplete=\"off\"\n          spellcheck=\"false\"\n          style=\"\n            width:100%;\n            box-sizing:border-box;\n            border:1px solid rgba(255,255,255,.14);\n            border-radius:18px;\n            padding:16px 18px;\n            font-size:1rem;\n            font-weight:700;\n            text-align:center;\n            color:#fff;\n            background:rgba(255,255,255,.05);\n            outline:none;\n          \"\n        >\n      </div>\n\n      <p style=\"\n        margin:12px 0 0;\n        color:#8f9aba;\n        font-size:.86rem;\n        line-height:1.5;\n      \">\n        Hint: the code is shown during the livestream\n      </p>\n\n      <p id=\"tcs-code-error\" style=\"\n        display:none;\n        margin:10px 0 0;\n        color:#ff5f5f;\n        font-size:.9rem;\n        font-weight:800;\n      \">\n        Incorrect access code\n      </p>\n\n      <div style=\"\n        display:grid;\n        grid-template-columns:1fr 1fr;\n        gap:12px;\n        margin-top:22px;\n      \">\n        <button id=\"tcs-code-submit\" type=\"button\" style=\"\n          border:none;\n          cursor:pointer;\n          border-radius:18px;\n          padding:16px 18px;\n          font-size:1rem;\n          font-weight:900;\n          color:#111;\n          background:linear-gradient(180deg,#f0c63a 0%,#d9ac1d 100%);\n          box-shadow:0 14px 30px rgba(217,172,29,.26);\n        \">\n          Unlock the Drop\n        </button>\n\n        <button id=\"tcs-code-back\" type=\"button\" style=\"\n          border:1px solid rgba(255,255,255,.14);\n          cursor:pointer;\n          border-radius:18px;\n          padding:16px 18px;\n          font-size:1rem;\n          font-weight:800;\n          color:#fff;\n          background:rgba(255,255,255,.04);\n        \">\n          Back\n        </button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<section style=\"\n  background:#050505;\n  padding:1px 16px;\n  font-family:Inter, Arial, sans-serif;\n  min-height:100vh;\n\">\n  <div style=\"\n    max-width:420px;\n    margin:-130px auto 0;\n    padding:0;\n    text-align:center;\n  \">\n    <div style=\"\n      background:#000;\n      border-radius:26px;\n      overflow:hidden;\n      box-shadow:0 18px 60px rgba(0,0,0,.6);\n      border:1px solid rgba(255,255,255,.06);\n    \">\n\n      <!-- HERO IMAGE -->\n      <div style=\"\n        position:relative;\n        background:linear-gradient(180deg,#101a48 0%,#090d23 100%);\n        padding:14px;\n      \">\n        <a id=\"tcs-image-link\" href=\"https://44deal.com\" target=\"_blank\" rel=\"noopener noreferrer nofollow\" style=\"display:block; text-decoration:none;\">\n          <img\n            id=\"tcs-hero-image\"\n            src=\"/wp-content/uploads/2026/04/ChatGPT-Image-Apr-6-2026-09_38_10-AM.webp\"\n            alt=\"TCS Drops Stream Bonus Promotion\"\n            style=\"\n              display:block;\n              width:100%;\n              height:auto;\n              border-radius:22px;\n              object-fit:cover;\n              box-shadow:0 12px 36px rgba(0,0,0,.38);\n            \"\n          >\n        </a>\n\n        <div style=\"\n          position:absolute;\n          left:26px;\n          right:26px;\n          bottom:26px;\n          display:flex;\n          justify-content:center;\n          pointer-events:none;\n        \">\n          <div style=\"\n            display:inline-flex;\n            align-items:center;\n            gap:8px;\n            padding:9px 16px;\n            border-radius:999px;\n            background:rgba(8,12,24,.86);\n            border:1px solid rgba(255,214,107,.16);\n            box-shadow:0 10px 30px rgba(0,0,0,.35);\n          \">\n            <span style=\"width:8px; height:8px; background:#ffd66b; border-radius:50%; display:inline-block; box-shadow:0 0 10px rgba(255,214,107,.55);\"></span>\n            <span style=\"\n              color:#e9cf8c;\n              font-size:.84rem;\n              font-weight:800;\n              letter-spacing:.04em;\n              text-transform:uppercase;\n            \">\n              Exclusive Access Reward\n            </span>\n          </div>\n        </div>\n      </div>\n\n      <!-- CONTENT -->\n      <div style=\"padding:10px 26px 20px; text-align:center; background:#000;\">\n        <h1 id=\"tcs-title-text\" style=\"\n          margin:0;\n          color:#fff;\n          font-size:2rem;\n          line-height:1.08;\n          font-weight:900;\n        \">\n          You Found It.\n        </h1>\n\n        <p id=\"tcs-headline\" style=\"\n          margin:10px auto 0;\n          max-width:340px;\n          color:#d7def0;\n          font-size:1.05rem;\n          font-weight:700;\n          line-height:1.4;\n        \">\n          Exclusive Stream Offer\n        </p>\n\n        <!-- CTA MOVED HERE -->\n        <div style=\"margin-top:18px;\">\n          <a id=\"tcs-cta-link\"\n             href=\"https://44deal.com\"\n             target=\"_blank\"\n             rel=\"noopener noreferrer nofollow\"\n             style=\"\n               display:block;\n               text-decoration:none;\n               background:linear-gradient(180deg,#f0c63a 0%,#d9ac1d 100%);\n               color:#0d0d0d;\n               font-weight:900;\n               font-size:1.12rem;\n               padding:20px 22px;\n               border-radius:22px;\n               box-shadow:0 14px 30px rgba(217,172,29,.22);\n               letter-spacing:.01em;\n               animation:tcs-soft-pulse 2.2s ease-in-out infinite;\n             \">\n            <span id=\"tcs-cta-text\">Unlock Bonus</span>\n          </a>\n        </div>\n\n        <p id=\"tcs-intro-1\" style=\"\n          margin:14px auto 0;\n          max-width:340px;\n          color:#aeb6cc;\n          font-size:.98rem;\n          line-height:1.55;\n        \">\n          This is the private offer we only show during live streams.\n        </p>\n\n        <p id=\"tcs-intro-2\" style=\"\n          margin:10px auto 0;\n          max-width:340px;\n          color:#9aa3bd;\n          font-size:.95rem;\n          line-height:1.55;\n        \">\n          If you\u2019re seeing this, you came from the stream \u2014 and that matters.\n        </p>\n\n        <p id=\"tcs-intro-3\" style=\"\n          margin:10px auto 0;\n          max-width:340px;\n          color:#9aa3bd;\n          font-size:.95rem;\n          line-height:1.55;\n        \">\n          We don\u2019t show these offers publicly. They\u2019re selected in real time and only shared with viewers who are paying attention.\n        </p>\n\n        <p id=\"tcs-active-now-text\" style=\"\n          margin:12px auto 0;\n          max-width:340px;\n          color:#e6bf52;\n          font-size:.92rem;\n          font-weight:800;\n          letter-spacing:.04em;\n          text-transform:uppercase;\n        \">\n          This one is active right now.\n        </p>\n\n        <!-- ACTIVE PROMOS -->\n <div style=\"margin-top:12px;\">\n          <a href=\"https://t.me/tcsdrops\"\n             target=\"_blank\"\n             rel=\"noopener noreferrer nofollow\"\n             style=\"\n               display:inline-flex;\n               align-items:center;\n               justify-content:center;\n               gap:12px;\n               min-width:176px;\n               text-decoration:none;\n               background:#117fc2;\n               color:#fff;\n               font-weight:800;\n               font-size:1rem;\n               padding:15px 22px;\n               border-radius:18px;\n               box-shadow:0 10px 22px rgba(17,127,194,.16);\n             \">\n            <span>Continue to Telegram</span>\n          </a>\n        </div>\n        <div style=\"margin-top:18px;\">\n          <div style=\"\n            display:inline-flex;\n            align-items:center;\n            gap:9px;\n            padding:10px 16px;\n            border-radius:14px;\n            background:linear-gradient(180deg,#2a1f00 0%,#1a1300 100%);\n            border:1px solid rgba(255,212,77,.22);\n            box-shadow:0 12px 28px rgba(255,191,0,.14);\n          \">\n            <span style=\"color:#ffd44d; font-size:.9rem;\">\u2728</span>\n            <span id=\"tcs-live-offers-text\" style=\"\n              color:#e8bf42;\n              font-size:.92rem;\n              font-weight:800;\n            \">\n              Live Offers Available: 54\n            </span>\n          </div>\n        </div>\n\n      \n        <p style=\"\n          margin:18px 0 0;\n          color:#72798a;\n          font-size:.78rem;\n          letter-spacing:.14em;\n          text-transform:uppercase;\n        \">\n          Play responsibly \u2022 18+\n        </p>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\n(function () {\n  var WORKER_URL = 'https://fragrant-river-191e.samuellloydgreen.workers.dev/';\n\n  var gate = document.getElementById('tcs-age-gate');\n  var ageStep = document.getElementById('tcs-age-step');\n  var codeStep = document.getElementById('tcs-code-step');\n\n  var yesBtn = document.getElementById('tcs-age-yes');\n  var noBtn = document.getElementById('tcs-age-no');\n\n  var codeInput = document.getElementById('tcs-access-code');\n  var codeSubmit = document.getElementById('tcs-code-submit');\n  var codeBack = document.getElementById('tcs-code-back');\n  var codeError = document.getElementById('tcs-code-error');\n\n  var imageLink = document.getElementById('tcs-image-link');\n  var heroImage = document.getElementById('tcs-hero-image');\n  var ctaLink = document.getElementById('tcs-cta-link');\n\n  var titleTextEl = document.getElementById('tcs-title-text');\n  var headlineEl = document.getElementById('tcs-headline');\n  var intro1El = document.getElementById('tcs-intro-1');\n  var intro2El = document.getElementById('tcs-intro-2');\n  var intro3El = document.getElementById('tcs-intro-3');\n  var activeNowTextEl = document.getElementById('tcs-active-now-text');\n  var liveOffersTextEl = document.getElementById('tcs-live-offers-text');\n  var ctaTextEl = document.getElementById('tcs-cta-text');\n\n  if (!gate || !yesBtn || !noBtn || !ageStep || !codeStep || !codeInput || !codeSubmit || !codeBack || !codeError) return;\n\n  var STORAGE_KEY = 'tcs_age_verified';\n  var CODE_KEY = 'tcs_code_verified';\n  var EXIT_URL = 'https://cashmonster.app/signup?invite=3F63FA3A';\n  var ACCESS_CODE = 'MAY150FS';\n  var LIVE_OFFERS_COUNT = '54';\n\n  function showAgeStep() {\n    ageStep.style.display = 'block';\n    codeStep.style.display = 'none';\n    codeError.style.display = 'none';\n    codeInput.value = '';\n  }\n\n  function showCodeStep() {\n    ageStep.style.display = 'none';\n    codeStep.style.display = 'block';\n    codeError.style.display = 'none';\n    setTimeout(function () {\n      codeInput.focus();\n    }, 50);\n  }\n\n  function unlockPage() {\n    gate.style.display = 'none';\n    document.body.style.overflow = '';\n  }\n\n  function checkCode() {\n    var entered = (codeInput.value || '').trim().toUpperCase();\n\n    if (entered === ACCESS_CODE) {\n      try {\n        localStorage.setItem(CODE_KEY, 'yes');\n      } catch (e) {}\n      unlockPage();\n    } else {\n      codeError.style.display = 'block';\n    }\n  }\n\n  function applyOfferData(data) {\n    if (!data || !data.ok) return;\n\n    if (data.imageUrl && heroImage) {\n      heroImage.src = data.imageUrl;\n    }\n\n    if (data.affiliateLink && imageLink) {\n      imageLink.href = data.affiliateLink;\n    }\n\n    if (data.affiliateLink && ctaLink) {\n      ctaLink.href = data.affiliateLink;\n    }\n\n    if (data.titleText && titleTextEl) {\n      titleTextEl.textContent = data.titleText;\n    }\n\n    if (data.headline && headlineEl) {\n      headlineEl.textContent = data.headline;\n    }\n\n    if (data.introLine1 && intro1El) {\n      intro1El.textContent = data.introLine1;\n    }\n\n    if (data.introLine2 && intro2El) {\n      intro2El.textContent = data.introLine2;\n    }\n\n    if (data.introLine3 && intro3El) {\n      intro3El.textContent = data.introLine3;\n    }\n\n    if (data.activeNowText && activeNowTextEl) {\n      activeNowTextEl.textContent = data.activeNowText;\n    }\n\n    if (data.liveOffersText && liveOffersTextEl) {\n      liveOffersTextEl.textContent = data.liveOffersText + ': ' + LIVE_OFFERS_COUNT;\n    }\n\n    if (data.ctaText && ctaTextEl) {\n      ctaTextEl.textContent = data.ctaText;\n    }\n  }\n\n  function loadOfferData() {\n    fetch(WORKER_URL, {\n      method: 'GET',\n      cache: 'no-store'\n    })\n    .then(function (response) {\n      if (!response.ok) {\n        throw new Error('Worker request failed with status ' + response.status);\n      }\n      return response.json();\n    })\n    .then(function (data) {\n      applyOfferData(data);\n    })\n    .catch(function (error) {\n      console.error('Offer data load failed:', error);\n    });\n  }\n\n  try {\n    if (localStorage.getItem(STORAGE_KEY) === 'yes' && localStorage.getItem(CODE_KEY) === 'yes') {\n      unlockPage();\n    } else {\n      document.body.style.overflow = 'hidden';\n      showAgeStep();\n    }\n  } catch (e) {\n    document.body.style.overflow = 'hidden';\n    showAgeStep();\n  }\n\n  yesBtn.addEventListener('click', function () {\n    try {\n      localStorage.setItem(STORAGE_KEY, 'yes');\n    } catch (e) {}\n    showCodeStep();\n  });\n\n  noBtn.addEventListener('click', function () {\n    window.location.href = EXIT_URL;\n  });\n\n  codeBack.addEventListener('click', function () {\n    showAgeStep();\n  });\n\n  codeSubmit.addEventListener('click', checkCode);\n\n  codeInput.addEventListener('keydown', function (e) {\n    if (e.key === 'Enter') {\n      e.preventDefault();\n      checkCode();\n    }\n  });\n\n  codeInput.addEventListener('input', function () {\n    if (codeError.style.display === 'block') {\n      codeError.style.display = 'none';\n    }\n  });\n\n  loadOfferData();\n})();\n</script>";
