const content = "<section class=\"tcs-section tcs-section--deep-navy\" style=\"text-align:left;\">\n  <div class=\"tcs-container\">\n\n    <!-- H1 + INTRO -->\n    <h1 class=\"tcs-review-heading\">\n      Imperial Wins Casino Review &amp; \u20ac1,000 + Free Spins Bonus Breakdown\n    </h1>\n    <p class=\"tcs-review-intro\">\n      Imperial Wins is a Curacao-licensed online casino with fast crypto payouts, a sizeable welcome package\n      and a large multi-provider game lobby. Based on our scoring framework, Imperial Wins earns a\n      <strong>TopCasinoScout Score (TCS) of 7,700 / 10,000</strong>, driven by <strong>very strong payments and withdrawals</strong>,\n      <strong>good game depth</strong> and a generally positive Trustpilot profile, but held back by Tier-3 licensing,\n      only mid-range responsible gambling tools and some confusion around withdrawal fee wording.\n      In this updated Imperial Wins review, we break down the welcome deal, our test results for KYC and\n      payouts, bonus rules, support quality and where the casino still has work to do.\n      All findings in this review are based on our independent audit conducted on 03 December 2025, which included\n      real-time support testing (via live chat/Telegram), bonus verification, payout simulations and a full TCS scoring assessment.\n    </p>\n\n    <!-- (keep your existing <style> block here if you\u2019re using it across reviews) -->\n\n    <!-- HERO SECTION (now matching 1win layout) -->\n    <div class=\"tcs-review-hero\">\n      <div class=\"tcs-review-hero-main\">\n        <div class=\"tcs-review-hero-topline\">\n          TopCasinoScout Score \u2022 Imperial Wins Casino\n        </div>\n\n        <!-- LOGO + TITLE + RATING + TCS SCORE IN ONE TOP ROW -->\n        <div class=\"tcs-review-hero-row\" style=\"align-items:flex-start;\">\n\n          <!-- Left: logo + title + stars -->\n          <div class=\"tcs-review-hero-left\" style=\"flex:1;\">\n            <div class=\"tcs-review