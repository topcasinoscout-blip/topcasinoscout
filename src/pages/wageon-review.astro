n    <a class=\"tcs-btn-secondary\"\n       href=\"/how-we-rate\"\n       target=\"_blank\" rel=\"noopener noreferrer\">\n      Learn How We Rate Casinos\n    </a>\n\n    <!-- BUTTON 4: Blacklisted & Unsafe Casinos -->\n    <a class=\"tcs-btn-secondary\"\n       href=\"/blacklisted-and-unsafe-casinos\"\n       target=\"_blank\" rel=\"noopener noreferrer\">\n      View Blacklisted &amp; Unsafe Casinos\n    </a>\n\n    <!-- BUTTON 5: Insider Articles / Blog -->\n    <a class=\"tcs-btn-secondary\"\n       href=\"/insider-articles/\"\n       target=\"_blank\" rel=\"noopener noreferrer\">\n      Read Insider Articles &amp; Guides\n    </a>\n\n    <!-- BUTTON 6: Responsible gambling -->\n    <a class=\"tcs-btn-secondary\"\n       href=\"/responsible-gambling\"\n       target=\"_blank\" rel=\"noopener noreferrer\">\n      Responsible Gambling Resources\n    </a>\n\n    <!-- BUTTON 7: Review guidelines -->\n    <a class=\"tcs-btn-secondary\"\n       href=\"/casino-review-guidelines\"\n       target=\"_blank\" rel=\"noopener noreferrer\">\n      Casino Review Guidelines\n    </a>\n  </div>\n</div>\n\n</div>\n</div>\n\n</div>\n</section>\n\n<style>\n  /* Make hero + main grid use the same column widths */\n  .tcs-review-hero {\n    margin: 26px 0 40px;\n    display: grid;\n    grid-template-columns: minmax(0,1.5fr) minmax(0,1.1fr);\n    gap: 26px;\n    align-items: stretch;\n  }\n\n  .tcs-review-grid {\n    display: grid;\n    grid-template-columns: minmax(0,1.5fr) minmax(0,1.1fr);\n    gap: 32px;\n    margin-top: 16px;\n  }\n\n  /* Bottom links panel */\n  .tcs-bottom-links-panel {\n    margin-top: 24px;\n  }\n\n  .tcs-bottom-links-grid {\n    display: grid;\n    grid-template-columns: minmax(0,1.1fr) minmax(0,1.4fr);\n    gap: 26px;\n    align-items: center;\n    background: #080826;\n    border-radius: 18px;\n    border: 1px solid #241e67;\n    padding: 26px 24px 24px;\n    box-shadow: 0 0 24px rgba(0,0,0,.45);\n  }\n\n  .tcs-bottom-links-media {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .tcs-bottom-links-media-inner {\n    width: 100%;\n    border-radius: 16px;\n    border: 1px dashed #3b348f;\n    background: radial-gradient(circle at top, #141445, #05051b);\n    padding: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n  }\n\n  .tcs-bottom-links-media-inner img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .tcs-bottom-links-title {\n    margin: 8px 0 10px;\n    font-size: 1.25rem;\n    color: #ffcc33;\n  }\n\n  .tcs-bottom-links-text {\n    margin: 0 0 16px;\n    font-size: .95rem;\n    color: #c9d4ff;\n    max-width: 750px;\n  }\n\n  .tcs-bottom-links-buttons {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 12px;\n  }\n\n  .tcs-bottom-links-buttons .tcs-btn-primary,\n  .tcs-bottom-links-buttons .tcs-btn-secondary {\n    font-size: .9rem;\n    padding: 9px 18px;\n  }\n\n  @media (max-width: 900px) {\n    .tcs-review-hero {\n      grid-template-columns: 1fr;\n    }\n    .tcs-review-hero-media {\n      order: -1;\n    }\n\n    .tcs-review-grid {\n      grid-template-columns: 1fr;\n    }\n\n    .tcs-bottom-links-grid {\n      grid-template-columns: 1fr;\n    }\n    .tcs-bottom-links-media {\n      order: -1; /* image on top for mobile */\n    }\n  }\n</style>";
