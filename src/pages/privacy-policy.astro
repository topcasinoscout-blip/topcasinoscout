---
import Layout from '../layouts/Layout.astro';
const title = "Privacy Policy";
const description = "Privacy Policy This Privacy Policy explains how TopCasinoScout (\u201cwe\u201d, \u201cour\u201d, \u201cthe site\u201d) collects, stores, and uses information when visitors access our...";
const content = "<section class=\"tcs-section tcs-section--navy\">\n  <div class=\"tcs-container privacy-container\">\n\n    <h1 class=\"tcs-heading-xl\">Privacy Policy</h1>\n\n    <p class=\"tcs-text-lead privacy-intro\">\n      This Privacy Policy explains how TopCasinoScout (\u201cwe\u201d, \u201cour\u201d, \u201cthe site\u201d) collects, stores,\n      and uses information when visitors access our website. We are committed to protecting your\n      privacy and ensuring that your personal data is handled securely, transparently, and in\n      compliance with GDPR and other international data protection standards.\n    </p>\n\n    <!-- SECTION 1 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">1. Information We Collect</h2>\n      <p>\n        TopCasinoScout is a casino comparison website. We do not collect sensitive personal data,\n        account credentials, or financial information.  \n        The information we may collect includes:\n      </p>\n      <ul class=\"privacy-list\">\n        <li><strong>Non-identifiable analytics data</strong> such as page views, device type, browser, country, and traffic sources.</li>\n        <li><strong>Cookies and tracking data</strong> used for performance measurement, personalization, and affiliate attribution.\n            See our <a href=\"/cookie-policy\">Cookie Policy</a> for details.</li>\n        <li><strong>Contact information</strong> (only if you voluntarily submit it through our <a href=\"/contact-us\">Contact Page</a>).</li>\n      </ul>\n      <p>We do <strong>not</strong> collect or store gambling activity, deposit amounts, payment details, or casino login information.</p>\n    </div>\n\n    <!-- SECTION 2 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">2. How We Use Your Information</h2>\n      <p>Your data may be used for the following:</p>\n      <ul class=\"privacy-list\">\n        <li>Improving site performance and user experience</li>\n        <li>Providing geo-smart casino bonus recommendations</li>\n        <li>Measuring engagement with <a href=\"/top-casino-bonuses\">bonus tables</a> and rankings</li>\n        <li>Ensuring affiliate links function correctly</li>\n        <li>Detecting technical issues</li>\n        <li>Responding to contact/support requests</li>\n      </ul>\n      <p>We do not use your data for spam, marketing emails, or selling information to third parties.</p>\n    </div>\n\n    <!-- SECTION 3 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">3. Affiliate Tracking & Third-Party Links</h2>\n      <p>\n        TopCasinoScout contains affiliate links. When you click an offer, a tracking parameter may be\n        applied so casino operators can verify referrals.  \n        We do <strong>not</strong> receive:\n      </p>\n      <ul class=\"privacy-list\">\n        <li>Your casino login details</li>\n        <li>Your deposit amounts</li>\n        <li>Your financial information</li>\n        <li>Your personal identity</li>\n      </ul>\n      <p>\n        Affiliate networks may set cookies to confirm traffic for reporting accuracy.  \n        More details are available in our \n        <a href=\"/affiliate-disclosure\">Affiliate Disclosure</a>.\n      </p>\n    </div>\n\n    <!-- SECTION 4 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">4. Legal Basis for Processing (GDPR)</h2>\n      <p>We process data under the following lawful bases:</p>\n      <ul class=\"privacy-list\">\n        <li><strong>Legitimate interest</strong> \u2014 to operate and improve a casino comparison website</li>\n        <li><strong>Consent</strong> \u2014 for cookies & tracking technologies</li>\n        <li><strong>Contractual necessity</strong> \u2014 when users contact us for support</li>\n      </ul>\n    </div>\n\n    <!-- SECTION 5 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">5. Data Storage & Security</h2>\n      <p>\n        We use industry-standard security measures to protect stored data.  \n        Non-personal analytics data is kept for a limited period and then automatically removed.\n      </p>\n      <p>\n        We do not host or store any user accounts, payment details, or sensitive personal identifiers.\n      </p>\n    </div>\n\n    <!-- SECTION 6 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">6. Your Rights</h2>\n      <p>Depending on your region, you may have the right to:</p>\n      <ul class=\"privacy-list\">\n        <li>Access the data we hold about you</li>\n        <li>Request deletion of your personal information</li>\n        <li>Correct inaccurate information</li>\n        <li>Withdraw cookie consent</li>\n        <li>Restrict certain forms of processing</li>\n      </ul>\n      <p>To exercise these rights, contact us using the link below.</p>\n    </div>\n\n    <!-- SECTION 7 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">7. International Data Transfers</h2>\n      <p>\n        Some analytics tools and affiliate networks may process data outside your country.\n        All partners used by TopCasinoScout comply with GDPR, standard contractual clauses,\n        or equivalent safeguards.\n      </p>\n    </div>\n\n    <!-- SECTION 8 -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">8. Updates to This Policy</h2>\n      <p>\n        We may update this Privacy Policy from time to time.  \n        The \u201clast updated\u201d date will always appear at the top of the page.\n      </p>\n    </div>\n\n    <!-- CONTACT -->\n    <div class=\"privacy-block\">\n      <h2 class=\"tcs-heading-lg\">Contact Us</h2>\n      <p>If you have any privacy-related questions, please contact our team.</p>\n      <a href=\"/contact-us\" class=\"tcs-play-button\" target=\"_blank\" rel=\"noopener noreferrer\">\n        Contact Support\n      </a>\n    </div>\n\n  </div>\n</section>\n\n<style>\n  .privacy-container{max-width:900px;margin:0 auto}\n  .privacy-intro{max-width:820px}\n  .privacy-block{margin-top:34px;color:#d0e3ff}\n  .privacy-list{margin:10px 0 0;padding-left:1rem}\n  .privacy-list li{margin-bottom:6px;line-height:1.7}\n</style>";
---
<Layout title={title} description={description} slug="privacy-policy">
  <div class="tcs-page-content" set:html={content} />

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/" class="il-link">🏠 Home</a>
      <a href="/detailed-casino-reviews" class="il-link">📋 Casino Reviews</a>
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit Bonuses</a>
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Bonus Finder</a>
    </div>
  </div>
</div>

<style>
  .internal-links-block {
    background: rgba(255,204,51,.06);
    border-top: 1px solid rgba(255,204,51,.2);
    border-bottom: 1px solid rgba(255,204,51,.2);
    padding: 18px 24px;
    margin: 32px 0 0;
  }
  .il-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .il-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,204,51,.8);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .il-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .il-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
  }
  .il-link:hover {
    border-color: rgba(255,204,51,.5);
    background: rgba(255,204,51,.08);
    color: #ffcc33;
    text-decoration: none;
  }
</style>
</Layout>
