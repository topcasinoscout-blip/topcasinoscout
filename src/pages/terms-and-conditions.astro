---
import Layout from '../layouts/Layout.astro';
const title = "Terms and Conditions";
const description = "Terms & Conditions These Terms & Conditions (\u201cTerms\u201d) govern the use of TopCasinoScout (\u201cwe\u201d, \u201cour\u201d, \u201cthe website\u201d). By accessing or using this site, yo...";
const content = "<section class=\"tcs-section tcs-section--navy\">\n  <div class=\"tcs-container terms-container\">\n\n    <h1 class=\"tcs-heading-xl\">Terms & Conditions</h1>\n\n    <p class=\"tcs-text-lead terms-intro\">\n      These Terms & Conditions (\u201cTerms\u201d) govern the use of TopCasinoScout (\u201cwe\u201d, \u201cour\u201d, \u201cthe website\u201d).\n      By accessing or using this site, you agree to comply fully with these Terms, our \n      <a href=\"/privacy-policy\">Privacy Policy</a>, and \n      <a href=\"/cookie-policy\">Cookie Policy</a>.  \n      If you do not agree with any part of these Terms, you must discontinue use of the website immediately.\n    </p>\n\n    <!-- SECTION 1 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">1. Website Purpose</h2>\n      <p>\n        TopCasinoScout is an independent comparison resource providing information about \n        <strong>online casino bonuses</strong>, deposit offers, free spins, casino reviews,\n        and responsible-gambling guidelines.  \n        We do not provide or operate gambling services directly \u2014 we link to licensed third-party\n        casino operators.\n      </p>\n      <p>\n        Our mission is to help players compare bonuses safely. For more information on how we review and score casinos,\n        visit our <a href=\"/how-we-rate\">Rating Methodology</a>.\n      </p>\n    </div>\n\n    <!-- SECTION 2 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">2. Age Restrictions</h2>\n      <p>\n        This website is strictly intended for users aged <strong>18+</strong> or the legal age for online gambling\n        in your jurisdiction \u2014 whichever is higher.  \n        If you are underage, you must leave the site immediately.\n      </p>\n      <p>For more guidance, see our <a href=\"/age-disclaimer-18/\">18+ Age Disclaimer</a>.</p>\n    </div>\n\n    <!-- SECTION 3 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">3. Affiliate Disclosure</h2>\n      <p>\n        Some links on this website are affiliate links. That means we may receive a commission when a user signs up or\n        deposits at partner casinos \u2014 at no extra cost to you.  \n      </p>\n      <p>\n        This does <strong>not</strong> influence our rankings or reviews. Operator payments cannot buy a higher rating or a positive review.  \n        Full details: <a href=\"/affiliate-disclosure\">Affiliate Disclosure</a>.\n      </p>\n    </div>\n\n    <!-- SECTION 4 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">4. No Gambling Is Offered</h2>\n      <p>\n        TopCasinoScout is an informational and comparison website.  \n        We do not:\n      </p>\n      <ul class=\"terms-list\">\n        <li>Offer real-money gambling services</li>\n        <li>Process deposits, withdrawals, or payment information</li>\n        <li>Manage casino accounts or provide customer support for casinos</li>\n        <li>Access player gambling activity</li>\n      </ul>\n      <p>Any wagering activity takes place exclusively on the third-party casino operator\u2019s website.</p>\n    </div>\n\n    <!-- SECTION 5 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">5. Accuracy of Information</h2>\n      <p>\n        We strive to keep all casino bonus information and rankings accurate. However, bonuses can change frequently.\n        Players should always verify:\n      </p>\n      <ul class=\"terms-list\">\n        <li>Bonus terms & wagering requirements</li>\n        <li>Deposit limits and payment eligibility</li>\n        <li>Restricted countries</li>\n        <li>Expiration dates</li>\n      </ul>\n      <p>\n        We are not responsible for outdated promotions or incorrect operator information.  \n        Use our <a href=\"/casino-bonus-finder/\">AI Bonus Finder</a> for the most up-to-date bonus suggestions.\n      </p>\n    </div>\n\n    <!-- SECTION 6 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">6. User Responsibilities</h2>\n      <p>By using this website, you agree:</p>\n      <ul class=\"terms-list\">\n        <li>Not to misuse the site in any illegal or harmful manner</li>\n        <li>To check gambling laws in your region</li>\n        <li>To play responsibly and never gamble more than you can afford to lose</li>\n      </ul>\n      <p>Support resources can be found at our <a href=\"/responsible-gambling\">Responsible Gambling</a> page.</p>\n    </div>\n\n    <!-- SECTION 7 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">7. Limitation of Liability</h2>\n      <p>\n        TopCasinoScout is not liable for:\n      </p>\n      <ul class=\"terms-list\">\n        <li>Losses resulting from gambling activity</li>\n        <li>Incorrect or outdated bonus information</li>\n        <li>Technical issues or downtime</li>\n        <li>Security breaches occurring on third-party casino websites</li>\n      </ul>\n      <p>\n        Your interaction with any casino operator is at your own risk.  \n        Always read the operator\u2019s own Terms & Conditions before depositing.\n      </p>\n    </div>\n\n    <!-- SECTION 8 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">8. External Links</h2>\n      <p>\n        Our site contains external links to third-party casino operators.  \n        We are not responsible for:\n      </p>\n      <ul class=\"terms-list\">\n        <li>Content on external websites</li>\n        <li>Privacy practices of third-party services</li>\n        <li>Data collection performed by operators or affiliate networks</li>\n      </ul>\n      <p>See our <a href=\"/privacy-policy\">Privacy Policy</a> for data information.</p>\n    </div>\n\n    <!-- SECTION 9 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">9. Changes to These Terms</h2>\n      <p>\n        We may update these Terms occasionally to reflect changes in laws, affiliate networks, or site functionality.\n        The latest version will always appear on this page.\n      </p>\n    </div>\n\n    <!-- SECTION 10 -->\n    <div class=\"terms-block\">\n      <h2 class=\"tcs-heading-lg\">10. Contact Us</h2>\n      <p>If you have questions regarding these Terms, contact our support team below.</p>\n      <a href=\"/contact-us\" class=\"tcs-play-button\" target=\"_blank\" rel=\"noopener noreferrer\">Contact Support</a>\n    </div>\n\n  </div>\n</section>\n\n<style>\n  .terms-container{max-width:900px;margin:0 auto}\n  .terms-intro{max-width:820px}\n  .terms-block{margin-top:34px;color:#d0e3ff}\n  .terms-list{margin:10px 0 0;padding-left:1rem}\n  .terms-list li{margin-bottom:6px;line-height:1.7}\n</style>";
---
<Layout title={title} description={description} slug="terms-and-conditions">
  <div class="tcs-page-content" set:html={content} />
</Layout>
