---
import Layout from '../layouts/Layout.astro';
const title = "Cookie Policy";
const description = "Cookie Policy This Cookie Policy explains how TopCasinoScout (\u201cwe\u201d, \u201cour\u201d, \u201cthe site\u201d) uses cookies, trackers, and similar technologies to improve your ...";
const content = "<section class=\"tcs-section tcs-section--navy\">\n  <div class=\"tcs-container cookie-container\">\n\n    <h1 class=\"tcs-heading-xl\">Cookie Policy</h1>\n\n    <p class=\"tcs-text-lead cookie-intro\">\n      This Cookie Policy explains how TopCasinoScout (\u201cwe\u201d, \u201cour\u201d, \u201cthe site\u201d) uses cookies,\n      trackers, and similar technologies to improve your browsing experience, analyze website traffic,\n      and deliver relevant casino comparison content.  \n      By using this website, you agree to the use of cookies as described below.\n    </p>\n\n    <!-- WHAT ARE COOKIES -->\n    <div class=\"cookie-block\">\n      <h2 class=\"tcs-heading-lg\">What Are Cookies?</h2>\n      <p>\n        Cookies are small text files stored on your device when you visit a website.  \n        They help enhance usability, remember preferences, measure performance, and personalize\n        content such as <a href=\"/top-casino-bonuses/\">casino deposit bonuses</a>,\n        GEO-smart rankings, and recommended gambling sites.\n      </p>\n    </div>\n\n    <!-- TYPES -->\n    <div class=\"cookie-block\">\n      <h2 class=\"tcs-heading-lg\">Types of Cookies We Use</h2>\n\n      <h3 class=\"tcs-heading-md\">1. Essential Cookies</h3>\n      <p>\n        Required for core site features, including navigation, security, and loading\n        structured content like <a href=\"/casino-rankings\">casino rankings tables</a>.\n        These cannot be disabled.\n      </p>\n\n      <h3 class=\"tcs-heading-md\">2. Performance & Analytics Cookies</h3>\n      <p>\n        Help us understand how visitors use the site, which pages perform best, and where\n        users discover casino offers. We may use:\n      </p>\n      <ul class=\"cookie-list\">\n        <li>Google Analytics (IP anonymization enabled)</li>\n        <li>Traffic and click heatmaps</li>\n        <li>Affiliate conversion metrics</li>\n      </ul>\n\n      <h3 class=\"tcs-heading-md\">3. Functional Cookies</h3>\n      <p>\n        Used to remember your preferences such as language, region, and your last-used\n        <a href=\"/casino-bonus-finder/\">AI Casino Bonus Finder</a> settings.\n      </p>\n\n      <h3 class=\"tcs-heading-md\">4. Affiliate Tracking Cookies</h3>\n      <p>\n        Some links contain tracking parameters provided by casino operators or affiliate networks.\n        These allow partners to confirm that TopCasinoScout referred a visitor.\n        We do <strong>not</strong> store personal data and do not receive information about your account,\n        deposits, or identity on casino platforms.\n      </p>\n    </div>\n\n    <!-- MANAGING COOKIES -->\n    <div class=\"cookie-block\">\n      <h2 class=\"tcs-heading-lg\">Managing and Disabling Cookies</h2>\n      <p>\n        You can control or delete cookies at any time using your browser settings.  \n        Most browsers allow you to:\n      </p>\n      <ul class=\"cookie-list\">\n        <li>Block all cookies</li>\n        <li>Delete existing cookies</li>\n        <li>Block third-party cookies</li>\n        <li>Receive alerts when a site wants to set cookies</li>\n      </ul>\n\n      <p>\n        If you disable cookies, some features \u2014 including bonus tables, ranking filters,\n        and personalized casino recommendations \u2014 may not function correctly.\n      </p>\n    </div>\n\n    <!-- THIRD-PARTY -->\n    <div class=\"cookie-block\">\n      <h2 class=\"tcs-heading-lg\">Third-Party Services We Use</h2>\n      <p>\n        We work with trusted third parties to deliver analytics and affiliate reporting, including:\n      </p>\n      <ul class=\"cookie-list\">\n        <li>Google Analytics 4</li>\n        <li>Affiliate networks that track conversions</li>\n        <li>Geo-targeting services for bonus localization</li>\n      </ul>\n      <p>\n        These providers may set their own cookies when you interact with our website.\n      </p>\n    </div>\n\n    <!-- YOUR PRIVACY -->\n    <div class=\"cookie-block\">\n      <h2 class=\"tcs-heading-lg\">Your Privacy Matters</h2>\n      <p>\n        We do not collect personally identifiable information via cookies.\n        All data is used strictly to improve the accuracy of\n        <a href=\"/top-casino-bonuses\">casino bonus comparison tools</a>,\n        enhance site performance, and maintain content relevance based on visitor interests.\n      </p>\n      <p>\n        For detailed data practices, please see our\n        <a href=\"/privacy-policy\">Privacy Policy</a>.\n      </p>\n    </div>\n\n    <!-- CONTACT -->\n    <div class=\"cookie-block\">\n      <h2 class=\"tcs-heading-lg\">Contact Us</h2>\n      <p>\n        If you have questions about how cookies are used on TopCasinoScout, please contact our team through the link below.\n      </p>\n      <a href=\"/contact-us\" class=\"tcs-play-button\" target=\"_blank\" rel=\"noopener noreferrer\">\n        Contact Support\n      </a>\n    </div>\n\n  </div>\n</section>\n\n<style>\n  .cookie-container{max-width:900px;margin:0 auto}\n  .cookie-intro{max-width:820px}\n  .cookie-block{margin-top:34px;color:#d0e3ff}\n  .cookie-list{margin:10px 0 0;padding-left:1rem}\n  .cookie-list li{margin-bottom:6px;line-height:1.7}\n</style>";
---
<Layout title={title} description={description} slug="cookie-policy">
  <div class="tcs-page-content" set:html={content} />

<!-- internal-links-block -->
<div class="internal-links-block">
  <div class="il-inner">
    <span class="il-label">📌 Related</span>
    <div class="il-links">
      <a href="/" class="il-link">🏠 Home</a>
      <a href="/detailed-casino-reviews" class="il-link">📋 Casino Reviews</a>
      <a href="/top-casino-bonuses" class="il-link">🎁 Top Bonuses</a>
      <a href="/no-deposit-bonuses" class="il-link">🎰 No Deposit Bonuses</a>
      <a href="/top-casino-rankings" class="il-link">🏆 Casino Rankings</a>
      <a href="/casino-bonus-finder" class="il-link">🤖 AI Bonus Finder</a>
    </div>
  </div>
</div>

<style>
  .internal-links-block {
    background: rgba(255,204,51,.06);
    border-top: 1px solid rgba(255,204,51,.2);
    border-bottom: 1px solid rgba(255,204,51,.2);
    padding: 18px 24px;
    margin: 32px 0 0;
  }
  .il-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .il-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,204,51,.8);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .il-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .il-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
  }
  .il-link:hover {
    border-color: rgba(255,204,51,.5);
    background: rgba(255,204,51,.08);
    color: #ffcc33;
    text-decoration: none;
  }
</style>
</Layout>
