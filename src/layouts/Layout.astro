---
export interface Props {
  title: string;
  description?: string;
  slug?: string;
}

const { title, description = "TopCasinoScout — The site casinos hope you don't find first. Honest reviews, best bonuses, no fluff.", slug = "" } = Astro.props;
const canonical = `https://topcasinoscout.com/${slug}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-C88RMJRDMX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-C88RMJRDMX');
  </script>
  <title>{title} | TopCasinoScout</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={`${title} | TopCasinoScout`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/tcs-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #05051b; color: #fff; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: #ffcc33; text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <!-- Logo -->
      <a href="/" class="nav-logo">
        <img src="/tcs-logo.png" alt="TopCasinoScout" class="nav-logo-img" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="nav-logo-text" style="display:none">Top<span style="color:#ffcc33">Casino</span>Scout</span>
      </a>

      <!-- Links -->
      <ul class="nav-links" id="navLinks">
        <li><a href="/" class="nav-link">HOME</a></li>
        <li><a href="/top-casino-bonuses" class="nav-link">TOP CASINO BONUSES</a></li>
        <li><a href="/no-deposit-bonuses" class="nav-link">NO DEPOSIT BONUSES</a></li>
        <li><a href="/top-casino-rankings" class="nav-link">CASINO RANKINGS</a></li>
        <li><a href="/detailed-casino-reviews" class="nav-link">CASINO REVIEWS</a></li>
        <li><a href="/bonus-calculator-tool" class="nav-link">TOOLS</a></li>
        <li><a href="/blacklisted-online-casinos" class="nav-link">BLACKLIST</a></li>
        <li><a href="/casino-bonus-finder" class="nav-link nav-link--gold">AI BONUS FINDER</a></li>
      </ul>

      <button class="nav-hamburger" id="navToggle" aria-label="Toggle menu">☰</button>
    </div>
  </nav>

  <!-- Page content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <a href="/" class="footer-logo">
            <img src="/tcs-logo.png" alt="TopCasinoScout" style="height:48px;width:auto;" onerror="this.style.display='none'">
          </a>
          <p class="footer-tagline">The site casinos hope you don't find first. Independent reviews, verified bonuses, and straight-talking guides.</p>
        </div>
        <div class="footer-col">
          <h4>Reviews</h4>
          <ul>
            <li><a href="/detailed-casino-reviews">All Reviews</a></li>
            <li><a href="/top-casino-rankings">Rankings</a></li>
            <li><a href="/blacklisted-online-casinos">Blacklisted</a></li>
            <li><a href="/casino-review-guidelines">Our Process</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Bonuses</h4>
          <ul>
            <li><a href="/top-casino-bonuses">Top Bonuses</a></li>
            <li><a href="/no-deposit-bonuses">No Deposit</a></li>
            <li><a href="/casino-promo-codes">Promo Codes</a></li>
            <li><a href="/free-spin-slots">Free Spins</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Info</h4>
          <ul>
            <li><a href="/about">About Us</a></li>
            <li><a href="/how-we-rate-online-casinos">How We Rate</a></li>
            <li><a href="/responsible-gambling">Responsible Gambling</a></li>
            <li><a href="/contact-us">Contact</a></li>
            <li><a href="/affiliate-disclosure">Disclosure</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-legal">
          © {new Date().getFullYear()} TopCasinoScout. All rights reserved. 18+ only. Gambling can be addictive — please <a href="/responsible-gambling">play responsibly</a>.
          TopCasinoScout is an independent comparison site. We may receive commission from casinos featured on this site.
          <br><a href="/privacy-policy">Privacy</a> · <a href="/terms-and-conditions">Terms</a> · <a href="/cookie-policy">Cookies</a> · <a href="/affiliate-disclosure">Affiliate Disclosure</a>
        </p>
        <div class="footer-age">18+</div>
      </div>
    </div>
  </footer>

  <script>
    // Mobile nav
    const toggle = document.getElementById('navToggle');
    const links = document.getElementById('navLinks');
    if (toggle && links) {
      toggle.addEventListener('click', () => links.classList.toggle('is-open'));
    }
    // Fix any leftover localhost links
    document.querySelectorAll('a[href*="localhost"]').forEach(a => {
      const fixed = (a.getAttribute('href') || '').replace(/https?:\/\/localhost(:\d+)?(\/wordpress)?/g, '');
      if (fixed) a.setAttribute('href', fixed || '/');
    });
  </script>

  <style>
    /* ── NAV ── */
    .nav {
      background: rgba(5,5,27,.97);
      border-bottom: 1px solid rgba(255,255,255,.08);
      position: sticky; top: 0; z-index: 100;
      backdrop-filter: blur(12px);
    }
    .nav-inner {
      max-width: 1400px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; height: 68px; gap: 24px;
    }
    .nav-logo { display: flex; align-items: center; text-decoration: none; flex-shrink: 0; }
    .nav-logo-img { height: 52px; width: auto; }
    .nav-logo-text { font-size: 1.1rem; font-weight: 800; color: #fff; letter-spacing: -.02em; }
    .nav-links {
      display: flex; align-items: center; gap: 2px;
      list-style: none; flex: 1; justify-content: center;
    }
    .nav-link {
      display: block; padding: 6px 11px;
      color: rgba(255,255,255,.75); font-size: .78rem; font-weight: 600;
      letter-spacing: .05em; border-radius: 6px;
      transition: color .15s, background .15s; text-decoration: none;
    }
    .nav-link:hover { color: #fff; background: rgba(255,255,255,.07); text-decoration: none; }
    .nav-link--gold { color: #ffcc33 !important; }
    .nav-link--gold:hover { background: rgba(255,204,51,.1) !important; }
    .nav-hamburger { display: none; background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer; margin-left: auto; }

    @media (max-width: 1100px) {
      .nav-links { display: none; }
      .nav-links.is-open {
        display: flex; flex-direction: column; align-items: flex-start;
        position: absolute; top: 68px; left: 0; right: 0;
        background: rgba(5,5,27,.99); padding: 16px 24px 24px;
        border-bottom: 1px solid rgba(255,255,255,.08); z-index: 99;
      }
      .nav-hamburger { display: block; }
    }

    /* ── FOOTER ── */
    .footer { background: #030314; border-top: 1px solid rgba(255,255,255,.08); padding: 48px 0 32px; }
    .footer-inner { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
    @media (max-width: 768px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 480px) { .footer-grid { grid-template-columns: 1fr; } }
    .footer-tagline { color: rgba(255,255,255,.5); font-size: .85rem; line-height: 1.6; margin-top: 12px; }
    .footer-col h4 { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.4); margin-bottom: 14px; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .footer-col a { color: rgba(255,255,255,.6); font-size: .88rem; transition: color .15s; }
    .footer-col a:hover { color: #fff; text-decoration: none; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.08); padding-top: 24px; display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
    .footer-legal { font-size: .75rem; color: rgba(255,255,255,.35); line-height: 1.7; max-width: 800px; }
    .footer-legal a { color: rgba(255,255,255,.45); }
    .footer-age { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border: 2px solid rgba(255,75,92,.6); border-radius: 50%; color: rgba(255,75,92,.8); font-weight: 800; font-size: .8rem; flex-shrink: 0; }

    /* ── GLOBAL PAGE CONTENT ── */
    .tcs-page-content { max-width: 1140px; margin: 0 auto; padding: 40px 24px; }
    .tcs-page-content h1 { font-size: clamp(1.8rem,3vw,2.6rem); font-weight:800; margin-bottom:18px; line-height:1.15; }
    .tcs-page-content h2 { font-size: clamp(1.3rem,2.5vw,1.9rem); font-weight:700; margin:32px 0 14px; }
    .tcs-page-content h3 { font-size:1.2rem; font-weight:700; margin:24px 0 10px; }
    .tcs-page-content p { color:rgba(255,255,255,.75); margin-bottom:14px; line-height:1.7; }
    .tcs-page-content ul, .tcs-page-content ol { margin:12px 0 16px 22px; color:rgba(255,255,255,.75); }
    .tcs-page-content li { margin-bottom:6px; line-height:1.6; }
    .tcs-page-content table { width:100%; border-collapse:collapse; margin:20px 0; font-size:.9rem; }
    .tcs-page-content th { background:rgba(255,255,255,.06); color:#fff; padding:10px 14px; text-align:left; font-weight:700; border-bottom:1px solid rgba(255,255,255,.1); }
    .tcs-page-content td { padding:10px 14px; color:rgba(255,255,255,.7); border-bottom:1px solid rgba(255,255,255,.06); }
    .tcs-page-content a { color:#ffcc33; }
    .tcs-page-content strong { color:#fff; }
    .tcs-page-content img { border-radius:8px; margin:16px 0; }

    /* Legacy WP classes that some pages use */
    .tcs-container { max-width:1140px; margin:0 auto; padding:0 24px; }
    .tcs-section { padding:64px 0; }
    .tcs-section--navy { background:#05051b; }
    .tcs-section--dark { background:#080829; }
    .tcs-heading-lg { font-size:clamp(1.4rem,3vw,2rem); font-weight:800; margin-bottom:10px; }
    .tcs-text-lead { color:rgba(255,255,255,.7); line-height:1.7; }
    .tcs-text-lead--narrow { max-width:600px; }
    .tcs-card { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:24px; }
    .bonus-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:24px; margin-top:32px; }
    .bonus-card { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:24px; text-align:center; }
    .bonus-icon { width:80px; height:80px; object-fit:contain; margin:0 auto 16px; }
    .bonus-title { font-size:1.1rem; font-weight:700; margin-bottom:10px; color:#ffcc33; }
    .bonus-text { font-size:.9rem; color:rgba(255,255,255,.7); line-height:1.6; margin-bottom:18px; }
    .bonus-btn { display:inline-flex; align-items:center; padding:10px 22px; background:#ffcc33; color:#05051b; font-weight:700; font-size:.9rem; border-radius:8px; text-decoration:none; }
    .bonus-btn:hover { background:#f4c045; text-decoration:none; }
    .region-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:20px; margin-top:32px; }
    .region-card { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:20px; text-align:center; }
    .region-img { width:100%; height:120px; object-fit:cover; border-radius:8px; margin-bottom:12px; }
    .region-title { font-weight:700; margin-bottom:8px; font-size:.95rem; }
    .region-text { font-size:.82rem; color:rgba(255,255,255,.6); line-height:1.5; margin-bottom:14px; }
    .region-btn { display:inline-flex; align-items:center; padding:8px 18px; background:#ffcc33; color:#05051b; font-weight:700; font-size:.82rem; border-radius:6px; text-decoration:none; }
    .safety-box { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:24px; max-width:700px; margin:0 auto; text-align:center; }
    .safety-title { font-weight:700; font-size:1.1rem; color:#ffcc33; margin-bottom:10px; }
    .safety-text { font-size:.9rem; color:rgba(255,255,255,.7); line-height:1.6; margin-bottom:18px; }
    .safety-btn { display:inline-flex; align-items:center; padding:10px 22px; background:#ffcc33; color:#05051b; font-weight:700; font-size:.9rem; border-radius:8px; text-decoration:none; }
  </style>
</body>
</html>
